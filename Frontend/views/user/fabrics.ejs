<div class="modal-overlay" id="modalOverlay">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-label" id="modalMode">Request Sample</div>
    <div class="modal-title" id="modalTitle">Fabric Name</div>
    <p class="modal-sub">Fill in your details and we'll get back within 4 working hours with pricing, availability, and sample dispatch info.</p>
    <form class="modal-form" action="/inquiry" method="POST">
      <input type="hidden" name="fabric" id="modalFabricInput">
      <input class="modal-input" type="text"  name="name"  placeholder="Your Name *" required>
      <input class="modal-input" type="tel"   name="phone" placeholder="Phone / WhatsApp *" required>
      <input class="modal-input" type="email" name="email" placeholder="Email Address">
      <input class="modal-input" type="text"  name="qty"   placeholder="Quantity Required (e.g. 500 metres)">
      <button class="modal-submit" type="submit">Send Enquiry →</button>
    </form>
  </div>
</div>

<%- include('partials/footer') %>