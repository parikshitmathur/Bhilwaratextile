      <% fabrics.forEach((f, i) => { %>
      <div class="fabric-card reveal delay-<%= (i%3)+1 %> <%= f.large ? 'large' : '' %>" data-category="<%= f.category %>">
        <div class="fabric-img-wrap">
          <img class="fabric-img" src="<%= f.img %>" alt="<%= f.name %>" loading="lazy">
          <% if(f.badge){ %><div class="fabric-badge <%= f.badgeClass %>"><%= f.badge %></div><% } %>
          <button class="fabric-wish" onclick="this.classList.toggle('wished');this.textContent=this.classList.contains('wished')?'❤️':'🤍'">🤍</button>
          
 <div class="fabric-swatches">
    <% if (f && f.swatches && Array.isArray(f.swatches)) { %>
        <% f.swatches.forEach(color => { %>
            <div class="swatch" "></div>
        <% }) %>
    <% } else { %>
        <span>No colors available</span>
    <% } %>
</div>
        </div> 

        <div class="fabric-body">
          <div class="fabric-cat"><%= f.catLabel %></div>
          <div class="fabric-name"><%= f.name %></div>
          <div class="fabric-desc"><%= f.desc %></div>
          <div class="fabric-meta">
            <div class="meta-item"><span class="meta-label">GSM</span><span class="meta-value"><%= f.gsm %></span></div>
            <div class="meta-item"><span class="meta-label">Min Order</span><span class="meta-value"><%= f.moq %></span></div>
            <div class="meta-item"><span class="meta-label">Width</span><span class="meta-value"><%= f.width %></span></div>
            <div class="meta-item"><span class="meta-label">Finish</span><span class="meta-value"><%= f.finish %></span></div>
          </div>
          <div class="fabric-actions">
            <button class="btn-enquire" onclick="openModal('<%= f.name %>')"><span>📩 Enquire Now</span></button>
            <button class="btn-sample" onclick="openModal('<%= f.name %>', true)">Request Sample</button>
          </div>
        </div>
      </div>
      <% }) %>

    </div><div class="load-more-wrap reveal">
      <button class="btn-load-more" id="loadMoreBtn"><span>Load More Fabrics</span></button>
    </div>
  </div>
