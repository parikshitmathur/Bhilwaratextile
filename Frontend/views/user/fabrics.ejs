<%- include('partials/header') %>

<div id="floatingIcons" style="position:fixed;inset:0;pointer-events:none;z-index:9989;overflow:hidden;"></div>

<div class="cursor-dot"  id="cursorDot"></div>
<div class="cursor-ring" id="cursorRing"></div>

<section class="page-hero">
  <div class="page-hero-bg"></div>
  <img class="page-hero-img" src="https://images.unsplash.com/photo-1558171813-0a3de81ff4cb?auto=format&fit=crop&q=80&w=1600" alt="Fabric rolls background">

  <svg class="hero-weave" viewBox="0 0 500 600" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
    <% for(let i=0;i<12;i++){ %>
    <line x1="0" y1="<%= i*50 %>" x2="500" y2="<%= i*50 + 200 %>" stroke="#c8962a" stroke-width=".8" opacity="0.6"/>
    <% } %>
    <% for(let i=0;i<10;i++){ %>
    <line x1="<%= i*55 %>" y1="0" x2="<%= i*55 - 100 %>" y2="600" stroke="#c8962a" stroke-width=".5" opacity="0.4"/>
    <% } %>
  </svg>

  <div class="page-hero-inner">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <span style="color:rgba(255,255,255,.55)">Our Fabrics</span>
    </div>
    <p class="page-hero-label">Our Collection</p>
    <h1 class="page-hero-title">
      Premium Fabrics<br>
      <em>Direct From the Loom</em>
    </h1>
    <p class="page-hero-sub">
      1200+ fabric patterns. 4 core categories. Zero middlemen. 
      Everything you need for suitings, shirtings, uniforms and beyond — 
      straight from Bhilwara's finest manufacturing units.
    </p>
  </div>
</section>

<div class="marquee-strip">
  <div class="marquee-track">
    <% ['Cotton Suitings','Poly-Viscose Blends','Uniform Fabrics','Premium Shirtings','Woolen Blends','Custom Dyeing','ISO Certified','Direct from Mill','Cotton Suitings','Poly-Viscose Blends','Uniform Fabrics','Premium Shirtings','Woolen Blends','Custom Dyeing','ISO Certified','Direct from Mill'].forEach(t => { %>
    <div class="marquee-item"><span class="marquee-dot"></span><%= t %></div>
    <% }) %>
  </div>
</div>

<div class="feature-banner reveal">
  <div class="feature-banner-inner">
    <div class="fb-left">
      <div class="fb-label">Why Order From Us</div>
      <h3>Mill-Direct Quality. <em>Wholesale Pricing.</em></h3>
      <p>No agents. No markup. We manufacture and supply — you get the best price on the best fabric.</p>
    </div>
    <div class="fb-stats">
      <div class="fb-stat">
        <div class="fb-stat-num" data-count="1200">0</div>
        <div class="fb-stat-lbl">Patterns</div>
      </div>
      <div class="fb-stat">
        <div class="fb-stat-num" data-count="4">0</div>
        <div class="fb-stat-lbl">Categories</div>
      </div>
      <div class="fb-stat">
        <div class="fb-stat-num" data-count="72">0</div>
        <div class="fb-stat-lbl">Hr Dispatch</div>
      </div>
      <div class="fb-stat">
        <div class="fb-stat-num" data-count="100">0</div>
        <div class="fb-stat-lbl">Min. Metres</div>
      </div>
    </div>
  </div>
</div>

<section class="filter-section">
  <div class="filter-inner">
    <div class="filter-top reveal">
      <div>
        <div class="filter-title">All Fabrics</div>
        <div class="filter-count" id="fabricCount">Showing all 12 fabrics</div>
      </div>
      <div class="grid-toggle">
        <button class="grid-btn active" id="btn3col" title="3 columns">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="4" height="4" stroke-width="1.5"/><rect x="6" y="1" width="4" height="4" stroke-width="1.5"/><rect x="11" y="1" width="4" height="4" stroke-width="1.5"/><rect x="1" y="7" width="4" height="4" stroke-width="1.5"/><rect x="6" y="7" width="4" height="4" stroke-width="1.5"/><rect x="11" y="7" width="4" height="4" stroke-width="1.5"/></svg>
        </button>
        <button class="grid-btn" id="btn2col" title="2 columns">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" stroke-width="1.5"/><rect x="9" y="1" width="6" height="6" stroke-width="1.5"/><rect x="1" y="9" width="6" height="6" stroke-width="1.5"/><rect x="9" y="9" width="6" height="6" stroke-width="1.5"/></svg>
        </button>
        <button class="grid-btn" id="btn1col" title="List view">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="14" height="4" stroke-width="1.5"/><rect x="1" y="7" width="14" height="4" stroke-width="1.5"/><rect x="1" y="13" width="14" height="2" stroke-width="1.5"/></svg>
        </button>
      </div>
    </div>
    <div class="filter-tags reveal delay-1" id="filterTags">
      <button class="filter-btn active" data-filter="all"><span>All Fabrics</span></button>
      <button class="filter-btn" data-filter="suiting"><span>Suitings</span></button>
      <button class="filter-btn" data-filter="shirting"><span>Shirtings</span></button>
      <button class="filter-btn" data-filter="uniform"><span>Uniforms</span></button>
      <button class="filter-btn" data-filter="woolen"><span>Woolen Blends</span></button>
      <button class="filter-btn" data-filter="custom"><span>Custom Range</span></button>
    </div>
  </div>
</section>

