<%- include('partials/header') %>

<!-- FontAwesome for Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    /* 💎 CORE ELITE STYLES */
    body { background: #000000; color: #fff; overflow-x: hidden; scroll-behavior: smooth; }
    
    .gold-text {
        background: linear-gradient(to right, #C9922A, #fde68a, #C9922A);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-size: 200% auto;
        animation: textShine 4s linear infinite;
    }
    @keyframes textShine { to { background-position: 200% center; } }

    /* Typography & Layout Fixes */
    .hero-title { line-height: 0.85; letter-spacing: -0.04em; }
    
    .elite-card { 
        background: rgba(10, 10, 12, 0.8); 
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.03);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .elite-card:hover { border-color: #C9922A; transform: translateY(-8px); shadow: 0 20px 40px rgba(201, 146, 42, 0.1); }

    /* Google FAQ Logic */
    .paa-card { border-bottom: 1px solid rgba(255,255,255,0.05); transition: 0.3s; }
    .paa-question { cursor: pointer; padding: 20px 0; display: flex; justify-content: space-between; align-items: center; }
    .paa-answer { max-height: 0; overflow: hidden; transition: all 0.4s ease; color: #a1a1aa; font-style: italic; }
    .paa-active .paa-answer { max-height: 200px; padding-bottom: 20px; }
    .paa-active i { transform: rotate(180deg); color: #C9922A; }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: #000; }
    ::-webkit-scrollbar-thumb { background: #C9922A; border-radius: 10px; }
</style>

<div class="min-h-screen">

    <!-- 🏗️ SECTION 1: HERO -->
<!-- Yahan loop lagao agar multiple slides dikhani hain -->
<% slides.forEach(slide => { %>
<section class="relative pt-32 pb-20 px-6 overflow-hidden bg-black">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#C9922A]/5 blur-[100px] rounded-full pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 z-10">
            <span class="text-[10px] font-black text-[#C9922A] uppercase tracking-[0.6em] mb-4 block italic"><%= slide.tagline %></span>
            <h1 class="hero-title text-6xl md:text-8xl font-black italic uppercase mb-8">
                <span class="block text-white"><%= slide.titleMain %></span>
                <span class="text-[#C9922A] block mt-2"><%= slide.titleGold %></span>
            </h1>
            <p class="text-zinc-400 text-sm md:text-base leading-relaxed mb-8 italic border-l-2 border-[#C9922A]/40 pl-6 max-w-xl">
                <%= slide.description %>
            </p>
            <div class="flex gap-10">
                <div>
                    <h4 class="text-3xl font-black text-white italic"><%= slide.stat1_value %></h4>
                    <p class="text-[9px] text-zinc-500 uppercase font-bold tracking-widest mt-1"><%= slide.stat1_label %></p>
                </div>
                <div>
                    <h4 class="text-3xl font-black text-white italic"><%= slide.stat2_value %></h4>
                    <p class="text-[9px] text-zinc-500 uppercase font-bold tracking-widest mt-1"><%= slide.stat2_label %></p>
                </div>
            </div>
        </div>

        <div class="lg:col-span-5 relative">
            <div class="relative rounded-[3rem] overflow-hidden border border-zinc-800 shadow-2xl aspect-[4/5] group">
                <img src="<%= slide.imageURL %>" class="w-full h-full object-cover opacity-40 grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000">
                <div class="absolute inset-0 bg-gradient-to-t from-[#000] via-transparent to-transparent"></div>
            </div>
            <div class="absolute -bottom-4 -left-4 bg-[#C9922A] text-black px-5 py-2 rounded-xl font-black text-[9px] uppercase tracking-widest shadow-2xl rotate-[-2deg]">
                <%= slide.badgeText %>
            </div>
        </div>
    </div>
</section>
<% }) %>

    <!-- 🏭 SECTION 2: INDUSTRIAL ECOSYSTEM -->
    <section class="py-20 bg-[#050507] border-y border-zinc-900">
        <div class="max-w-7xl mx-auto px-6 text-center mb-16">
            <h2 class="text-3xl font-black italic uppercase tracking-tighter">Trade <span class="gold-text">Ecosystem</span></h2>
            <p class="text-zinc-500 text-[9px] font-black uppercase mt-2 tracking-[0.4em]">Integrated Manufacturing</p>
        </div>
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="elite-card p-8 rounded-[2.5rem]">
                <i class="fas fa-microchip text-amber-600 text-xl mb-6 block"></i>
                <h4 class="text-md font-black uppercase italic text-white mb-3">Smart Spinning</h4>
                <p class="text-[11px] text-zinc-500 leading-relaxed italic">Advanced ring aur open-end technology jo world-class yarn taiyar karti hai.</p>
            </div>
            <div class="elite-card p-8 rounded-[2.5rem]">
                <i class="fas fa-layer-group text-blue-500 text-xl mb-6 block"></i>
                <h4 class="text-md font-black uppercase italic text-white mb-3">Fabric Processing</h4>
                <p class="text-[11px] text-zinc-500 leading-relaxed italic">Modern dyeing plants jo kapde ko global standards ke hisab se "Elite" banate hain.</p>
            </div>
            <div class="elite-card p-8 rounded-[2.5rem]">
                <i class="fas fa-truck-fast text-green-500 text-xl mb-6 block"></i>
                <h4 class="text-md font-black uppercase italic text-white mb-3">Global Supply</h4>
                <p class="text-[11px] text-zinc-500 leading-relaxed italic">Efficient logistics network jo Bhilwara se direct port tak mal pahunchata hai.</p>
            </div>
        </div>
    </section>

    <!-- 🧶 SECTION 3: FABRIC SEGMENTS -->
    <section class="py-20 bg-black relative">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-12">
                <h2 class="text-4xl font-black italic uppercase tracking-tighter">Fabric <span class="gold-text">Segments</span></h2>
                <p class="text-zinc-600 text-[10px] font-black uppercase tracking-[0.4em] mt-2">Bhilwara's Core Expertise</p>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <% ['PV Suiting', 'Cotton Blends', 'Denim & Canvas', 'Technical Textiles'].forEach((fabric, i) => { %>
                <div class="p-6 border border-zinc-900 rounded-2xl hover:bg-zinc-900/40 transition-all group">
                    <p class="text-[#C9922A] font-black text-lg mb-1 italic">0<%= i+1 %></p>
                    <h4 class="text-white font-bold uppercase tracking-tight text-xs group-hover:text-[#C9922A]"><%= fabric %></h4>
                    <p class="text-[9px] text-zinc-500 mt-2 italic leading-relaxed">High-performance manufacturing for global markets.</p>
                </div>
                <% }) %>
            </div>
        </div>
    </section>

    <!-- 🛡️ SECTION 4: VERIFIED PARTNERS -->
    <section class="py-20 bg-[#050507]">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex justify-between items-end mb-12">
                <div>
                    <h2 class="text-4xl font-black italic uppercase tracking-tighter">Verified <span class="gold-text">Partners</span></h2>
                    <p class="text-zinc-600 text-[10px] font-black uppercase tracking-widest mt-2">Elite Industrialists</p>
                </div>
                <a href="/verified-sellers" class="text-[10px] font-black uppercase tracking-widest text-[#C9922A] border-b border-[#C9922A]/20 pb-1 hover:text-white transition-all italic">Explore All</a>
            </div>
            <div id="topPartners" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Loaded by JavaScript -->
            </div>
        </div>
    </section>

    <!-- 🔍 SECTION 5: PEOPLE ALSO ASK -->
   <!-- 🔍 SECTION: PEOPLE ALSO ASK (EXPANDED) -->
<section class="py-20 bg-black">
    <div class="max-w-2xl mx-auto px-6">
        <!-- Google Style Header -->
        <div class="flex items-center gap-3 mb-8 pb-4 border-b border-zinc-900">
            <i class="fab fa-google text-blue-500 text-lg"></i>
            <h3 class="text-lg font-bold text-white tracking-tight">People also ask</h3>
        </div>

        <div class="space-y-1">
            <!-- Q1 -->
            <div class="paa-card" onclick="togglePAA(this)">
                <div class="paa-question text-[11px] font-black text-white uppercase tracking-wider">
                    Bhilwara kis cheez ke liye sabse zyada prasiddh hai?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="paa-answer text-[11px] leading-relaxed italic">
                    Bhilwara ko "Synthetic Suiting Capital of India" kaha jata hai. Yeh Polyester-Viscose (PV) suiting ka sabse bada hub hai, jahan se poore desh aur videshon mein premium kapda supply hota hai.
                </div>
            </div>

            <!-- Q2 -->
            <div class="paa-card" onclick="togglePAA(this)">
                <div class="paa-question text-[11px] font-black text-white uppercase tracking-wider">
                    Kya hum factory se direct bulk inquiry kar sakte hain?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="paa-answer text-[11px] leading-relaxed italic">
                    Ji haan, Bhilwara Textile portal ka maksad hi manufacturers aur buyers ko direct connect karna hai. Aap kisi bhi verified seller ki profile par jaakar direct inquiry bhej sakte hain.
                </div>
            </div>

            <!-- Q3 -->
            <div class="paa-card" onclick="togglePAA(this)">
                <div class="paa-question text-[11px] font-black text-white uppercase tracking-wider">
                    Vastra Nagri ko "Manchester of Rajasthan" kyun kehte hain?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="paa-answer text-[11px] leading-relaxed italic">
                    Apni vishal textile production capacity aur spinning units ki wajah se ise Manchester ki upadhi di gayi hai. Yahan har saal 1 billion meters se zyada fabric produce hota hai.
                </div>
            </div>

            <!-- Q4 -->
            <div class="paa-card" onclick="togglePAA(this)">
                <div class="paa-question text-[11px] font-black text-white uppercase tracking-wider">
                    Yahan kis-kis tarah ke fabric ki variety milti hai?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="paa-answer text-[11px] leading-relaxed italic">
                    PV Suiting ke alawa, Bhilwara mein Cotton Blends, Denim, Technical Textiles, Corporate Uniform fabrics aur specialized Shirting ki vishal range available hai.
                </div>
            </div>

            <!-- Q5 -->
            <div class="paa-card" onclick="togglePAA(this)">
                <div class="paa-question text-[11px] font-black text-white uppercase tracking-wider">
                    Bhilwara ke fabric ki quality check kaise hoti hai?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="paa-answer text-[11px] leading-relaxed italic">
                    Yahan ki adhiktar mills ISO certified hain aur in-house NABL accredited labs ka use karti hain, taaki colorfastness aur durability ke global standards maintain rahein.
                </div>
            </div>

            <!-- Q6 -->
            <div class="paa-card" onclick="togglePAA(this)">
                <div class="paa-question text-[11px] font-black text-white uppercase tracking-wider">
                    Export orders ke liye logistics ki kya suvidha hai?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="paa-answer text-[11px] leading-relaxed italic">
                    Bhilwara ka transport network India ke har bade port se juda hai. Yahan dedicated ICD (Inland Container Depot) suvidha hai jo export consignments ko smooth banati hai.
                </div>
            </div>

            <!-- Q7 -->
            <div class="paa-card" onclick="togglePAA(this)">
                <div class="paa-question text-[11px] font-black text-white uppercase tracking-wider">
                    Kya naye traders ko small MOQs ki suvidha milti hai?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="paa-answer text-[11px] leading-relaxed italic">
                    Kai verified partners startups ke liye flexible MOQs (Minimum Order Quantity) offer karte hain. Aap seller se unke specific terms ke bare mein direct baat kar sakte hain.
                </div>
            </div>

        </div>
    </div>
</section>

</div>

<script>
    // 🛡️ Load Partners with Icon Fallback
    async function loadPartners() {
        try {
            const res = await fetch('/api/merchants/list');
            const data = await res.json();
            const top4 = data.slice(0, 4);
            
            document.getElementById('topPartners').innerHTML = top4.map(m => {
                const logoContent = m.logo 
                    ? `<img src="${m.logo}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500">`
                    : `<div class="w-full h-full flex items-center justify-center bg-zinc-900 text-zinc-700 group-hover:text-[#C9922A] transition-colors">
                         <i class="fas fa-industry text-2xl"></i>
                       </div>`;

                return `
                    <div class="elite-card p-8 rounded-[2.5rem] flex flex-col items-center text-center group">
                        <div class="w-16 h-16 bg-zinc-950 border border-zinc-800 rounded-2xl mb-5 overflow-hidden flex-shrink-0">
                            ${logoContent}
                        </div>
                        <h4 class="text-xs font-black text-white uppercase mb-1 line-clamp-1 italic">${m.companyName}</h4>
                        <p class="text-[8px] text-[#C9922A] font-bold uppercase tracking-[0.2em] mb-6">${m.city || 'Bhilwara'}</p>
                        <a href="/merchant/${m._id}" class="inline-block w-full py-3 bg-zinc-900/50 border border-zinc-800 rounded-xl text-[9px] font-black uppercase tracking-widest text-zinc-400 group-hover:bg-[#C9922A] group-hover:text-black transition-all">View Profile</a>
                    </div>
                `;
            }).join('');
        } catch (err) { console.error("Error loading merchants:", err); }
    }

    // 🔍 Toggle Accordion
    function togglePAA(el) {
        document.querySelectorAll('.paa-card').forEach(c => { if(c !== el) c.classList.remove('paa-active'); });
        el.classList.toggle('paa-active');
    }

    loadPartners();
</script>

<%- include('partials/footer') %>