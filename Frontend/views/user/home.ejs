<style>
    :root {
        --amber-glow: #d97706;
        --card-bg: rgba(255, 255, 255, 0.03);
    }

    /* Section padding 80px se ghata kar 40px kar di */
    .bt-elite-slider {
        position: relative;
        width: 100%;
        overflow: hidden;
        background: #050505;
        padding: 40px 0; 
    }

    .slider__nav { display: none; }

    .slider__inner {
        display: flex;
        transition: transform 0.6s cubic-bezier(0.7, 0, 0.3, 1);
        width: 100%;
    }

    /* Horizontal gap kam karne ke liye padding 10px ki */
    .slider__contents {
        min-width: 100%;
        padding: 0 10px; 
        box-sizing: border-box;
    }

    @media (min-width: 1024px) {
        .slider__contents { min-width: 33.33%; }
    }

    /* Dots ka top margin 40px se 20px kiya */
    .slider__dots {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 20px;
    }

    .slider__label {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.2);
        cursor: pointer;
        transition: 0.3s;
    }

    #s1:checked ~ .slider__inner { transform: translateX(0%); }
    #s2:checked ~ .slider__inner { transform: translateX(-100%); }
    #s3:checked ~ .slider__inner { transform: translateX(-200%); }
    #s4:checked ~ .slider__inner { transform: translateX(-300%); }

    #s1:checked ~ .slider__dots label[for="s1"],
    #s2:checked ~ .slider__dots label[for="s2"],
    #s3:checked ~ .slider__dots label[for="s3"],
    #s4:checked ~ .slider__dots label[for="s4"] {
        background: var(--amber-glow);
        transform: scale(1.2);
    }

    /* Card padding 40px se 24px (p-6 equivalent) kar di */
    .elite-review-card {
        background: var(--card-bg);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1.5rem;
        padding: 24px; 
        height: 100%;
        backdrop-filter: blur(10px);
        transition: 0.4s;
    }

    .elite-review-card:hover {
        border-color: var(--amber-glow);
    }
</style>

<section class="bt-elite-slider">
    <div class="max-w-7xl mx-auto px-6">
        
        <div class="mb-6 text-center md:text-left">
            <h2 class="text-2xl font-black text-white uppercase italic">Elite <span class="text-amber-600">Reviews</span></h2>
            <p class="text-gray-500 text-[9px] uppercase tracking-[0.2em] mt-1">Woven with trust since 1975</p>
        </div>

        <input type="radio" name="slider" id="s1" checked class="slider__nav">
        <input type="radio" name="slider" id="s2" class="slider__nav">
        <input type="radio" name="slider" id="s3" class="slider__nav">
        <input type="radio" name="slider" id="s4" class="slider__nav">

        <div class="slider__inner">
            <% if (testimonials && testimonials.length > 0) { %>
                <% testimonials.forEach((t, index) => { %>
                    <div class="slider__contents">
                        <div class="elite-review-card">
                            <div class="flex gap-1 mb-3">
                                <% for(let i=0; i < (t.rating || 5); i++) { %>
                                    <i class="fa-solid fa-star text-amber-500 text-[8px]"></i>
                                <% } %>
                            </div>
                            
                            <p class="text-gray-300 text-sm italic leading-snug mb-4">
                                "<%= t.description %>"
                            </p>

                            <div class="flex items-center gap-3 border-t border-white/5 pt-3">
                                <div class="w-8 h-8 rounded-full bg-amber-600 flex items-center justify-center font-black text-black text-xs">
                                    <%= t.name.charAt(0) %>
                                </div>
                                <div>
                                    <h4 class="text-white font-bold uppercase text-[10px] tracking-wider"><%= t.name %></h4>
                                    <p class="text-amber-600 text-[7px] font-black uppercase">Verified Buyer</p>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>

        <div class="slider__dots">
            <label for="s1" class="slider__label"></label>
            <label for="s2" class="slider__label"></label>
            <label for="s3" class="slider__label"></label>
            <label for="s4" class="slider__label"></label>
        </div>

    </div>
</section>


