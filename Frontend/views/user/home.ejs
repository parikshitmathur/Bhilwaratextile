<%- include('partials/header') %>

<!-- ═══════════════════════════════════════════
  BHILWARA TEXTILE AUTHORITY — HOMEPAGE
  Author: Premium UI Redesign
  Classes/IDs: All renamed with "btx-" prefix
═══════════════════════════════════════════ -->

<!-- ── GOOGLE FONTS ── -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,500;0,700;1,300;1,700&family=Playfair+Display:ital,wght@1,900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
<title><%= title %> | Bhilwara Textile B2B Portal</title>
<meta name="description" content="Find premium <%= title %> from verified manufacturers in Bhilwara. Direct B2B access to Rajasthan's finest textile hub.">
<meta name="keywords" content="Bhilwara Textile, <%= title %>, Fabric Manufacturers, Rajasthan Textile, B2B Textile Portal">
<style>
/* ══════════════════════════════════════
   ROOT TOKENS
══════════════════════════════════════ */
:root {
  --gold:      #C9922A;
  --gold-lt:   #f5c163;
  --gold-dk:   #9a6c18;
  --ink:       #0a0a0b;
  --ink-soft:  #111318;
  --slate:     #1c1f26;
  --off-white: #f6f3ee;
  --muted:     #6b7280;
  --border:    rgba(255,255,255,0.08);
  --font-hero: 'Bebas Neue', sans-serif;
  --font-body: 'DM Sans', sans-serif;
  --font-italic: 'Playfair Display', serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: var(--font-body);
  background: var(--ink);
  color: #fff;
  overflow-x: hidden;
}

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
.btx-hero {
  position: relative;
  min-height: 100svh;
  background: var(--ink);
  overflow: hidden;
  display: flex;
  align-items: center;
}

/* noise grain overlay */
.btx-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.03;
  pointer-events: none;
  z-index: 1;
}

/* diagonal gold accent */
.btx-hero::after {
  content: '';
  position: absolute;
  top: -30%;
  right: -10%;
  width: 55%;
  height: 140%;
  background: linear-gradient(135deg, rgba(201,146,42,0.06) 0%, transparent 60%);
  transform: skewX(-8deg);
  pointer-events: none;
  z-index: 1;
}

.btx-hero-slider-wrap {
  width: 100%;
  position: relative;
  z-index: 2;
}

.btx-hero-slide {
  display: none;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 80px 6% 80px;
  gap: 40px;
  min-height: 100svh;
}

.btx-hero-slide.btx-active {
  display: flex;
  animation: btxHeroIn 1s cubic-bezier(0.22,1,0.36,1) forwards;
}

@keyframes btxHeroIn {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* TEXT SIDE */
.btx-hero-text {
  flex: 1;
  max-width: 620px;
}

.btx-hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 22px;
}

.btx-hero-eyebrow::before {
  content: '';
  display: block;
  width: 28px;
  height: 1px;
  background: var(--gold);
}

.btx-hero-title {
  font-family: var(--font-hero);
  font-size: clamp(3.2rem, 7vw, 7rem);
  line-height: 0.95;
  letter-spacing: 0.01em;
  color: #fff;
  margin-bottom: 24px;
}

.btx-hero-title em {
  font-family: var(--font-italic);
  color: var(--gold);
  font-style: italic;
  letter-spacing: 0;
}

.btx-hero-sub {
  font-size: clamp(0.9rem, 1.2vw, 1.1rem);
  color: rgba(255,255,255,0.5);
  line-height: 1.8;
  max-width: 480px;
  margin-bottom: 40px;
  font-weight: 300;
}

.btx-hero-cta {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: center;
}

.btx-btn-primary {
  background: var(--gold);
  color: #000;
  padding: 16px 36px;
  border-radius: 6px;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  transition: all 0.3s ease;
  border: 2px solid var(--gold);
}

.btx-btn-primary:hover {
  background: transparent;
  color: var(--gold);
  transform: translateY(-2px);
}

.btx-btn-ghost {
  background: transparent;
  color: rgba(255,255,255,0.7);
  padding: 14px 28px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  text-decoration: none;
  border: 1px solid rgba(255,255,255,0.15);
  transition: all 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btx-btn-ghost:hover {
  border-color: var(--gold);
  color: var(--gold);
}

/* VISUAL SIDE */
.btx-hero-visual {
  flex-shrink: 0;
  position: relative;
}

.btx-hero-img-wrap {
  width: clamp(260px, 32vw, 440px);
  height: clamp(340px, 42vw, 570px);
  border-radius: 40px;
  overflow: hidden;
  border: 1px solid rgba(201,146,42,0.2);
  box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 60px rgba(201,146,42,0.08);
  position: relative;
}

.btx-hero-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s ease;
}

.btx-hero-img-wrap:hover img { transform: scale(1.04); }

.btx-hero-badge {
  position: absolute;
  bottom: -24px;
  left: -24px;
  background: var(--gold);
  color: #000;
  padding: 22px 24px;
  border-radius: 24px;
  font-family: var(--font-hero);
  box-shadow: 0 20px 40px rgba(201,146,42,0.3);
  text-align: center;
  z-index: 3;
}

.btx-hero-badge strong {
  display: block;
  font-size: 2.4rem;
  line-height: 1;
}

.btx-hero-badge span {
  font-size: 9px;
  font-weight: 900;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  line-height: 1.3;
  display: block;
  margin-top: 4px;
  font-family: var(--font-body);
}

/* slide dots */
.btx-hero-dots {
  position: absolute;
  bottom: 36px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8px;
  z-index: 10;
}

.btx-hero-dot {
  width: 6px;
  height: 6px;
  border-radius: 999px;
  background: rgba(255,255,255,0.25);
  transition: all 0.4s ease;
  cursor: pointer;
}

.btx-hero-dot.btx-active {
  width: 28px;
  background: var(--gold);
}

/* RESPONSIVE HERO */
@media (max-width: 768px) {
  .btx-hero-slide {
    flex-direction: column;
    padding: 100px 5% 80px;
    justify-content: center;
    text-align: center;
    gap: 36px;
  }
  .btx-hero-eyebrow { justify-content: center; }
  .btx-hero-sub { margin-inline: auto; }
  .btx-hero-cta { justify-content: center; }
  .btx-hero-visual { width: 100%; display: flex; justify-content: center; }
  .btx-hero-img-wrap { width: 260px; height: 320px; }
  .btx-hero-badge { left: -10px; }
}

/* ══════════════════════════════════════
   MARQUEE
══════════════════════════════════════ */
.btx-marquee-wrap {
  width: 100%;
  overflow: hidden;
  background: var(--gold);
  padding: 14px 0;
  border-top: 1px solid rgba(0,0,0,0.1);
  border-bottom: 1px solid rgba(0,0,0,0.1);
}

.btx-marquee-track {
  display: flex;
  width: max-content;
  align-items: center;
  gap: 60px;
  animation: btxMarquee 30s linear infinite;
}

.btx-marquee-wrap:hover .btx-marquee-track { animation-play-state: paused; }

@keyframes btxMarquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

.btx-marquee-item {
  display: flex;
  align-items: center;
  gap: 12px;
  color: #000;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  white-space: nowrap;
}

.btx-marquee-item svg {
  width: 14px;
  height: 14px;
  opacity: 0.5;
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .btx-marquee-item { font-size: 10px; gap: 10px; }
  .btx-marquee-track { gap: 40px; animation-duration: 18s; }
}

/* ══════════════════════════════════════
   QUICK ACCESS CARDS
══════════════════════════════════════ */
.btx-access-section {
  background: var(--off-white);
  padding: 80px 5%;
}

.btx-access-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 1200px;
  margin: auto;
}

.btx-access-card {
  background: #fff;
  border-radius: 20px;
  padding: 44px 32px;
  text-align: center;
  text-decoration: none;
  display: block;
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(0,0,0,0.06);
  transition: all 0.4s ease;
  box-shadow: 0 4px 24px rgba(0,0,0,0.05);
}

.btx-access-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: var(--gold);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s ease;
}

.btx-access-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 24px 60px rgba(0,0,0,0.12);
}

.btx-access-card:hover::after { transform: scaleX(1); }

.btx-access-icon {
  width: 68px;
  height: 68px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
  transition: transform 0.3s ease;
}

.btx-access-card:hover .btx-access-icon { transform: scale(1.1) rotate(4deg); }

.btx-access-icon svg { width: 28px; height: 28px; }

.btx-access-title {
  font-size: 1.1rem;
  font-weight: 700;
  color: #111;
  margin-bottom: 12px;
}

.btx-access-divider {
  width: 32px;
  height: 2px;
  background: #e5e7eb;
  margin: 0 auto 14px;
  border-radius: 999px;
  transition: all 0.4s ease;
}

.btx-access-card:hover .btx-access-divider {
  width: 56px;
  background: var(--gold);
}

.btx-access-desc {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.7;
}

@media (max-width: 768px) {
  .btx-access-grid { grid-template-columns: 1fr; gap: 16px; }
  .btx-access-section { padding: 60px 5%; }
}

/* ══════════════════════════════════════
   CATEGORY SLIDER
══════════════════════════════════════ */
.btx-cat-section {
  background: var(--off-white);
  padding: 20px 0 60px;
}

.btx-cat-inner {
  max-width: 1300px;
  margin: auto;
  padding: 0 5%;
}

.btx-cat-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 40px;
  flex-wrap: wrap;
  gap: 16px;
}

.btx-section-eyebrow {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 10px;
}

.btx-section-title {
  font-family: var(--font-hero);
  font-size: clamp(2rem, 4vw, 3rem);
  color: #111;
  line-height: 1;
  letter-spacing: 0.02em;
}

.btx-section-title span { color: var(--gold); }

.btx-section-desc {
  font-size: 13px;
  color: var(--muted);
  margin-top: 8px;
  font-weight: 400;
}

.btx-nav-pair {
  display: flex;
  gap: 10px;
  flex-shrink: 0;
}

.btx-nav-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid #ddd;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  font-size: 13px;
  color: #555;
}

.btx-nav-btn:hover {
  background: #111;
  color: #fff;
  border-color: #111;
  transform: translateY(-2px);
}

/* Category card */
.btx-cat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  transition: transform 0.35s ease;
}

.btx-cat-card:hover { transform: translateY(-6px); }

.btx-cat-img-ring {
  width: 110px;
  height: 110px;
  border-radius: 50%;
  overflow: hidden;
  background: #fff;
  padding: 3px;
  border: 2px solid transparent;
  box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  transition: all 0.35s ease;
  position: relative;
}

.btx-cat-card:hover .btx-cat-img-ring {
  border-color: var(--gold);
  box-shadow: 0 12px 32px rgba(201,146,42,0.25);
}

.btx-cat-img-ring img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.btx-cat-card:hover .btx-cat-img-ring img { transform: scale(1.1); }

.btx-cat-overlay {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: 0.35s ease;
  color: #fff;
  font-size: 15px;
}

.btx-cat-card:hover .btx-cat-overlay { opacity: 1; }

.btx-cat-name {
  margin-top: 16px;
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #111;
  text-align: center;
}

.btx-cat-sub {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #aaa;
  margin-top: 4px;
}

/* Modal */
.btx-modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: none;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(8px);
  align-items: center;
  justify-content: center;
}

.btx-modal-overlay.btx-open { display: flex; }

.btx-modal-box {
  background: #fff;
  width: 92%;
  max-width: 480px;
  border-radius: 28px;
  overflow: hidden;
  box-shadow: 0 40px 80px rgba(0,0,0,0.3);
  transform: scale(0.93);
  opacity: 0;
  transition: all 0.3s ease;
}

.btx-modal-overlay.btx-open .btx-modal-box {
  transform: scale(1);
  opacity: 1;
}

.btx-modal-head {
  background: #111;
  color: #fff;
  padding: 28px 28px 22px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.btx-modal-label {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 6px;
}

.btx-modal-title {
  font-family: var(--font-hero);
  font-size: 1.6rem;
  letter-spacing: 0.05em;
}

.btx-modal-close {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: none;
  cursor: pointer;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.btx-modal-close:hover { background: var(--gold); color: #000; }

.btx-modal-body {
  padding: 28px;
}

.btx-modal-sub-label {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #aaa;
  margin-bottom: 18px;
}

.btx-subcat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.btx-subcat-item {
  background: #f9f9f9;
  border: 1px solid #eee;
  border-radius: 14px;
  padding: 14px 18px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #333;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.3s ease;
}

.btx-subcat-item:hover {
  background: #fff8ed;
  border-color: var(--gold);
  color: var(--gold-dk);
}

/* ══════════════════════════════════════
   HERITAGE SECTION
══════════════════════════════════════ */
.btx-heritage {
  background: var(--ink);
  padding: 100px 5%;
  overflow: hidden;
}

.btx-heritage-inner {
  max-width: 1280px;
  margin: auto;
}

.btx-heritage-header { margin-bottom: 70px; }

.btx-heritage-pre {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.45em;
  color: var(--gold);
  text-transform: uppercase;
  margin-bottom: 16px;
}

.btx-heritage-title {
  font-family: var(--font-hero);
  font-size: clamp(2.8rem, 6vw, 5.5rem);
  line-height: 0.9;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.btx-heritage-title em {
  font-family: var(--font-italic);
  color: var(--gold);
  font-style: italic;
}

.btx-heritage-rule {
  width: 56px;
  height: 3px;
  background: var(--gold);
  margin-top: 24px;
  border-radius: 2px;
}

.btx-heritage-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

/* image side */
.btx-heritage-img-col { position: relative; }

.btx-heritage-img-frame {
  position: relative;
  z-index: 2;
  border-radius: 40px;
  overflow: hidden;
  border: 1px solid var(--border);
}

.btx-heritage-img-frame img {
  width: 100%;
  height: 500px;
  object-fit: cover;
  filter: grayscale(1);
  transition: filter 0.8s ease;
  display: block;
}

.btx-heritage-img-frame:hover img { filter: grayscale(0); }

.btx-heritage-img-frame::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10,10,11,0.6) 0%, transparent 60%);
}

.btx-heritage-stat-card {
  position: absolute;
  bottom: -20px;
  right: -20px;
  z-index: 10;
  background: #fff;
  padding: 28px 32px;
  border-radius: 24px;
  text-align: center;
  border: 3px solid var(--gold);
  box-shadow: 0 20px 50px rgba(0,0,0,0.2);
  color: #000;
}

.btx-heritage-stat-card strong {
  font-family: var(--font-hero);
  font-size: 3rem;
  color: var(--gold-dk);
  display: block;
  line-height: 1;
}

.btx-heritage-stat-card span {
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  line-height: 1.4;
  display: block;
  margin-top: 6px;
  color: #555;
}

.btx-heritage-glow {
  position: absolute;
  top: -60px;
  left: -60px;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: rgba(201,146,42,0.12);
  filter: blur(80px);
  pointer-events: none;
}

/* text side */
.btx-heritage-text-col { color: #fff; }

.btx-heritage-text-col h3 {
  font-size: 1.4rem;
  font-weight: 700;
  margin-bottom: 18px;
  color: #fff;
}

.btx-heritage-text-col p {
  color: rgba(255,255,255,0.5);
  line-height: 1.9;
  font-size: 14px;
  font-weight: 300;
  margin-bottom: 32px;
}

.btx-feature-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 40px;
}

.btx-feat-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 22px 20px;
  transition: all 0.35s ease;
}

.btx-feat-card:hover {
  background: rgba(255,255,255,0.07);
  border-color: rgba(201,146,42,0.3);
}

.btx-feat-icon {
  width: 44px;
  height: 44px;
  background: var(--gold);
  border-radius: 12px;
