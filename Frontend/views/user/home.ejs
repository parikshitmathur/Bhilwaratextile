<!-- ═══════════════════════════════════════════
  HERO
═══════════════════════════════════════════ -->
<section class="btx-hero" id="btx-home">

  <div class="btx-hero-slider-wrap">

    <% if (typeof slides !== 'undefined' && slides.length > 0) { %>
      <% slides.forEach((slide, i) => { %>
        <div class="btx-hero-slide <%= i === 0 ? 'btx-active' : '' %>" data-btx-slide>

          <!-- TEXT -->
          <div class="btx-hero-text">
            <p class="btx-hero-eyebrow">Bhilwara, Rajasthan · Est. 1975</p>

            <h1 class="btx-hero-title">
              <%- slide.title || 'Where Threads<br><em>Become Legacy</em>' %>
            </h1>

            <p class="btx-hero-sub">
              <%= slide.subtitle || "India's textile capital, woven into every metre. Premium suitings & shirtings crafted with mastery." %>
            </p>

            <div class="btx-hero-cta">
              <a href="/fabrics" class="btx-btn-primary">
                <i class="fa-solid fa-arrow-right"></i> Explore Collection
              </a>
              <a href="https://wa.me/91XXXXXXXXXX" class="btx-btn-ghost">
                💬 WhatsApp Us
              </a>
            </div>
          </div>

          <!-- VISUAL -->
          <div class="btx-hero-visual">
            <div class="btx-hero-img-wrap">
              <img src="<%= slide.imagePath %>" alt="<%= slide.title || 'Fabric' %>">
            </div>
            <div class="btx-hero-badge">
              <strong>50+</strong>
              <span>Years of<br>Excellence</span>
            </div>
          </div>

        </div>
      <% }) %>
    <% } else { %>
      <div class="btx-hero-slide btx-active" data-btx-slide>
        <div class="btx-hero-text">
          <p class="btx-hero-eyebrow">Bhilwara, Rajasthan · Est. 1975</p>
          <h1 class="btx-hero-title">Where Threads<br><em>Become Legacy</em></h1>
          <p class="btx-hero-sub">India's textile capital, woven into every metre. Premium suitings and shirtings crafted with mastery.</p>
          <div class="btx-hero-cta">
            <a href="/fabrics" class="btx-btn-primary"><i class="fa-solid fa-arrow-right"></i> Explore Collection</a>
            <a href="https://wa.me/91XXXXXXXXXX" class="btx-btn-ghost">💬 WhatsApp Us</a>
          </div>
        </div>
        <div class="btx-hero-visual">
          <div class="btx-hero-img-wrap">
            <img src="/images/hero-default.jpg" alt="Textile">
          </div>
          <div class="btx-hero-badge"><strong>50+</strong><span>Years of<br>Excellence</span></div>
        </div>
      </div>
    <% } %>

  </div>

  <!-- DOTS -->
  <div class="btx-hero-dots" id="btxHeroDots"></div>

</section>

<script>
(function() {
  const slides = document.querySelectorAll('[data-btx-slide]');
  if (slides.length < 2) return;

  const dotsWrap = document.getElementById('btxHeroDots');
  let current = 0;

  // build dots
  slides.forEach((_, i) => {
    const d = document.createElement('div');
    d.className = 'btx-hero-dot' + (i === 0 ? ' btx-active' : '');
    d.addEventListener('click', () => goTo(i));
    dotsWrap.appendChild(d);
  });

  function goTo(idx) {
    slides[current].classList.remove('btx-active');
    dotsWrap.children[current].classList.remove('btx-active');
    current = idx;
    slides[current].classList.add('btx-active');
    dotsWrap.children[current].classList.add('btx-active');
  }

  setInterval(() => goTo((current + 1) % slides.length), 5000);
})();
</script>


