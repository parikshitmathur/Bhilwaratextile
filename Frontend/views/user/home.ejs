<!-- kaam -->
<div class="swiper-wrapper">

    <% if (locals.categories && categories.length > 0) { %>

        <% categories.forEach((cat, index) => { %>

            <div class="swiper-slide h-auto py-4 flex justify-center">

                <!-- CATEGORY LINK -->
                <a
                    href="/category/<%= encodeURIComponent(cat.name) %>"
                    class="btx-elite-card group block text-center"
                >

                    <!-- IMAGE -->
                    <div class="btx-thumb-wrap relative mx-auto mb-5 <%= index % 2 === 1 ? 'shape-alt' : 'shape-std' %>">

                        <img
                            src="<%= cat.image || '/images/default.jpg' %>"
                            alt="<%= cat.name %>"
                            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                        >

                        <!-- OVERLAY -->
                        <div class="btx-elite-overlay">

                            <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-black shadow-xl scale-0 group-hover:scale-100 transition-all duration-500">

                                <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>

                            </div>

                        </div>

                    </div>

                    <!-- TEXT -->
                    <div class="px-2">

                        <h3 class="text-[12px] font-black uppercase tracking-[0.1em] text-gray-900 group-hover:text-black transition-all duration-300 mb-1">

                            <%= cat.name %>

                        </h3>

                        <div class="flex items-center justify-center gap-1.5 opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-y-2 group-hover:translate-y-0">

                            <span class="h-[1px] w-4 bg-black"></span>

                            <p class="text-[8px] font-black text-black uppercase tracking-tighter">
                                View Collection
                            </p>

                            <span class="h-[1px] w-4 bg-black"></span>

                        </div>

                    </div>

                </a>

            </div>

        <% }) %>

    <% } else { %>

        <div class="w-full text-center py-10">

            <p class="text-gray-400 italic text-sm">
                No collections available at the moment.
            </p>

        </div>

    <% } %>

</div>

