<script>
    // ==========================================
    // 1. THE "FAKE BUT REAL" DATABASES
    // ==========================================
    const fakeReviews = [
        { name: "Rahul Sharma", loc: "New Delhi, India", stars: 5, text: "Excellent fabric quality and fast delivery. Best B2B portal in India." },
        { name: "Hasina Trading", loc: "Barmer, Rajasthan", stars: 4, text: "Good company, genuine suppliers. Very easy to send inquiries." },
        { name: "Rashid Shamboko", loc: "Lusaka, Zambia", stars: 5, text: "Great export quality fabrics. The suppliers responded very fast to my needs." },
        { name: "Amit Agarwal", loc: "Surat, Gujarat", stars: 5, text: "Highly impressed with the premium suiting collection available here." },
        { name: "Al-Noor Textiles", loc: "Dubai, UAE", stars: 4, text: "Reliable platform. The verification of sellers gives a lot of trust." },
        { name: "Meera Fashions", loc: "Mumbai, India", stars: 5, text: "Got the exact cotton yarn I was looking for. Brilliant interface!" },
        { name: "Jonathan Smith", loc: "London, UK", stars: 5, text: "Importing from Bhilwara has never been this smooth. Highly recommended." },
        { name: "Vikas Jain", loc: "Ahmedabad, India", stars: 4, text: "Good portal for bulk orders. Customer support is also very helpful." },
        { name: "Priya Boutique", loc: "Jaipur, India", stars: 5, text: "I regularly source my boutique fabrics from here. Top-notch quality!" },
        { name: "Chen Wei", loc: "Guangzhou, China", stars: 4, text: "Good variety of synthetic blends. Easy to communicate with sellers." }
    ];

    const fakeSuppliers = [
        { name: "Shree Ji Textiles", loc: "Bhilwara, Rajasthan", stars: 5, desc: "Leading manufacturer of premium polyester viscose suiting fabrics and yarns since 1995." },
        { name: "Kartik Weaves", loc: "Surat, Gujarat", stars: 5, desc: "We accept bulk orders in woven fabrics of all types like Pure chiffon, Dola, lichi etc." },
        { name: "KVH Furnishing", loc: "Panipat, Haryana", stars: 4, desc: "Leading manufacturer and supplier of furnishing fabrics. Aiming to offer high quality goods." },
        { name: "Mahadev Synthetics", loc: "Bhilwara, Rajasthan", stars: 5, desc: "Specialists in cotton blends, denim fabric, and heavy duty workwear materials." },
        { name: "Royal Threads", loc: "Ahmedabad, Gujarat", stars: 4, desc: "Wholesaler of unstitched dress materials, kurtis, and pure cotton cambric." },
        { name: "Global Yarns Co.", loc: "Ludhiana, Punjab", stars: 5, desc: "Exporters of premium acrylic and wool blended yarns for winterwear manufacturing." },
        { name: "Chippas & Brothers", loc: "Jaipur, Rajasthan", stars: 5, desc: "Famous for traditional block prints, indigo dyes, and pure organic cotton fabrics." },
        { name: "TexCorp India", loc: "Mumbai, Maharashtra", stars: 4, desc: "B2B suppliers of technical textiles and non-woven fabrics for medical use." },
        { name: "A-One Suitings", loc: "Bhilwara, Rajasthan", stars: 5, desc: "Premium suiting and shirting manufacturers catering to top brands across India." },
        { name: "Siddhi Silks", loc: "Varanasi, UP", stars: 5, desc: "Authentic banarasi silk sarees and raw silk fabric direct from weavers." }
    ];

    // ==========================================
    // 2. HELPER FUNCTIONS
    // ==========================================
    // Function to get random items from array
    function getRandomItems(arr, num) {
        const shuffled = [...arr].sort(() => 0.5 - Math.random());
        return shuffled.slice(0, num);
    }

    // Function to generate star HTML (Only 4 or 5 stars)
    function generateStars(rating) {
        let starsHtml = '';
        for(let i=1; i<=5; i++) {
            if(i <= rating) starsHtml += '<i class="fa-solid fa-star"></i>';
            else starsHtml += '<i class="fa-regular fa-star"></i>';
        }
        return starsHtml;
    }

    // ==========================================
    // 3. RENDER FUNCTIONS WITH ANIMATION
    // ==========================================
    function updateWidgets() {
        const reviewContainer = document.getElementById('reviews-container');
        const supplierContainer = document.getElementById('suppliers-container');

        // Step A: Add Fade-out class
        reviewContainer.classList.add('fade-out');
        supplierContainer.classList.add('fade-out');

        // Step B: Wait for fade-out, then change content and Fade-in
        setTimeout(() => {
            // Pick 2 random reviews and 2 random suppliers
            const activeReviews = getRandomItems(fakeReviews, 2);
            const activeSuppliers = getRandomItems(fakeSuppliers, 2);

            // Generate HTML for Reviews
            reviewContainer.innerHTML = activeReviews.map(rev => `
                <div class="bt-live-card">
                    <div class="bt-card-top">
                        <div class="bt-avatar">${rev.name.charAt(0)}</div>
                        <div class="bt-user-info">
                            <h4>${rev.name}</h4>
                            <p>From ${rev.loc}</p>
                            <div class="bt-stars">${generateStars(rev.stars)}</div>
                        </div>
                    </div>
                    <div class="bt-review-text">"${rev.text}"</div>
                </div>
            `).join('');

            // Generate HTML for Suppliers
            supplierContainer.innerHTML = activeSuppliers.map(sup => `
                <div class="bt-live-card" style="display:flex; flex-direction:column;">
                    <div class="bt-card-top">
                        <div class="bt-avatar" style="background:rgba(59,130,246,0.1); color:#3b82f6; border-color:rgba(59,130,246,0.3)">
                            ${sup.name.charAt(0)}
                        </div>
                        <div class="bt-user-info">
                            <h4>${sup.name}</h4>
                            <p>${sup.loc}</p>
                            <div class="bt-stars">${generateStars(sup.stars)}</div>
                        </div>
                    </div>
                    <div class="bt-supplier-desc">${sup.desc}</div>
                   <div class="bt-action-btns">
    <!-- Links updated to point to the All Categories page -->
    <a href="/all-categories" class="bt-sm-btn btn-pink">Send Inquiry</a>
    <a href="/all-categories" class="bt-sm-btn btn-blue">Contact</a>
</div>
                </div>
            `).join('');

            // Remove Fade-out, Add Fade-in
            reviewContainer.classList.remove('fade-out');
            supplierContainer.classList.remove('fade-out');
            
            // Trigger reflow to restart animation
            void reviewContainer.offsetWidth; 
            
            reviewContainer.classList.add('fade-in');
            supplierContainer.classList.add('fade-in');

        }, 500); // 500ms delay matches the CSS transition time
    }

    // ==========================================
    // 4. START THE MAGIC
    // ==========================================
    // Load first time immediately
    updateWidgets();

    // Rotate every 8 Seconds (8000 milliseconds)
    setInterval(updateWidgets, 8000);
</script>

