<!-- ══════════ PROCESS ══════════ -->
<section class="process-section">
  <div class="process-inner">
    <div style="text-align:center" class="reveal">
      <p class="section-label" style="justify-content:center">Our Process</p>
      <h2 class="section-title" style="max-width:500px;margin:0 auto">From Raw Fibre to <em>Finished Fabric</em></h2>
    </div>
    <div class="process-steps">
      <div class="process-step reveal delay-1">
        <div class="step-circle">🌾</div>
        <div class="step-num">Step 01</div>
        <div class="step-title">Fibre Sourcing</div>
        <p class="step-body">Premium raw cotton & polyester sourced directly from certified farms and petrochemical plants.</p>
      </div>
      <div class="process-step reveal delay-2">
        <div class="step-circle">🔄</div>
        <div class="step-num">Step 02</div>
        <div class="step-title">Spinning</div>
        <p class="step-body">State-of-the-art spinning machines produce ultra-fine, uniform yarn for consistent weave quality.</p>
      </div>
      <div class="process-step reveal delay-3">
        <div class="step-circle">🧶</div>
        <div class="step-num">Step 03</div>
        <div class="step-title">Weaving</div>
        <p class="step-body">Rapier and air-jet looms weave precise patterns at 400+ picks per minute for flawless fabric construction.</p>
      </div>
      <div class="process-step reveal delay-4">
        <div class="step-circle">🎨</div>
        <div class="step-num">Step 04</div>
        <div class="step-title">Dyeing & Finishing</div>
        <p class="step-body">Eco-safe reactive dyes. Heat-setting, calendering and anti-shrink finishing for a premium hand-feel.</p>
      </div>
      <div class="process-step reveal delay-5">
        <div class="step-circle">✅</div>
        <div class="step-num">Step 05</div>
        <div class="step-title">QC & Dispatch</div>
        <p class="step-body">Multi-point lab testing, final inspection, roll packing and dispatch to your doorstep.</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════════ TESTIMONIALS ══════════ -->
<section class="testimonials-section">
  <div style="max-width:1280px;margin:0 auto;padding:0 2rem" class="reveal">
    <p class="section-label" style="color:rgba(255,255,255,0.5)">What Our Clients Say</p>
    <h2 class="section-title" style="color:#fff">Trusted Across <em>India</em></h2>
  </div>
  <div class="testimonials-track-wrap">
    <div class="testimonials-track" id="testimonialTrack">
      <% 
      const testimonials = [
        { text: "Been ordering suiting fabrics from Bhilwara Textile for 6 years. Their Poly-Viscose blend is unmatched — the drape, the finish, the consistency. No one else comes close.", name: "Rajesh Agarwal", city: "Delhi, School Uniform Supplier", init: "RA" },
        { text: "We supply uniforms to 40 corporate clients across Pune. Bhilwara Textile is our go-to — reliable quality and the best bulk pricing we've found anywhere in India.", name: "Sunita Mehta", city: "Pune, Corporate Uniform Manufacturer", init: "SM" },
        { text: "Visited the factory in Bhilwara and was blown away. The scale of operations is incredible. The quality controls they have in place give me full confidence in every order.", name: "Mohammed Farooq", city: "Hyderabad, Fabric Exporter", init: "MF" },
        { text: "The custom dyeing service is outstanding. We gave them a specific Pantone code and they nailed it on the first sample. Will definitely be a repeat customer.", name: "Ananya Sharma", city: "Mumbai, Fashion Brand", init: "AS" },
        { text: "Delivery is always on time and the packing is excellent. As a retailer in a small town, getting consistent B2B service is rare — Bhilwara Textile has never let me down.", name: "Vikram Singh", city: "Jodhpur, Fabric Retailer", init: "VS" },
        { text: "We source fabrics from many mills. For suiting-grade materials, Bhilwara Textile is simply the best value proposition in the entire country. Period.", name: "Deepak Goyal", city: "Ludhiana, Garment Exporter", init: "DG" }
      ];
      %>
      <% testimonials.forEach(t => { %>
      <div class="testi-card">
        <div class="testi-quote">"</div>
        <p class="testi-text"><%= t.text %></p>
        <div class="testi-author">
          <div class="testi-avatar"><%= t.init %></div>
          <div>
            <div class="testi-name"><%= t.name %></div>
            <div class="testi-city"><%= t.city %></div>
          </div>
        </div>
      </div>
      <% }) %>
      <!-- Duplicate for seamless loop -->
      <% testimonials.forEach(t => { %>
      <div class="testi-card">
        <div class="testi-quote">"</div>
        <p class="testi-text"><%= t.text %></p>
        <div class="testi-author">
          <div class="testi-avatar"><%= t.init %></div>
          <div>
            <div class="testi-name"><%= t.name %></div>
            <div class="testi-city"><%= t.city %></div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ══════════ INQUIRY ══════════ -->
<section class="inquiry-section" id="inquiry">
  <div class="inquiry-inner">
    <div class="reveal">
      <p class="section-label" style="justify-content:center">Get in Touch</p>
      <h2 class="section-title">Send a Bulk <em>Enquiry</em></h2>
      <p class="section-body" style="text-align:center;max-width:500px;margin:1rem auto 0">
        Tell us your requirements. Our team gets back within 4 business hours with samples, pricing, and availability.
      </p>
    </div>
    <form class="inquiry-form reveal" action="/inquiry" method="POST">
      <div class="form-group">
        <label class="form-label">Your Name *</label>
        <input class="form-input" type="text" name="name" placeholder="Rajesh Agarwal" required>
      </div>
      <div class="form-group">
        <label class="form-label">Company / Business Name</label>
        <input class="form-input" type="text" name="company" placeholder="Agarwal Garments Pvt. Ltd.">
      </div>
      <div class="form-group">
        <label class="form-label">Phone / WhatsApp *</label>
        <input class="form-input" type="tel" name="phone" placeholder="+91 98765 XXXXX" required>
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input class="form-input" type="email" name="email" placeholder="you@company.com">
      </div>
      <div class="form-group">
        <label class="form-label">Fabric Type Required *</label>
        <select class="form-select" name="fabric" required>
          <option value="">— Select Fabric Type —</option>
          <option>Poly-Viscose Suiting</option>
          <option>Pure Cotton Shirting</option>
          <option>Uniform Grade Fabric</option>
          <option>Woolen Blend Suiting</option>
          <option>Custom / Other</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Quantity Required (Metres) *</label>
        <input class="form-input" type="text" name="quantity" placeholder="e.g. 500 metres" required>
      </div>
      <div class="form-group full">
        <label class="form-label">Additional Requirements</label>
        <textarea class="form-textarea" name="message" placeholder="Shade, GSM, end-use, delivery timeline, custom requirements..."></textarea>
      </div>
      <button class="btn-submit" type="submit"><span>📩 &nbsp;Submit Enquiry</span></button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>

