<script>
async function loadHomeMerchants() {
    try {
        const res = await fetch('/api/merchants/list');
        const allMerchants = await res.json();
        
        // 🔥 Sirf TOP 4 Sellers dikhane ke liye slice kiya
        const topFour = allMerchants.slice(0, 4);
        renderHomeGrid(topFour);
    } catch (e) { 
        console.error("Home Section Error:", e); 
    }
}

function renderHomeGrid(list) {
    const grid = document.getElementById('homeMerchantsGrid');
    
    if (!list.length) {
        grid.innerHTML = `<div class="col-span-full text-center py-10 text-zinc-700 text-[10px] font-black uppercase tracking-widest">No Partners Verified Yet</div>`;
        return;
    }

    grid.innerHTML = list.map((m, index) => `
        <div class="merchant-card-home overflow-hidden p-6 rounded-[2.5rem] flex flex-col items-center text-center animate-card" style="animation-delay: ${index * 0.1}s">
            
            <!-- Badge -->
            <div class="absolute top-5 right-6">
                <i class="fas fa-shield-check text-[#C9922A] text-[10px]"></i>
            </div>

            <!-- Logo -->
            <div class="w-16 h-16 rounded-2xl bg-zinc-900 border border-zinc-800 flex items-center justify-center text-[#C9922A] mb-5 overflow-hidden">
                ${m.logo ? `<img src="${m.logo}" class="w-full h-full object-cover">` : `<i class="fas fa-industry text-2xl opacity-30"></i>`}
            </div>
            
            <h3 class="text-sm font-black uppercase tracking-tight text-white mb-1 line-clamp-1">${m.companyName || 'Bhilwara Merchant'}</h3>
            <p class="text-[9px] font-bold text-[#C9922A] uppercase tracking-[0.2em] mb-4">${m.city || 'Bhilwara'}</p>
            
            <div class="w-full pt-4 border-t border-zinc-800/50 mt-auto">
                <a href="/merchant/${m._id}" class="group relative flex items-center justify-center w-full py-3 bg-zinc-900 border border-zinc-800 hover:border-[#C9922A] text-white text-[9px] font-black uppercase tracking-[0.2em] rounded-xl transition-all overflow-hidden">
                    <span class="relative z-10">View Profile</span>
                    <div class="absolute inset-0 bg-[#C9922A] translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
                </a>
            </div>
        </div>
    `).join('');
}

// Section load hone par function call
loadHomeMerchants();
</script>
