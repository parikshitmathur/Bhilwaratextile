<!-- ══════════ ANIMATED WEAVE ══════════ -->
<section class="weave-section">
  <p class="section-label reveal" style="justify-content:center">The Art of Weaving</p>
  <h2 class="section-title reveal" style="color:#fff; text-align:center; max-width:600px; margin:0 auto 1rem;">
    Every Thread Tells a <em style="color:var(--gold-light)">Story</em>
  </h2>
  <p style="color:rgba(255,255,255,0.5); font-family:'Cormorant Garamond',serif; font-size:1.1rem; text-align:center; max-width:500px; margin:0 auto; font-weight:300;" class="reveal">
    Our fabrics pass through 14 stages of precision manufacturing — from raw fibre to finished metre — before they reach you.
  </p>
  <div class="weave-svg-wrap reveal">
    <svg viewBox="0 0 700 120" xmlns="http://www.w3.org/2000/svg" width="100%" height="120">
      <!-- Animated sine wave threads -->
      <path id="t1" d="M0,60 Q175,10 350,60 T700,60" stroke="#c8962a" stroke-width="2" fill="none" stroke-dasharray="8,6" stroke-linecap="round">
        <animate attributeName="stroke-dashoffset" from="0" to="-400" dur="3s" repeatCount="indefinite"/>
      </path>
      <path id="t2" d="M0,60 Q175,110 350,60 T700,60" stroke="#e8b84b" stroke-width="1.5" fill="none" stroke-dasharray="5,8" opacity="0.6">
        <animate attributeName="stroke-dashoffset" from="-400" to="0" dur="4s" repeatCount="indefinite"/>
      </path>
      <path id="t3" d="M0,40 Q175,90 350,40 T700,40" stroke="rgba(200,150,42,0.4)" stroke-width="1" fill="none" stroke-dasharray="3,10">
        <animate attributeName="stroke-dashoffset" from="0" to="-300" dur="5s" repeatCount="indefinite"/>
      </path>
      <path id="t4" d="M0,80 Q175,30 350,80 T700,80" stroke="rgba(232,184,75,0.3)" stroke-width="1" fill="none" stroke-dasharray="3,10">
        <animate attributeName="stroke-dashoffset" from="-300" to="0" dur="5.5s" repeatCount="indefinite"/>
      </path>
      <!-- Vertical warp threads -->
      <line x1="100" y1="20" x2="100" y2="100" stroke="rgba(200,150,42,0.15)" stroke-width="1"/>
      <line x1="200" y1="20" x2="200" y2="100" stroke="rgba(200,150,42,0.15)" stroke-width="1"/>
      <line x1="300" y1="20" x2="300" y2="100" stroke="rgba(200,150,42,0.15)" stroke-width="1"/>
      <line x1="400" y1="20" x2="400" y2="100" stroke="rgba(200,150,42,0.15)" stroke-width="1"/>
      <line x1="500" y1="20" x2="500" y2="100" stroke="rgba(200,150,42,0.15)" stroke-width="1"/>
      <line x1="600" y1="20" x2="600" y2="100" stroke="rgba(200,150,42,0.15)" stroke-width="1"/>
    </svg>
  </div>
</section>

