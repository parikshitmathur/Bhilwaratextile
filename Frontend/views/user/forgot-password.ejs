<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f4f0e8] flex flex-col min-h-screen">

    <main class="flex-grow flex justify-center items-center py-12 px-4 mt-[64px]">
        <div class="max-w-md w-full bg-white shadow-2xl rounded-3xl overflow-hidden">
            
            <div class="bg-[#141210] p-8 text-center">
                <h2 class="text-3xl font-bold text-white">Forgot Password?</h2>
                <p class="text-gray-400 text-sm mt-2">Enter your email to receive an OTP.</p>
            </div>

            <div class="p-8">
                <form action="/api/send-forgot-otp" method="POST" class="space-y-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address</label>
                        <input type="email" name="email" required placeholder="Registered email" 
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 transition-all">
                    </div>
                    <button type="submit" class="w-full bg-[#141210] hover:bg-[#C9922A] text-white font-bold py-3.5 rounded-xl transition-all">
                        Send OTP
                    </button>
                </form>
            </div>
            
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>