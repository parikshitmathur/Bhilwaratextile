<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-[#f4f0e8] flex flex-col min-h-screen">

    <main class="flex-grow flex justify-center items-center py-12 px-4 sm:px-6 lg:px-8 mt-[64px]">
        
        <div class="max-w-md w-full bg-white shadow-2xl rounded-3xl border border-gray-100 overflow-hidden">
            
            <div class="bg-[#141210] p-8 text-center relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-[#C9922A] rounded-full opacity-20 blur-3xl -mr-10 -mt-10"></div>
                <h2 class="text-3xl font-bold text-white relative z-10">Welcome Back</h2>
                <p class="text-gray-400 text-sm mt-2 relative z-10">Sign in to your Bhilwara Textile account.</p>
            </div>

            <div class="p-8">
                <form action="/api/login" method="POST" class="space-y-6">
                    
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address</label>
                        <input type="email" name="email" required placeholder="name@company.com" 
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Password</label>
                        <input type="password" name="password" required placeholder="••••••••" 
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all">
                    </div>

                    <button type="submit" class="w-full bg-[#141210] hover:bg-[#C9922A] text-white font-bold text-base py-3.5 rounded-xl shadow-lg transition-all duration-300">
                        Sign In
                    </button>
                    
                </form>

                <p class="text-center text-sm text-gray-500 mt-6">
                    Don't have an account? 
                    <a href="/register" class="font-bold text-[#141210] hover:text-[#C9922A] transition-colors">Free Join</a>
                </p>
            </div>
            
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>