<%- include('partials/header') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Bebas+Neue&family=Lato:wght@300;400;700&display=swap');

  :root {
    --gold: #c8962a;
    --gold-light: #e8b84b;
    --charcoal: #1a1a1a;
    --cream: #faf7f2;
    --text-muted: #6b6b6b;
  }
  
  body { background: var(--cream); font-family: 'Lato', sans-serif; overflow-x: hidden; cursor: none; font-size: 14px; }

  /* ── CURSOR ── */
  .cursor-dot { width:6px;height:6px;background:var(--gold);border-radius:50%;position:fixed;pointer-events:none;z-index:99999; }
  .cursor-ring { width:30px;height:30px;border:1.5px solid var(--gold);border-radius:50%;position:fixed;pointer-events:none;z-index:99998; transition: transform .15s; transform:translate(-12px,-12px); }

  /* ══════════ PAGE HERO (Shorter Height) ══════════ */
  .page-hero {
    background: var(--charcoal);
    min-height: 60vh; /* Pehle 85vh tha */
    display: flex; align-items: flex-end;
    position: relative; overflow: hidden;
    padding: 0 2rem 3rem;
  }
  .hero-full-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .25; }
  
  .page-hero-inner {
    position: relative; z-index: 5; max-width: 1100px; margin: 0 auto; width: 100%;
    display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 2rem; align-items: flex-end;
  }
  
  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 900;
    color: #fff; line-height: 1.1;
  }
  .hero-title em { font-style: italic; color: var(--gold-light); display: block; }

  .hero-quote {
    font-family: 'Cormorant Garamond', serif; font-size: 1.1rem;
    color: rgba(255,255,255,.6); line-height: 1.6;
    border-left: 2px solid var(--gold); padding-left: 1rem;
  }

  /* ══════════ SECTION COMPACTNESS ══════════ */
  section { padding: 5rem 2rem; } /* Pehle 8rem tha */
  .intro-section { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem; align-items: center; }
  
  .section-title { font-size: clamp(1.8rem, 3vw, 2.4rem); color: var(--charcoal); margin-bottom: 1rem; line-height: 1.2; }
  .section-body { font-size: 0.95rem; line-height: 1.7; color: var(--text-muted); margin-bottom: 1rem; }

  /* ══════════ TIMELINE COMPACT ══════════ */
  .timeline-section { padding: 5rem 2rem; background: #f0ede6; }
  .tl-item { padding: 0 0 2.5rem 2.5rem; display: grid; grid-template-columns: 100px 1fr; gap: 1.5rem; }
  .tl-year { font-family:'Bebas Neue',sans-serif; font-size: 1.6rem; color: var(--gold); }
  .tl-dot { width: 14px; height: 14px; left: -7px; top: 6px; position: absolute; background: var(--gold); border-radius: 50%; border: 2px solid #f0ede6; }

  /* ══════════ VALUES & TEAM GRID ══════════ */
  .values-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; }
  .val-card { padding: 1.8rem; background: #fff; border-top: 2px solid transparent; transition: 0.3s; }
  .val-card:hover { border-top-color: var(--gold); transform: translateY(-4px); }
  
  .team-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.2rem; }
  .team-img-w { aspect-ratio: 4/5; }
  .team-name { font-size: 1rem; }

  /* ══════════ STATS STRIP ══════════ */
  .stats-strip { background: var(--gold); padding: 2.5rem 2rem; }
  .stats-row { display: grid; grid-template-columns: repeat(5,1fr); max-width: 1100px; margin: 0 auto; }
  .ss-num { font-family:'Bebas Neue',sans-serif; font-size: 2.2rem; }

  /* Responsive Fixes */
  @media(max-width:768px){
    .intro-section, .page-hero-inner, .team-grid, .values-grid { grid-template-columns: 1fr; }
    .hero-right { display: none; }
    section { padding: 3.5rem 1.25rem; }
  }
</style>

<!-- ══════════ HERO ══════════ -->
<section class="page-hero">
  <!-- Sahi Image URL jo textile loom dikhata hai -->
  <img class="hero-full-img" src="https://images.unsplash.com/photo-1558278812-ad8a34c05f29?q=80&w=2000&auto=format&fit=crop" alt="Textile Background">
  <div class="page-hero-inner">
    <div class="hero-left reveal-l">
      <p class="hero-eyebrow" style="font-family:'Bebas Neue'; letter-spacing:0.3em; color:var(--gold); margin-bottom:10px;">Est. 1975 • Rajasthan</p>
      <h1 class="hero-title">Woven with<br><em>Pride & Purpose</em></h1>
    </div>
    <div class="hero-right reveal-r">
      <blockquote class="hero-quote">
        "Our story is stitched together by the hands of thousands of skilled weavers in Bhilwara."
      </blockquote>
    </div>
  </div>
</section>

<!-- ══════════ INTRO ══════════ -->
<section>
  <div class="intro-section">
    <div class="reveal-l">
      <img style="width:100%; border-radius:10px;" src="https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?q=80&w=800&auto=format&fit=crop" alt="Fabric Rolls">
    </div>
    <div class="reveal-r">
      <p class="section-eyebrow">Our Legacy</p>
      <h2 class="section-title">Thread by Thread <em>History</em></h2>
      <p class="section-body">
        Since 1975, Bhilwara Textile has been the backbone of Indian suiting. What started with one loom is now a 3 lakh sq. ft. powerhouse of quality and innovation.
      </p>
      <div style="display:flex; gap:20px; margin-top:15px;">
        <div><div class="ss-num" style="font-size:1.8rem; color:var(--charcoal)" data-count="50">0</div><p style="font-size:10px; font-weight:bold; color:var(--gold)">YEARS</p></div>
        <div><div class="ss-num" style="font-size:1.8rem; color:var(--charcoal)" data-count="1200">0</div><p style="font-size:10px; font-weight:bold; color:var(--gold)">PATTERNS</p></div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════ VALUES COMPACT ══════════ -->
<section style="background:#fff;">
  <div style="max-width:1100px; margin:0 auto;">
    <h2 class="section-title" style="text-align:center; margin-bottom:3rem;">Core <em>Principles</em></h2>
    <div class="values-grid">
      <% [
        {i:'🧵', t:'Quality', b:'Every batch tested for GSM & strength in our NABL lab.'},
        {i:'🌿', t:'Sustainable', b:'Solar powered manufacturing & water-efficient dyeing.'},
        {i:'⚡', t:'Reliable', b:'Dispatched within 72 hours with real-time tracking.'}
      ].forEach(v => { %>
        <div class="val-card reveal">
          <span style="font-size:1.5rem;"><%= v.i %></span>
          <h4 style="font-family:'Playfair Display'; margin:10px 0;"><%= v.t %></h4>
          <p class="section-body" style="font-size:0.85rem;"><%= v.b %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ══════════ STATS ══════════ -->
<div class="stats-strip">
  <div class="stats-row">
    <% [['50','Years'],['1200','Patterns'],['800','Clients'],['300K','Sq.Ft.'],['120','Cr+']].forEach(([n,l])=>{ %>
    <div style="text-align:center">
      <div class="ss-num" data-count="<%= n.replace('K','') %>"><%= n %></div>
      <p style="font-size:10px; font-weight:900; opacity:0.6; text-transform:uppercase;"><%= l %></p>
    </div>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>

<script>
(function(){
  /* Cursor */
  const dot=document.getElementById('cursorDot'), ring=document.getElementById('cursorRing');
  document.addEventListener('mousemove',e=>{
    dot.style.left = e.clientX + 'px'; dot.style.top = e.clientY + 'px';
    ring.style.left = e.clientX + 'px'; ring.style.top = e.clientY + 'px';
  });

  /* Simple Reveal */
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.style.opacity=1; e.target.style.transform='none';}});
  },{threshold:0.1});
  document.querySelectorAll('.reveal-l, .reveal-r, .reveal').forEach(el=>{
    el.style.opacity=0; el.style.transition='0.8s ease';
    el.style.transform = el.classList.contains('reveal-l') ? 'translateX(-30px)' : 'translateY(30px)';
    obs.observe(el);
  });

  /* Counter */
  document.querySelectorAll('[data-count]').forEach(el=>{
    const countObs = new IntersectionObserver(entries=>{
      if(entries[0].isIntersecting){
        let n=0; const target=parseInt(el.dataset.count);
        const inv = setInterval(()=>{
          n += Math.ceil(target/50);
          if(n>=target){ el.textContent=target+'+'; clearInterval(inv); }
          else el.textContent=n+'+';
        },30);
        countObs.unobserve(el);
      }
    });
    countObs.observe(el);
  });
})();
</script>