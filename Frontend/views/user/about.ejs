<script>
(function(){

  /* ── Cursor ── */
  const dot=document.getElementById('cursorDot'),ring=document.getElementById('cursorRing');
  document.addEventListener('mousemove',e=>{
    dot.style.transform=`translate(${e.clientX-4}px,${e.clientY-4}px)`;
    ring.style.transform=`translate(${e.clientX-18}px,${e.clientY-18}px)`;
  });
  document.querySelectorAll('a,button,.team-card,.val-card,.tl-item').forEach(el=>{
    el.addEventListener('mouseenter',()=>ring.classList.add('hovered'));
    el.addEventListener('mouseleave',()=>ring.classList.remove('hovered'));
  });

  /* ── Floating Icons ── */
  const icons=['🧵','🪡','✂️','🧶','📐','🪢'];
  const fc=document.getElementById('floatWrap');
  for(let i=0;i<14;i++){
    const el=document.createElement('div');
    el.className='float-icon';
    el.textContent=icons[Math.floor(Math.random()*icons.length)];
    el.style.cssText=`left:${Math.random()*100}vw;bottom:${Math.random()*10}vh;animation-delay:${Math.random()*9}s;animation-duration:${8+Math.random()*7}s;font-size:${0.6+Math.random()*0.9}rem;`;
    fc.appendChild(el);
  }

  /* ── Scroll Reveal ── */
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('v');obs.unobserve(e.target);}});
  },{threshold:0.1});
  document.querySelectorAll('.reveal,.reveal-l,.reveal-r,.reveal-s').forEach(el=>obs.observe(el));

  /* ── Counters ── */
  document.querySelectorAll('[data-count]').forEach(el=>{
    const co=new IntersectionObserver(entries=>{
      if(!entries[0].isIntersecting)return;
      const t=parseInt(el.dataset.count),big=t>=100000;
      let n=0;const step=t/60;
      const tm=setInterval(()=>{
        n=Math.min(n+step,t);
        el.textContent=big?Math.floor(n/1000)+'K+':Math.floor(n)+'+';
        if(n>=t)clearInterval(tm);
      },22);
      co.unobserve(el);
    },{threshold:.4});
    co.observe(el);
  });

  /* ── Hero Parallax ── */
  const hi=document.querySelector('.hero-full-img');
  window.addEventListener('scroll',()=>{
    if(hi&&window.scrollY<window.innerHeight)
      hi.style.transform=`scale(1.05) translateY(${window.scrollY*.06}px)`;
  });

})();
</script>
