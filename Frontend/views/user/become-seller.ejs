<%- include('./partials/header') %>

<!-- Custom Style for extra "Oomph" -->
<style>
    .glass-card {
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .input-focus-effect:focus {
        box-shadow: 0 0 20px rgba(234, 179, 8, 0.15);
        transform: translateY(-1px);
    }
    .textile-pattern {
        background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
</style>

<section class="relative min-h-screen py-12 lg:py-20 bg-slate-950 overflow-hidden textile-pattern">
    <!-- Background Decor -->
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-12 w-96 h-96 bg-yellow-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 translate-y-12 -translate-x-12 w-96 h-96 bg-blue-500/10 rounded-full blur-[120px]"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="rounded-[40px] glass-card shadow-2xl overflow-hidden border border-white/5">
            <div class="grid gap-0 lg:grid-cols-[1fr_1.1fr]">
                
                <!-- Left Side: Value Proposition -->
                <div class="relative p-8 sm:p-12 lg:p-16 flex flex-col justify-center">
                    <div class="space-y-8">
                        <div>
                            <span class="inline-flex items-center gap-2 rounded-full bg-yellow-400/10 px-4 py-2 text-xs font-bold uppercase tracking-widest text-yellow-400 border border-yellow-400/20">
                                <span class="relative flex h-2 w-2">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-2 w-2 bg-yellow-500"></span>
                                </span>
                                Seller Partnership
                            </span>
                            <h1 class="mt-6 text-4xl sm:text-6xl font-black tracking-tight text-white leading-[1.1]">
                                Weave your <span class="text-yellow-400">Success</span> Story.
                            </h1>
                            <p class="mt-6 max-w-lg text-lg text-slate-400 leading-relaxed">
                                Join Bhilwara's elite textile network. From premium yarn manufacturers to global exporters, we connect you to the right loom of opportunities.
                            </p>
                        </div>

                        <!-- Feature List -->
                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center border border-white/10 text-yellow-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                                </div>
                                <div>
                                    <h3 class="font-bold text-white text-lg">Verified Network</h3>
                                    <p class="text-slate-400 text-sm">Access 100% pre-vetted buyer enquiries from across the globe.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center border border-white/10 text-yellow-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                                </div>
                                <div>
                                    <h3 class="font-bold text-white text-lg">Instant Visibility</h3>
                                    <p class="text-slate-400 text-sm">List your products and start receiving leads within 24 hours.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Side: The Form -->
                <div class="bg-white p-8 sm:p-12 lg:p-16 relative">
                    <div class="max-w-md mx-auto">
                        <div class="mb-10 text-center lg:text-left">
                            <h2 class="text-3xl font-black text-slate-900">Get Started</h2>
                            <p class="text-slate-500 mt-2 font-medium">It only takes 2 minutes to change your business trajectory.</p>
                        </div>

                        <form action="/api/seller/register" method="POST" class="space-y-6">
                            <div class="grid gap-5 sm:grid-cols-2">
                                <div class="space-y-2">
                                    <label class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1">Company Name</label>
                                    <input type="text" name="companyName" required placeholder="e.g. Bhilwara Silks"
                                        class="w-full rounded-2xl border-2 border-slate-100 bg-slate-50 px-5 py-3.5 text-sm transition-all focus:bg-white focus:border-yellow-500 focus:outline-none input-focus-effect" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1">Contact Person</label>
                                    <input type="text" name="contactPerson" required placeholder="Your Full Name"
                                        class="w-full rounded-2xl border-2 border-slate-100 bg-slate-50 px-5 py-3.5 text-sm transition-all focus:bg-white focus:border-yellow-500 focus:outline-none input-focus-effect" />
                                </div>
                            </div>

                            <div class="grid gap-5 sm:grid-cols-2">
                                <div class="space-y-2">
                                    <label class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1">Mobile Number</label>
                                    <div class="flex rounded-2xl border-2 border-slate-100 bg-slate-50 overflow-hidden focus-within:border-yellow-500 transition-all">
                                        <span class="inline-flex items-center px-4 bg-slate-100 text-slate-500 font-bold text-sm border-r border-slate-200">+91</span>
<input 
    type="tel" 
    name="mobile" 
    required 
    placeholder="9876543210" 
    maxlength="10"
    oninput="this.value = this.value.replace(/[^0-9]/g, ''); if(this.value.length > 0 && !['6','7','8','9'].includes(this.value[0])) { this.value = ''; }"
    class="w-full px-4 py-3 focus:outline-none text-lg text-black font-semibold border border-gray-300 rounded-md"
    style="color: #000000 !important;"
>
                                    </div>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1">Email</label>
                                    <input type="email" name="email" required placeholder="name@company.com"
                                        class="w-full rounded-2xl border-2 border-slate-100 bg-slate-50 px-5 py-3.5 text-sm transition-all focus:bg-white focus:border-yellow-500 focus:outline-none input-focus-effect" />
                                </div>
                            </div>

                            <div class="grid gap-5 sm:grid-cols-2">
                                <div class="space-y-2">
                                    <label class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1">City</label>
                                    <input type="text" name="city" required placeholder="City Name"
                                        class="w-full rounded-2xl border-2 border-slate-100 bg-slate-50 px-5 py-3.5 text-sm transition-all focus:bg-white focus:border-yellow-500 focus:outline-none input-focus-effect" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1">Business Type</label>
                                    <select name="businessType" required
                                        class="w-full rounded-2xl border-2 border-slate-100 bg-slate-50 px-5 py-3.5 text-sm focus:bg-white focus:border-yellow-500 focus:outline-none transition-all appearance-none cursor-pointer">
                                        <option value="" disabled selected>Choose Category</option>
                                        <option>Manufacturer</option>
                                        <option>Wholesaler</option>
                                        <option>Trader</option>
                                        <option>Exporter</option>
                                    </select>
                                </div>
                            </div>

                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1">Full Business Address</label>
                                <textarea name="address" rows="2" required placeholder="Where is your factory or shop located?"
                                    class="w-full rounded-2xl border-2 border-slate-100 bg-slate-50 px-5 py-3.5 text-sm transition-all focus:bg-white focus:border-yellow-500 focus:outline-none input-focus-effect"></textarea>
                            </div>

                            <button type="submit" class="group relative w-full overflow-hidden rounded-2xl bg-slate-950 px-8 py-4 text-white transition-all hover:bg-slate-900 active:scale-[0.98]">
                                <div class="absolute inset-0 bg-gradient-to-r from-yellow-500 to-yellow-600 opacity-0 transition-opacity group-hover:opacity-100"></div>
                                <span class="relative flex items-center justify-center gap-2 font-bold text-lg group-hover:text-slate-950 transition-colors">
                                    Complete Registration
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                </span>
                            </button>

                            <p class="text-center text-xs font-medium text-slate-400">
                                Secured by SSL encryption. By clicking, you agree to our <a href="#" class="text-slate-900 underline underline-offset-4 decoration-yellow-400">Terms</a>.
                            </p>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('./partials/footer') %>