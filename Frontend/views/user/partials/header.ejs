<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title><%= typeof title !== 'undefined' ? title : "Bhilwara Textile" %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/main.js" defer></script>
    
    <style> 
        @keyframes fadeInDown {
            0% { opacity: 0; transform: translateY(-20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .animate-\[fadeInDown_1s_ease-in-out\] {
            animation: fadeInDown 1s ease-in-out;
        }
        /* Mega menu smooth appearance */
        .mega-menu {
            transition: all 0.3s ease-in-out;
            transform-origin: top;
        }
        .group:hover .mega-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
    </style>
</head>
<body class="bg-gray-50">

    <nav class="fixed w-full z-50 top-0 left-0 bg-white border-b border-gray-200 transition-all duration-300 shadow-sm relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
            <div class="flex justify-between items-center h-20">
                
                <div class="flex-shrink-0 transition-transform duration-300 hover:scale-105 cursor-pointer">
                    <a href="/">
                        <h2 class="text-2xl font-extrabold text-gray-900 tracking-tight">
                            BHILWARA<span class="text-yellow-600">TEXTILE</span>
                        </h2>
                    </a>
                </div>

                <div class="hidden md:flex items-center space-x-8 h-full">
                    <a href="/" class="text-sm font-semibold text-gray-700 hover:text-yellow-600 transition">Home</a>
                    
                    <div class="group h-full flex items-center cursor-pointer">
                        <a href="/categories" class="text-sm font-semibold text-gray-700 hover:text-yellow-600 transition flex items-center gap-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                            All Categories
                        </a>

                        <div class="mega-menu invisible opacity-0 translate-y-4 absolute left-0 top-full w-full bg-white border-t border-gray-100 shadow-[0_10px_30px_rgba(0,0,0,0.1)] z-50 p-8">
                            <div class="max-w-7xl mx-auto grid grid-cols-4 gap-8">
                                
                                <div>
                                    <h3 class="text-xs font-bold text-gray-900 mb-4 uppercase tracking-wider border-b pb-2">Sarees</h3>
                                    <ul class="space-y-3">
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Designer Sarees</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Wedding Sarees</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Cotton Sarees</a></li>
                                    </ul>
                                </div>

                                <div>
                                    <h3 class="text-xs font-bold text-gray-900 mb-4 uppercase tracking-wider border-b pb-2">Dress</h3>
                                    <ul class="space-y-3">
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Designer Suits</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Anarkali Suits</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Party Wear</a></li>
                                    </ul>
                                </div>

                                <div>
                                    <h3 class="text-xs font-bold text-gray-900 mb-4 uppercase tracking-wider border-b pb-2">Fabrics</h3>
                                    <ul class="space-y-3">
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Fancy Fabric</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Cotton Fabric</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Silk Fabric</a></li>
                                    </ul>
                                </div>

                                <div>
                                    <h3 class="text-xs font-bold text-gray-900 mb-4 uppercase tracking-wider border-b pb-2">Machinery</h3>
                                    <ul class="space-y-3">
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Embroidery Machines</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Water Jet Loom</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Spare Parts</a></li>
                                    </ul>
                                </div>

                            </div>
                        </div>
                    </div>
                    
                    <a href="/seller" class="text-sm font-semibold text-gray-700 hover:text-yellow-600 transition">For Sellers</a>
                    
                    <a href="/about" class="text-sm font-semibold text-gray-700 hover:text-yellow-600 transition">Our Story</a>
                    
                    <div class="flex items-center space-x-4 pl-4 border-l border-gray-300">
                        <div class="text-blue-500">
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
                        </div>
                        <div class="flex flex-col">
                            <div class="flex items-center space-x-2 text-sm font-bold text-gray-800">
                                <a href="/login" class="hover:text-blue-600 transition">Sign In</a>
                                <span class="text-gray-400">|</span>
                                <a href="/join-free" class="hover:text-blue-600 transition flex items-center gap-1">
                                    Free Join
                                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </a>
                            </div>
                            <span class="text-xs text-gray-500 mt-0.5">My Account</span>
                        </div>
                    </div>

                    <a href="/buyer" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-bold text-white transition-all duration-200 bg-gray-900 rounded-lg hover:bg-yellow-600">
                        GET QUOTE
                    </a>
                </div>

                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-button" class="text-gray-800 focus:outline-none">
                        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </nav>
    <div class="pt-20"></div>

</body>
</html>