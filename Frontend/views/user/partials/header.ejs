<!-- =========================================================
BHILWARA TEXTILE - SMALL PREMIUM DARK NAVBAR
========================================================= -->

<!-- TAILWIND -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- GOOGLE FONT -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>

<!-- FONT AWESOME -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<style>

body{
    font-family:'Plus Jakarta Sans',sans-serif;
    background:#050507;
    color:white;
    margin:0;
    overflow-x:hidden;
}

/* =========================================================
PREMIUM NAVBAR
========================================================= */

.btx-navbar{
    background:rgba(5,5,7,0.78);
    backdrop-filter:blur(20px);
    -webkit-backdrop-filter:blur(20px);
    border:1px solid rgba(255,255,255,0.08);
    box-shadow:0 20px 60px rgba(0,0,0,0.45);
}

/* NAV LINKS */
.btx-link{
    position:relative;
    font-size:10px;
    font-weight:800;
    text-transform:uppercase;
    letter-spacing:.18em;
    color:#d4d4d8;
    transition:.35s ease;
}

.btx-link:hover{
    color:#C9922A;
}

.btx-link::after{
    content:'';
    position:absolute;
    left:0;
    bottom:-7px;
    width:0%;
    height:2px;
    background:#C9922A;
    transition:.35s ease;
}

.btx-link:hover::after{
    width:100%;
}

/* ACTIVE LINK */
.btx-active{
    color:#C9922A;
}

.btx-active::after{
    width:100%;
}

/* BUTTON */
.btx-btn{
    background:#C9922A;
    color:black;
    transition:.35s ease;
    box-shadow:0 10px 30px rgba(201,146,42,0.25);
}

.btx-btn:hover{
    background:white;
    transform:translateY(-2px);
}

/* MOBILE */
@media(max-width:768px){

    .btx-center-links{
        display:none;
    }

    .btx-portal{
        display:none;
    }

}

</style>

<!-- =========================================================
NAVBAR START
========================================================= -->

<nav
class="fixed top-0 left-0 w-full z-[99999] px-4 md:px-6 py-2">

    <div class="max-w-[1450px] mx-auto">

        <!-- NAVBAR BOX -->
        <div
        class="btx-navbar rounded-[28px] h-[72px] px-5 md:px-8">

            <div class="flex items-center justify-between w-full h-full">

                <!-- LOGO -->
                <div class="flex-shrink-0">

                    <a href="/" class="group">

                        <h1
                        class="text-[20px] md:text-[22px] font-black uppercase tracking-[-1px] leading-none">

                            Bhilwara
                            <span class="text-[#C9922A] italic">
                                Textile
                            </span>

                        </h1>

                        <p class="text-[7px] font-bold uppercase tracking-[0.4em] text-zinc-500 mt-1">
                            Elite Marketplace
                        </p>

                    </a>

                </div>

                <!-- CENTER LINKS -->
                <div class="flex-1 flex justify-center">

                    <div class="btx-center-links flex items-center gap-8">

                        <a href="/" class="btx-link">
                            Home
                        </a>

                        <a href="/verified-sellers" class="btx-link btx-active">
                            Partners
                        </a>

                        <a href="/fabrics" class="btx-link">
                            Fabrics
                        </a>

                        <a href="/about" class="btx-link">
                            About
                        </a>
                         <a href="/contact" class="btx-link">
                            Contact
                        </a>

                    </div>

                </div>

                <!-- RIGHT SIDE -->
                <div class="flex items-center gap-3 md:gap-4">

                    <!-- PORTAL -->
                   <div class="relative inline-block text-left group">
    
    <button id="portalBtn" onclick="togglePortal()" class="btx-portal flex items-center gap-2 bg-black hover:bg-zinc-900 border border-white/10 px-2 py-1.5 pr-4 rounded-full transition-all duration-300">
        <div class="w-8 h-8 rounded-full bg-[#C9922A] flex items-center justify-center text-black shadow-[0_0_15px_rgba(201,146,42,0.2)]">
            <i class="fa-solid fa-shield-halved text-[10px]"></i>
        </div>
        <span class="text-[9px] font-black uppercase tracking-[0.18em] text-white">Portal</span>
        <i class="fa-solid fa-chevron-down text-[8px] text-zinc-500 group-hover:text-[#C9922A] transition-transform duration-300" id="portalArrow"></i>
    </button>

    <div id="portalDropdown" class="absolute right-0 mt-3 w-48 origin-top-right hidden rounded-2xl bg-[#0b0b0f] border border-white/5 shadow-[0_20px_50px_rgba(0,0,0,0.5)] backdrop-blur-xl z-[100] overflow-hidden">
        <div class="py-2">
            
          <a href="/tx-login" class="flex items-center gap-3 px-5 py-3 hover:bg-white/5 group transition-all">
                <i class="fa-solid fa-right-to-bracket text-[10px] text-[#C9922A]"></i>
                <div class="flex flex-col">
                    <span class="text-[9px] font-black text-white uppercase tracking-widest">Merchant Login</span>
                    <span class="text-[7px] font-bold text-zinc-600 uppercase">Existing Sellers</span>
                </div>
            </a>

            <a href="/become-seller" class="flex items-center gap-3 px-5 py-3 hover:bg-white/5 group transition-all">
                <i class="fa-solid fa-user-plus text-[10px] text-[#C9922A]"></i>
                <div class="flex flex-col">
                    <span class="text-[9px] font-black text-white uppercase tracking-widest">Become a Seller</span>
                    <span class="text-[7px] font-bold text-zinc-600 uppercase">Register Business</span>
                </div>
            </a>

            <div class="h-[1px] bg-white/5 mx-4 my-1"></div>

            <a href="/buyer" class="flex items-center gap-3 px-5 py-3 hover:bg-white/5 group transition-all">
                <div class="w-6 h-6 rounded-lg bg-zinc-900 border border-white/5 flex items-center justify-center group-hover:border-[#C9922A]/30 transition-all">
                    <i class="fa-solid fa-headset text-[9px] text-zinc-500 group-hover:text-[#C9922A]"></i>
                </div>
                <div class="flex flex-col">
                    <span class="text-[9px] font-black text-white uppercase tracking-widest">Inquiry Hub</span>
                    <span class="text-[7px] font-bold text-zinc-600 uppercase tracking-tighter">Direct Authority</span>
                </div>
            </a>

        </div>
    </div>
</div>

<script>
    function togglePortal() {
        const dropdown = document.getElementById('portalDropdown');
        const arrow = document.getElementById('portalArrow');
        
        dropdown.classList.toggle('hidden');
        arrow.classList.toggle('rotate-180');
    }

    // Window click par dropdown band karne ke liye
    window.onclick = function(event) {
        if (!event.target.closest('.btx-portal')) {
            const dropdown = document.getElementById('portalDropdown');
            const arrow = document.getElementById('portalArrow');
            if (!dropdown.classList.contains('hidden')) {
                dropdown.classList.add('hidden');
                arrow.classList.remove('rotate-180');
            }
        }
    }
</script>

                    <!-- CTA -->
                    <a href="/join-free"
                    class="btx-btn px-5 py-2.5 rounded-full text-[10px] font-black uppercase tracking-[0.18em]">

                        Join Free

                    </a>

                </div>

            </div>

        </div>

    </div>

</nav>

<!-- =========================================================
DUMMY SECTION
========================================================= -->
