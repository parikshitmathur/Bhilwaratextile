<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-[#f4f0e8] flex flex-col min-h-screen">

    <main class="flex-grow flex justify-center items-center py-12 px-4 sm:px-6 lg:px-8 mt-[64px]">
        
        <div class="max-w-md w-full bg-white shadow-2xl rounded-3xl border border-gray-100 overflow-hidden">
            
            <div class="bg-[#141210] p-8 text-center relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-[#C9922A] rounded-full opacity-20 blur-3xl -mr-10 -mt-10"></div>
                <h2 class="text-3xl font-bold text-white relative z-10">Create Account</h2>
                <p class="text-gray-400 text-sm mt-2 relative z-10">Join the Bhilwara Textile network today.</p>
            </div>

            <div class="p-8">
                <form action="/api/register" method="POST" class="space-y-5">
                    
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name</label>
                        <input type="text" name="name" required placeholder="Enter your name" 
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Mobile Number</label>
                       <input 
    type="tel" 
    name="mobile" 
    required 
    placeholder="9876543210" 
    pattern="[6-9]{1}[0-9]{9}" 
    title="Please enter a 10-digit Indian number starting with 6, 7, 8, or 9"
    maxlength="10"
    oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);"
    class="w-full px-4 py-3 bg-gray-50 focus:bg-white focus:outline-none text-sm"
>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address</label>
                        <input type="email" name="email" required placeholder="name@company.com" 
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Password</label>
                        <input type="password" name="password" required placeholder="Create a password" 
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                    </div>

                    <button type="submit" class="w-full bg-[#141210] hover:bg-[#C9922A] text-white font-bold text-base py-3.5 rounded-xl shadow-lg transition-all duration-300 mt-2">
                        Create Account
                    </button>
                    
                </form>

                <p class="text-center text-sm text-gray-500 mt-6">
                    Already have an account? 
                    <a href="/login" class="font-bold text-[#141210] hover:text-[#C9922A] transition-colors">Sign In</a>
                </p>
            </div>
            
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>