  <%- include('partials/header') %>

  <!-- Fonts & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
  /* ─── RESET & BASE ──────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: #04040A;
    color: #fff;
    overflow-x: hidden;
    cursor: none;
  }

  /* ─── CUSTOM CURSOR ─────────────────────────────────────────────── */
  #cursor-dot {
    width: 8px; height: 8px;
    background: #C9922A;
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    transform: translate(-50%, -50%);
    transition: transform 0.1s;
  }
  #cursor-ring {
    width: 36px; height: 36px;
    border: 1.5px solid rgba(201,146,42,0.5);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9998;
    transform: translate(-50%, -50%);
    transition: all 0.18s ease;
  }
  body:hover #cursor-dot { transform: translate(-50%, -50%) scale(1); }

  /* ─── CSS VARIABLES ─────────────────────────────────────────────── */
  :root {
    --gold: #C9922A;
    --gold-light: #fde68a;
    --gold-dim: rgba(201,146,42,0.15);
    --surface: rgba(12, 12, 18, 0.7);
    --border: rgba(255,255,255,0.06);
    --border-gold: rgba(201,146,42,0.25);
    --text-muted: #52525b;
    --bebas: 'Bebas Neue', sans-serif;
  }

  /* ─── UTILS ─────────────────────────────────────────────────────── */
  .gold-text { background: linear-gradient(135deg, #C9922A, #fde68a 60%, #C9922A); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .glass { background: var(--surface); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border: 1px solid var(--border); }
  .gold-border { border: 1px solid var(--border-gold); box-shadow: 0 0 30px rgba(201,146,42,0.08); }
  .section-label { font-size: 9px; font-weight: 900; color: var(--gold); text-transform: uppercase; letter-spacing: 0.6em; display: block; margin-bottom: 1rem; }
  .reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ─── NOISE OVERLAY ─────────────────────────────────────────────── */
  body::after {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 9000; opacity: 0.4;
  }

  /* ─── STICKY NAV ────────────────────────────────────────────────── */
  #main-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 1.25rem 2rem;
    transition: all 0.4s ease;
  }
  #main-nav.scrolled {
    background: rgba(4,4,10,0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-gold);
    padding: 0.9rem 2rem;
  }
  .nav-inner { max-width: 1280px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { font-family: var(--bebas); font-size: 1.6rem; letter-spacing: 0.1em; color: var(--gold); }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.4em; color: #71717a; text-decoration: none; transition: color 0.3s; }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta {
    padding: 0.6rem 1.5rem; border-radius: 50px;
    background: var(--gold); color: #000;
    font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.35em;
    text-decoration: none; transition: all 0.3s;
  }
  .nav-cta:hover { background: var(--gold-light); transform: scale(1.05); }
  .nav-mobile-btn { display: none; background: none; border: none; color: var(--gold); font-size: 1.4rem; cursor: pointer; }

  /* ─── HERO ──────────────────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    position: relative;
    display: flex; align-items: center;
    overflow: hidden;
  }
  .hero-bg-glow {
    position: absolute; inset: 0; pointer-events: none;
  }
  .hero-bg-glow::before {
    content: '';
    position: absolute; top: -20%; right: -10%;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(201,146,42,0.15) 0%, transparent 65%);
    animation: pulse-glow 6s ease-in-out infinite alternate;
  }
  .hero-bg-glow::after {
    content: '';
    position: absolute; bottom: -20%; left: -10%;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(201,146,42,0.07) 0%, transparent 65%);
    animation: pulse-glow 8s ease-in-out infinite alternate-reverse;
  }
  @keyframes pulse-glow { from { transform: scale(1); opacity: 0.7; } to { transform: scale(1.2); opacity: 1; } }

  /* Diagonal grid lines */
  .hero-grid {
    position: absolute; inset: 0; opacity: 0.025; pointer-events: none;
    background-image: linear-gradient(rgba(201,146,42,1) 1px, transparent 1px), linear-gradient(90deg, rgba(201,146,42,1) 1px, transparent 1px);
    background-size: 80px 80px;
  }

  .hero-inner {
    max-width: 1280px; margin: 0 auto;
    padding: 8rem 2rem 4rem;
    display: flex; align-items: center;
    gap: 6rem; width: 100%;
  }

  /* Logo block */
  .hero-logo-wrap { position: relative; flex-shrink: 0; }
  .hero-logo-ring {
    width: 220px; height: 220px;
    border-radius: 50%; padding: 3px;
    background: conic-gradient(#C9922A 0deg, #fde68a 90deg, #C9922A 180deg, transparent 360deg);
    animation: spin-ring 8s linear infinite;
    position: relative;
  }
  @keyframes spin-ring { to { transform: rotate(360deg); } }
  .hero-logo-inner {
    width: 100%; height: 100%;
    background: #08080f;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .hero-logo-inner img { width: 90%; height: 90%; object-fit: cover; border-radius: 50%; }
  .hero-logo-initial { font-family: var(--bebas); font-size: 5rem; color: var(--gold); }

  .hero-badge {
    position: absolute; bottom: -10px; right: -10px;
    background: #10b981; border: 2px solid #04040A;
    border-radius: 50px; padding: 0.4rem 0.9rem;
    display: flex; align-items: center; gap: 6px;
    font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.3em;
  }
  .hero-badge-dot { width: 7px; height: 7px; background: #fff; border-radius: 50%; animation: blink 1.5s ease infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* Hero text */
  .hero-text { flex: 1; }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 0.4rem 1rem; border-radius: 50px;
    border: 1px solid var(--border-gold);
    background: var(--gold-dim);
    font-size: 9px; font-weight: 900; color: var(--gold);
    text-transform: uppercase; letter-spacing: 0.45em;
    margin-bottom: 1.5rem;
  }
  .hero-title {
    font-family: var(--bebas);
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 0.92;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .hero-desc {
    font-size: 1.05rem; line-height: 1.8;
    color: #71717a; max-width: 520px;
    border-left: 3px solid var(--gold);
    padding-left: 1.2rem; margin-bottom: 2.5rem;
    font-style: italic;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    padding: 0.9rem 2.2rem; border-radius: 50px;
    background: var(--gold); color: #000;
    font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.4em;
    text-decoration: none; transition: all 0.3s; border: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 12px 40px rgba(201,146,42,0.35); }
  .btn-outline {
    padding: 0.9rem 2.2rem; border-radius: 50px;
    border: 1px solid var(--border-gold); color: #fff;
    font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.4em;
    text-decoration: none; transition: all 0.3s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-outline:hover { background: var(--gold-dim); border-color: var(--gold); }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    font-size: 8px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.5em; color: var(--text-muted);
    animation: bounce-soft 2s ease infinite;
  }
  .scroll-indicator i { font-size: 1rem; color: var(--gold); }
  @keyframes bounce-soft { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }

  /* ─── TICKER ────────────────────────────────────────────────────── */
  .ticker-wrap {
    overflow: hidden;
    background: linear-gradient(90deg, #0c0c0e, #111118, #0c0c0e);
    border-top: 1px solid var(--border-gold);
    border-bottom: 1px solid var(--border-gold);
    padding: 1rem 0;
  }
  .ticker-track { display: flex; gap: 3rem; animation: ticker-move 30s linear infinite; width: max-content; }
  .ticker-item { font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.5em; color: var(--text-muted); white-space: nowrap; display: flex; align-items: center; gap: 1rem; }
  .ticker-item span { color: var(--gold); }
  .ticker-dot { width: 4px; height: 4px; background: var(--gold); border-radius: 50%; }
  @keyframes ticker-move { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ─── STATS ─────────────────────────────────────────────────────── */
  .stats-section { padding: 5rem 2rem; }
  .stats-grid { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5px; background: var(--border); border-radius: 2rem; overflow: hidden; }
  .stat-card {
    background: #06060C;
    padding: 3rem 2rem; text-align: center;
    transition: background 0.3s;
  }
  .stat-card:hover { background: #0d0d14; }
  .stat-num {
    font-family: var(--bebas);
    font-size: 4.5rem;
    color: var(--gold);
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .stat-label { font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.5em; color: var(--text-muted); }

  /* ─── SLIDER (Products) ──────────────────────────────────────────── */
  .products-section { padding: 6rem 0; }
  .section-header { max-width: 1280px; margin: 0 auto 3rem; padding: 0 2rem; display: flex; justify-content: space-between; align-items: flex-end; }
  .section-title-main { font-family: var(--bebas); font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: 0.05em; line-height: 1; text-transform: uppercase; }

  .slider-controls { display: flex; gap: 0.8rem; }
  .slider-btn {
    width: 44px; height: 44px; border-radius: 50%;
    border: 1px solid var(--border-gold);
    background: transparent; color: var(--gold);
    font-size: 1rem; cursor: pointer;
    transition: all 0.3s; display: flex; align-items: center; justify-content: center;
  }
  .slider-btn:hover { background: var(--gold); color: #000; }

  .slider-viewport { overflow: hidden; padding-bottom: 1rem; }
  .slider-track {
    display: flex;
    gap: 1.5rem;
    padding: 0 2rem;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    max-width: 1280px; /* only visually within this width but scroll beyond */
  }
  .product-card {
    flex: 0 0 clamp(280px, 30vw, 380px);
    border-radius: 2.5rem;
    overflow: hidden;
    background: #080810;
    border: 1px solid var(--border);
    transition: border-color 0.4s, transform 0.4s;
    position: relative;
  }
  .product-card:hover { border-color: var(--border-gold); transform: translateY(-8px); }
  .product-card-img { height: 260px; overflow: hidden; position: relative; }
  .product-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease; }
  .product-card:hover .product-card-img img { transform: scale(1.08); }
  .product-card-badge {
    position: absolute; top: 1.2rem; left: 1.2rem;
    padding: 0.35rem 0.9rem; border-radius: 50px;
    background: rgba(4,4,10,0.75); backdrop-filter: blur(10px);
    font-size: 8px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.35em;
    border: 1px solid var(--border);
  }
  .product-card-body { padding: 1.8rem 2rem 2rem; }
  .product-name { font-size: 1.15rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.3rem; }
  .product-meta { font-size: 9px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.4em; margin-bottom: 1.5rem; }
  .product-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 1.2rem; border-top: 1px solid var(--border); }
  .product-price-label { font-size: 7px; font-weight: 900; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.4em; }
  .product-price { font-family: var(--bebas); font-size: 2.2rem; color: var(--gold); letter-spacing: 0.05em; line-height: 1; }
  .product-add-btn {
    width: 46px; height: 46px; border-radius: 16px;
    background: #0f0f1a; border: 1px solid var(--border);
    color: #fff; font-size: 1.1rem;
    cursor: pointer; transition: all 0.3s;
    display: flex; align-items: center; justify-content: center;
  }
  .product-add-btn:hover { background: var(--gold); border-color: var(--gold); color: #000; transform: scale(1.1); }

  /* Slider dots */
  .slider-dots { display: flex; gap: 6px; justify-content: center; margin-top: 2rem; }
  .slider-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--text-muted); transition: all 0.3s; cursor: pointer; }
  .slider-dot.active { background: var(--gold); width: 24px; border-radius: 3px; }

  /* ─── MARQUEE (Image Strip) ─────────────────────────────────────── */
  .marquee-section { padding: 3rem 0; overflow: hidden; }
  .marquee-track { display: flex; gap: 1.5rem; animation: marquee-scroll 25s linear infinite; width: max-content; }
  .marquee-img { width: 260px; height: 160px; border-radius: 1.5rem; overflow: hidden; flex-shrink: 0; border: 1px solid var(--border); }
  .marquee-img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.3); transition: filter 0.4s; }
  .marquee-img:hover img { filter: grayscale(0); }
  @keyframes marquee-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ─── WHY US ─────────────────────────────────────────────────────── */
  .whyus-section { padding: 6rem 2rem; }
  .whyus-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
  .whyus-text h2 { font-family: var(--bebas); font-size: clamp(3rem,6vw,5.5rem); line-height: 0.95; letter-spacing: 0.03em; text-transform: uppercase; margin-bottom: 2rem; }
  .whyus-text p { color: #71717a; line-height: 1.9; font-size: 1rem; margin-bottom: 2rem; }
  .feature-list { display: flex; flex-direction: column; gap: 1rem; }
  .feature-item {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.2rem 1.5rem; border-radius: 1.2rem;
    background: #08080f; border: 1px solid var(--border);
    transition: all 0.3s;
  }
  .feature-item:hover { border-color: var(--border-gold); transform: translateX(8px); }
  .feature-icon { width: 42px; height: 42px; border-radius: 12px; background: var(--gold-dim); border: 1px solid var(--border-gold); display: flex; align-items: center; justify-content: center; color: var(--gold); flex-shrink: 0; }
  .feature-item-text h4 { font-size: 0.88rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
  .feature-item-text p { font-size: 0.78rem; color: var(--text-muted); line-height: 1.6; }

  /* Right side big number card */
  .whyus-right { display: flex; flex-direction: column; gap: 1.5rem; }
  .big-number-card {
    padding: 2.5rem; border-radius: 2rem;
    background: #08080f; border: 1px solid var(--border);
    position: relative; overflow: hidden; transition: border-color 0.3s;
  }
  .big-number-card:hover { border-color: var(--border-gold); }
  .big-number-card::before {
    content: '';
    position: absolute; top: 0; right: 0;
    width: 150px; height: 150px;
    background: radial-gradient(circle, var(--gold-dim) 0%, transparent 70%);
    pointer-events: none;
  }
  .bnum { font-family: var(--bebas); font-size: 5rem; color: var(--gold); letter-spacing: 0.05em; line-height: 1; }
  .bnum-label { font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.4em; color: var(--text-muted); }
  .bnum-desc { font-size: 0.85rem; color: #52525b; margin-top: 0.5rem; line-height: 1.6; }

  /* ─── TESTIMONIALS SLIDER ────────────────────────────────────────── */
  .testimonials-section { padding: 6rem 2rem; position: relative; overflow: hidden; }
  .testimonials-section::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .testimonials-section::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .testimonials-inner { max-width: 1280px; margin: 0 auto; }
  .testimonials-header { text-align: center; margin-bottom: 4rem; }
  .testi-track { display: flex; gap: 2rem; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
  .testi-card {
    flex: 0 0 calc(33.333% - 1.4rem);
    padding: 2.5rem; border-radius: 2rem;
    background: #08080f; border: 1px solid var(--border);
    transition: border-color 0.3s, transform 0.3s;
  }
  .testi-card:hover { border-color: var(--border-gold); transform: translateY(-6px); }
  .testi-stars { color: var(--gold); font-size: 0.75rem; letter-spacing: 2px; margin-bottom: 1.2rem; }
  .testi-text { font-size: 0.95rem; line-height: 1.8; color: #a1a1aa; font-style: italic; margin-bottom: 2rem; }
  .testi-author { display: flex; align-items: center; gap: 0.9rem; }
  .testi-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--gold-dim); border: 1px solid var(--border-gold);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--bebas); font-size: 1.3rem; color: var(--gold);
  }
  .testi-name { font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; }
  .testi-location { font-size: 9px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.3em; }

  /* ─── PROCESS SECTION ───────────────────────────────────────────── */
  .process-section { padding: 6rem 2rem; }
  .process-inner { max-width: 1280px; margin: 0 auto; }
  .process-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; position: relative; margin-top: 4rem; }
  .process-steps::before {
    content: '';
    position: absolute; top: 2.5rem; left: 12.5%; right: 12.5%;
    height: 1px; background: linear-gradient(90deg, transparent, var(--border-gold), var(--border-gold), var(--border-gold), transparent);
  }
  .process-step { padding: 0 1.5rem; text-align: center; }
  .step-num-wrap { position: relative; display: inline-flex; margin-bottom: 2rem; }
  .step-num {
    width: 54px; height: 54px; border-radius: 50%;
    background: #08080f; border: 1px solid var(--border-gold);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--bebas); font-size: 1.6rem; color: var(--gold);
    letter-spacing: 0.05em; position: relative; z-index: 1;
    transition: background 0.3s;
  }
  .process-step:hover .step-num { background: var(--gold-dim); }
  .step-icon { position: absolute; top: -8px; right: -8px; width: 22px; height: 22px; background: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 9px; color: #000; }
  .step-title { font-size: 0.92rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.7rem; }
  .step-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.7; }

  /* ─── CONTACT & MAP ──────────────────────────────────────────────── */
  .contact-section { padding: 6rem 2rem; }
  .contact-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 5fr 7fr; gap: 4rem; align-items: start; }

  .contact-info h2 { font-family: var(--bebas); font-size: clamp(2.5rem,5vw,4.5rem); letter-spacing: 0.03em; text-transform: uppercase; line-height: 1; margin-bottom: 2.5rem; }
  .contact-cards { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2.5rem; }
  .contact-card {
    display: flex; align-items: center; gap: 1.2rem;
    padding: 1.4rem 1.8rem; border-radius: 1.5rem;
    background: #08080f; border: 1px solid var(--border);
    transition: all 0.3s; text-decoration: none;
  }
  .contact-card:hover { border-color: var(--border-gold); transform: translateX(6px); }
