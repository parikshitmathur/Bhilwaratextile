<script>

    // RANDOM NUMBER CHANGE
    function updateLuxuryNumbers(){

        const allNumbers =
        document.querySelectorAll('.auto-change');

        allNumbers.forEach((item)=>{

            const min =
            parseInt(item.dataset.min);

            const max =
            parseInt(item.dataset.max);

            // RANDOM VALUE
            let value =
            (Math.random() * (max - min) + min)
            .toFixed(1);

            // FINAL
            item.innerHTML = `${value}K+`;

        });

    }

    // FIRST LOAD
    document.addEventListener(
        'DOMContentLoaded',
        updateLuxuryNumbers
    );

    // AUTO CHANGE EVERY 7 SEC
    setInterval(updateLuxuryNumbers,7000);

</script>

