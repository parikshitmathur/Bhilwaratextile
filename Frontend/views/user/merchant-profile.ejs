<script>

    function updateStats() {

        const stats = document.querySelectorAll('.auto-random');

        stats.forEach((item) => {

            const min = parseInt(item.dataset.min);
            const max = parseInt(item.dataset.max);

            let number =
                (Math.random() * (max - min) + min)
                .toFixed(1);

            item.innerHTML = `${number}K+`;

        });

    }

    document.addEventListener(
        'DOMContentLoaded',
        updateStats
    );

    // OPTIONAL AUTO CHANGE
    setInterval(updateStats, 8000);

</script>

