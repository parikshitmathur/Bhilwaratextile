<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen text-gray-800">

    <main class="flex-grow mt-[64px]">
        
        <section class="py-12 px-4 sm:px-6 lg:px-8 flex justify-center items-center bg-gray-50">
            <div class="max-w-6xl w-full bg-white shadow-2xl rounded-3xl border border-gray-100 overflow-hidden flex flex-col md:flex-row">
                
                <div class="w-full md:w-5/12 bg-[#141210] text-white p-8 sm:p-12 flex flex-col justify-center relative overflow-hidden">
                    <div class="absolute top-0 right-0 -mt-10 -mr-10 w-40 h-40 bg-[#C9922A] rounded-full opacity-20 blur-3xl"></div>
                    <div class="absolute bottom-0 left-0 -mb-10 -ml-10 w-40 h-40 bg-gray-500 rounded-full opacity-10 blur-3xl"></div>
                    
                    <div class="relative z-10">
                        <div class="inline-block bg-[#C9922A]/20 text-[#C9922A] border border-[#C9922A]/30 font-semibold px-4 py-1.5 rounded-full text-xs mb-6 tracking-wider uppercase">
                            Global Sourcing
                        </div>
                        <h1 class="text-3xl sm:text-4xl font-extrabold mb-4 leading-tight">For <span class="text-[#C9922A]">Buyers</span></h1>
                        <p class="text-gray-400 text-sm sm:text-base mb-10 leading-relaxed">We connect you with the best textile suppliers worldwide. Post your requirement and get the best deals in minutes.</p>

                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <div class="bg-white/10 p-2.5 rounded-lg shrink-0 mt-1">
                                    <svg class="w-5 h-5 text-[#C9922A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-white">Choose Category</h3>
                                    <p class="text-gray-400 text-xs mt-1">Select your textile needs and discover verified suppliers globally.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <div class="bg-white/10 p-2.5 rounded-lg shrink-0 mt-1">
                                    <svg class="w-5 h-5 text-[#C9922A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-white">Get Seller Contacts</h3>
                                    <p class="text-gray-400 text-xs mt-1">Receive multiple supplier options instantly to your inbox.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <div class="bg-white/10 p-2.5 rounded-lg shrink-0 mt-1">
                                    <svg class="w-5 h-5 text-[#C9922A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-white">Compare Quotes</h3>
                                    <p class="text-gray-400 text-xs mt-1">Choose the best deals and vendors for your business.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="w-full md:w-7/12 p-8 sm:p-12 flex flex-col justify-center">
                    <div class="mb-8">
                        <h2 class="text-2xl font-bold text-gray-900">Post Textile Requirement</h2>
                        <p class="text-gray-500 text-sm mt-1">Fill out the form below to get connected with suppliers.</p>
                    </div>

                    <form action="/submit-requirement" method="POST" class="space-y-5">
                        
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Company / Buyer Name <span class="text-red-500">*</span></label>
                            <input type="text" name="name" required placeholder="e.g. Fashion Exports Ltd." 
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                        </div>
                        
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Mobile Number <span class="text-red-500">*</span></label>
                                <div class="flex rounded-xl overflow-hidden border border-gray-200 focus-within:ring-2 focus-within:ring-[#C9922A]/50 focus-within:border-[#C9922A] transition-all">
                                    <span class="inline-flex items-center px-3 border-r border-gray-200 bg-gray-100 text-gray-600 text-sm font-medium">+91</span>
        <input 
    type="tel" 
    name="mobile" 
    required 
    placeholder="9876543210" 
    maxlength="10"
    oninput="this.value = this.value.replace(/[^0-9]/g, ''); if(this.value.length > 0 && !['6','7','8','9'].includes(this.value[0])) { this.value = ''; }"
    class="w-full px-4 py-3 bg-gray-50 focus:bg-white focus:outline-none text-sm"
>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
                                <input type="email" name="email" required placeholder="buyer@email.com" 
                                    class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Main Category <span class="text-red-500">*</span></label>
                                <select id="mainCat" name="category" onchange="updateSubCats()" required 
                                    class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm cursor-pointer shadow-sm">
                                    <option value="" disabled selected>Select Category</option>
                                    <% if(typeof categories !== 'undefined' && categories.length > 0) { %>
                                        <% categories.forEach(cat => { %>
                                            <option value="<%= cat.name %>" data-subs="<%= cat.subcategories ? cat.subcategories.join(',') : '' %>">
                                                <%= cat.name %>
                                            </option>
                                        <% }) %>
                                    <% } %>
                                </select>
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Sub Category <span class="text-red-500">*</span></label>
                                <select id="subCat" name="subcategory" required 
                                    class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm cursor-pointer shadow-sm">
                                    <option value="">-- Select Sub Category --</option>
                                </select>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Estimated Quantity (Meters) <span class="text-red-500">*</span></label>
                            <input type="number" name="quantity" required placeholder="e.g. 5000" min="1" 
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                        </div>

                        <div class="pt-4">
                            <button type="submit" class="w-full bg-[#141210] hover:bg-[#C9922A] text-white font-bold text-base py-3.5 rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
                                Submit Requirement
                            </button>
                        </div>
                        
                        <p class="text-center text-xs text-gray-400 mt-4">By submitting, you agree to our Terms of Service.</p>
                    </form>
                </div>
                
            </div>
        </section>

        <section class="py-16 px-4 bg-white border-t border-gray-100">
            <div class="max-w-6xl mx-auto text-center">
                <div class="inline-block bg-[#C9922A]/10 text-[#C9922A] font-bold px-3 py-1 rounded-full text-xs mb-4 tracking-wider uppercase">Simple Process</div>
                <h2 class="text-3xl font-extrabold text-gray-900 mb-4">How It Works for Buyers?</h2>
                <p class="text-gray-500 mb-12 max-w-2xl mx-auto">Procuring high-quality textiles from Bhilwara is now easier than ever. Follow these simple steps to get the best wholesale deals.</p>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="p-8 border border-gray-100 rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-all bg-white relative overflow-hidden group">
                        <div class="absolute top-0 left-0 w-full h-1 bg-[#C9922A] scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></div>
                        <div class="w-16 h-16 bg-[#141210] text-[#C9922A] rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-md group-hover:-translate-y-2 transition-transform duration-300">1</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-3">Post Requirement</h3>
                        <p class="text-gray-500 text-sm leading-relaxed">Fill out the simple form above with your required fabric category, sub-category, and estimated quantity.</p>
                    </div>
                    
                    <div class="p-8 border border-gray-100 rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-all bg-white relative overflow-hidden group">
                        <div class="absolute top-0 left-0 w-full h-1 bg-[#C9922A] scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></div>
                        <div class="w-16 h-16 bg-[#141210] text-[#C9922A] rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-md group-hover:-translate-y-2 transition-transform duration-300">2</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-3">Get Connected</h3>
                        <p class="text-gray-500 text-sm leading-relaxed">Our automated system matches your exact needs with top verified manufacturers and suppliers from Bhilwara.</p>
                    </div>
                    
                    <div class="p-8 border border-gray-100 rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-all bg-white relative overflow-hidden group">
                        <div class="absolute top-0 left-0 w-full h-1 bg-[#C9922A] scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></div>
                        <div class="w-16 h-16 bg-[#141210] text-[#C9922A] rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-md group-hover:-translate-y-2 transition-transform duration-300">3</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-3">Compare & Deal</h3>
                        <p class="text-gray-500 text-sm leading-relaxed">Receive multiple competitive quotes. Compare prices, check quality, and close the deal securely.</p>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <%- include('partials/footer') %>

    <script>
    function updateSubCats() {
        const mainSelect = document.getElementById('mainCat');
        const subSelect = document.getElementById('subCat');
        const selectedOption = mainSelect.options[mainSelect.selectedIndex];
        
        const subs = selectedOption.getAttribute('data-subs');
        
        subSelect.innerHTML = '<option value="" disabled selected>-- Select Sub Category --</option>';
        
        if (subs && subs.trim() !== "") {
            subSelect.disabled = false;
            subs.split(',').forEach(s => {
                const op = document.createElement('option');
                op.value = s.trim();
                op.innerText = s.trim();
                subSelect.appendChild(op);
            });
        } else {
            subSelect.innerHTML = '<option value="General">General (No Sub-categories)</option>';
            subSelect.disabled = false;
        }
    }
    </script>
</body>
</html>