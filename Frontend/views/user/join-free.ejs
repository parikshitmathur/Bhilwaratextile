<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
    <style>
        .hero-bg {
            background-image: linear-gradient(to right, rgba(20, 18, 16, 0.95) 0%, rgba(20, 18, 16, 0.7) 100%), url('https://i.pinimg.com/736x/f4/c4/3c/f4c43cd02794709f565d65d40a83d66b.jpg');
            background-size: cover;
            background-position: center;
        }
    </style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">

    <main class="flex-grow mt-[64px]">
        
        <section class="hero-bg py-20 px-4 sm:px-6 lg:px-8 min-h-[500px] flex items-center">
            <div class="max-w-7xl mx-auto w-full flex flex-col md:flex-row items-center gap-12">
                
                <div class="w-full md:w-1/2 text-white space-y-8">
                    <h1 class="text-4xl font-bold text-[#c8962a] mb-6 tracking-wide">NEW To Bhilwara Textile ?</h1>
                    
                    <div class="space-y-6">
                        <div class="flex items-center gap-4">
                            <div class="bg-[#c8962a]/20 p-3 rounded-full border border-[#c8962a]/50">
                                <svg class="w-6 h-6 text-[#c8962a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold">50,000+</h3>
                                <p class="text-sm text-gray-300">Regular Buyers Looking to Make a Purchase</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="bg-[#c8962a]/20 p-3 rounded-full border border-[#c8962a]/50">
                                <svg class="w-6 h-6 text-[#c8962a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold">12,500+</h3>
                                <p class="text-sm text-gray-300">Worldwide Business Associates</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="bg-[#c8962a]/20 p-3 rounded-full border border-[#c8962a]/50">
                                <svg class="w-6 h-6 text-[#c8962a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold">2,00,000+</h3>
                                <p class="text-sm text-gray-300">Products Ready to sell on Platform</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="w-full md:w-1/2 flex justify-center md:justify-end">
                    <div class="bg-white p-8 rounded-xl shadow-2xl w-full max-w-md">
                        <h2 class="text-2xl font-bold text-center text-gray-800 mb-6 uppercase tracking-wide">Join Free Now</h2>
                        
                        <script>
                            const urlParams = new URLSearchParams(window.location.search);
                            if(urlParams.get('success') === 'true') {
                                document.write('<div class="bg-green-100 text-green-700 p-3 rounded-lg text-center font-bold mb-4">Registration Successful! We will call you soon.</div>');
                            }
                        </script>

                        <form action="/api/quick-register" method="POST">
                            <div class="flex rounded-lg overflow-hidden border-2 border-gray-200 mb-6 focus-within:border-[#0ea5e9] transition-colors">
                                <span class="bg-gray-100 px-4 py-3 border-r border-gray-200 flex items-center font-bold text-gray-700">
                                    🇮🇳 +91
                                </span>
                              <input 
    type="tel" 
    name="mobile" 
    required 
    placeholder="9876543210" 
    maxlength="10"
    oninput="this.value = this.value.replace(/[^0-9]/g, ''); if(this.value.length > 0 && !['6','7','8','9'].includes(this.value[0])) { this.value = ''; }"
    class="w-full px-4 py-3 focus:outline-none text-lg text-black font-semibold border border-gray-300 rounded-md"
    style="color: #000000 !important;"
>
                            </div>
                            <button type="submit" class="w-full bg-[#0ea5e9] hover:bg-[#0284c7] text-white font-bold text-lg py-4 rounded-lg transition duration-300 shadow-md">
                                Free Registration
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </section>

        <section class="py-16 px-4 bg-white">
            <div class="max-w-6xl mx-auto text-center">
                <h2 class="text-3xl font-bold text-gray-800 mb-4">How It Works?</h2>
                <p class="text-gray-500 mb-12">Just drop your number, and we take care of the rest.</p>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="p-6 border border-gray-100 rounded-xl shadow-sm hover:shadow-md transition bg-gray-50">
                        <div class="w-16 h-16 bg-[#c8962a] text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-2">Share Your Number</h3>
                        <p class="text-gray-500 text-sm">Enter your active mobile number in the form above. No lengthy forms or passwords required upfront.</p>
                    </div>
                    <div class="p-6 border border-gray-100 rounded-xl shadow-sm hover:shadow-md transition bg-gray-50">
                        <div class="w-16 h-16 bg-[#c8962a] text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-2">We Call You</h3>
                        <p class="text-gray-500 text-sm">Our onboarding expert will call you within 24 hours to verify your details and understand your business needs.</p>
                    </div>
                    <div class="p-6 border border-gray-100 rounded-xl shadow-sm hover:shadow-md transition bg-gray-50">
                        <div class="w-16 h-16 bg-[#c8962a] text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-2">Profile Activated</h3>
                        <p class="text-gray-500 text-sm">We setup your premium Seller/Buyer profile. You start receiving global leads and quotations instantly.</p>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <%- include('partials/footer') %>
</body>
</html>