<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    body { background-color: #050507; color: #d4d4d8; }
    .gold-text { background: linear-gradient(to right, #C9922A, #F3D084, #C9922A); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .glass-card { background: rgba(15, 15, 19, 0.7); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.05); }
    input, textarea { background: #0f0f13 !important; border: 1px solid #27272a !important; color: white !important; font-size: 13px !important; }
    input:focus, textarea:focus { border-color: #C9922A !important; outline: none; }
</style>
<%- include('partials/header') %>
<div class="min-h-screen flex items-center justify-center p-6">
    <div class="max-w-4xl w-full">
        <div class="text-center mb-10">
            <h1 class="text-5xl font-black italic uppercase tracking-tighter text-white">
                Contact <span class="gold-text">Authority</span>
            </h1>
            <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.5em] mt-3 italic">Send your signal to our headquarters</p>
        </div>

        <div class="glass-card p-10 rounded-[3rem] border-t-2 border-[#C9922A]/30 shadow-2xl">
            <form action="/api/contact/submit" method="POST" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-[9px] font-black text-[#C9922A] uppercase tracking-widest mb-2 block">Full Name</label>
                        <input type="text" name="name" placeholder="Enter Identity" class="w-full px-5 py-4 rounded-2xl" required>
                    </div>
                    <div>
                        <label class="text-[9px] font-black text-[#C9922A] uppercase tracking-widest mb-2 block">Email Address</label>
                        <input type="email" name="email" placeholder="email@example.com" class="w-full px-5 py-4 rounded-2xl" required>
                    </div>
                </div>

                <div>
                    <label class="text-[9px] font-black text-zinc-500 uppercase tracking-widest mb-2 block">Subject / Purpose</label>
                    <input type="text" name="subject" placeholder="Bulk Requirement / Inquiry" class="w-full px-5 py-4 rounded-2xl" required>
                </div>

                <div>
                    <label class="text-[9px] font-black text-zinc-500 uppercase tracking-widest mb-2 block">Message Details</label>
                    <textarea name="message" rows="4" placeholder="Describe your requirement..." class="w-full px-5 py-5 rounded-[2rem] resize-none" required></textarea>
                </div>

                <button type="submit" class="w-full bg-[#C9922A] text-black font-black uppercase italic tracking-[0.2em] py-5 rounded-[2rem] hover:bg-white hover:scale-[1.02] transition-all duration-500 shadow-xl shadow-[#C9922A]/10">
                    Initialize Dispatch
                </button>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>