<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f4f0e8] flex flex-col min-h-screen">

    <main class="flex-grow flex justify-center items-center py-12 px-4 mt-[64px]">
        <div class="max-w-md w-full bg-white shadow-2xl rounded-3xl overflow-hidden">
            
            <div class="bg-[#141210] p-8 text-center">
                <h2 class="text-3xl font-bold text-[#C9922A]">Reset Password</h2>
                <p class="text-gray-400 text-sm mt-2">Check your email for the 4-digit OTP.</p>
            </div>

            <div class="p-8">
                <form action="/api/reset-password" method="POST" class="space-y-5">
                    
                    <script>
                        const urlParams = new URLSearchParams(window.location.search);
                        document.write('<input type="hidden" name="email" value="' + urlParams.get('email') + '">');
                    </script>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Enter 4-Digit OTP</label>
                        <input type="number" name="otp" required placeholder="1234" 
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:ring-2 focus:ring-[#C9922A]/50 transition-all text-center tracking-widest text-lg font-bold">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">New Password</label>
                        <input type="password" name="newPassword" required placeholder="Enter new password" 
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:ring-2 focus:ring-[#C9922A]/50 transition-all">
                    </div>

                    <button type="submit" class="w-full bg-[#141210] hover:bg-[#C9922A] text-white font-bold py-3.5 rounded-xl transition-all">
                        Change Password
                    </button>
                </form>
            </div>
            
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>