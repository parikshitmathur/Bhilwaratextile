<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title> 
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/main.js" defer></script>
    
    <style> 
        @keyframes fadeInDown {
            0% { opacity: 0; transform: translateY(-20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .animate-\[fadeInDown_1s_ease-in-out\] {
            animation: fadeInDown 1s ease-in-out;
        }
        /* Mega menu smooth appearance */
        .mega-menu {
            transition: all 0.3s ease-in-out;
            transform-origin: top;
        }
        .group:hover .mega-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
    </style>
</head>
<body class="bg-gray-50">

    <nav class="fixed w-full z-50 top-0 left-0 bg-white border-b border-gray-200 transition-all duration-300 shadow-sm relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
            <div class="flex justify-between items-center h-20">
                
                <div class="flex-shrink-0 transition-transform duration-300 hover:scale-105 cursor-pointer">
                    <h2 class="text-2xl font-extrabold text-gray-900 tracking-tight">
                        BHILWARA<span class="text-yellow-600">TEXTILE</span>
                    </h2>
                </div>

                <div class="hidden md:flex items-center space-x-8 h-full">
                    <a href="/" class="text-sm font-semibold text-gray-700 hover:text-yellow-600 transition">Home</a>
                    
                    <div class="group h-full flex items-center cursor-pointer">
                        <a href="/categories" class="text-sm font-semibold text-gray-700 hover:text-yellow-600 transition flex items-center gap-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                            All Categories
                        </a>

                        <div class="mega-menu invisible opacity-0 translate-y-4 absolute left-0 top-full w-full bg-white border-t border-gray-100 shadow-[0_10px_30px_rgba(0,0,0,0.1)] z-50 p-8">
                            <div class="max-w-7xl mx-auto grid grid-cols-4 gap-8">
                                
                                <div>
                                    <h3 class="text-xs font-bold text-gray-900 mb-4 uppercase tracking-wider border-b pb-2">Sarees</h3>
                                    <ul class="space-y-3">
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Designer Sarees</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Wedding Sarees</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Cotton Sarees</a></li>
                                    </ul>
                                </div>

                                <div>
                                    <h3 class="text-xs font-bold text-gray-900 mb-4 uppercase tracking-wider border-b pb-2">Dress</h3>
                                    <ul class="space-y-3">
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Designer Suits</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Anarkali Suits</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Party Wear</a></li>
                                    </ul>
                                </div>

                                <div>
                                    <h3 class="text-xs font-bold text-gray-900 mb-4 uppercase tracking-wider border-b pb-2">Fabrics</h3>
                                    <ul class="space-y-3">
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Fancy Fabric</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Cotton Fabric</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Silk Fabric</a></li>
                                    </ul>
                                </div>

                                <div>
                                    <h3 class="text-xs font-bold text-gray-900 mb-4 uppercase tracking-wider border-b pb-2">Machinery</h3>
                                    <ul class="space-y-3">
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Embroidery Machines</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Water Jet Loom</a></li>
                                        <li><a href="#" class="text-gray-500 text-sm hover:text-yellow-600 hover:translate-x-1 inline-block transition-transform duration-200">› Spare Parts</a></li>
                                    </ul>
                                </div>

                            </div>
                        </div>
                    </div>
                    <a href="/about" class="text-sm font-semibold text-gray-700 hover:text-yellow-600 transition">Our Story</a>
                    
                    <div class="flex items-center space-x-4 pl-4 border-l border-gray-300">
                        <div class="text-blue-500">
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
                        </div>
                        <div class="flex flex-col">
                            <div class="flex items-center space-x-2 text-sm font-bold text-gray-800">
                                <a href="/login" class="hover:text-blue-600 transition">Sign In</a>
                                <span class="text-gray-400">|</span>
                                <a href="/register" class="hover:text-blue-600 transition flex items-center gap-1">
                                    Free Join
                                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </a>
                            </div>
                            <span class="text-xs text-gray-500 mt-0.5">My Account</span>
                        </div>
                    </div>

                    <a href="#inquiry" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-bold text-white transition-all duration-200 bg-gray-900 rounded-lg hover:bg-yellow-600">
                        GET QUOTE
                    </a>
                </div>

                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-button" class="text-gray-800 focus:outline-none">
                        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </nav>
    <div class="pt-20"></div>

   <section class="relative w-full min-h-[70vh] flex flex-col justify-center bg-gray-900 bg-cover bg-center bg-no-repeat group pt-24 md:pt-32"
             style="background-image: url('https://i.pinimg.com/736x/f4/c4/3c/f4c43cd02794709f565d65d40a83d66b.jpg');">
        
        <div class="absolute inset-0 bg-black/70 z-0 transition-opacity duration-700 group-hover:bg-black/60"></div>

        <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 mt-10">
            
            <div class="text-center mb-10 animate-[fadeInDown_1s_ease-in-out]">
                <h1 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight mb-4 drop-shadow-lg">
                    B2B Trade Portal & Textile Business Listing
                </h1>
                <p class="text-gray-300 text-lg md:text-xl font-medium">
                    Connect with Top Verified Suppliers & Buyers Globally
                </p>
            </div>

            <div class="max-w-4xl mx-auto bg-white rounded-xl shadow-2xl p-2 md:p-3 hover:shadow-[0_0_30px_rgba(202,138,4,0.3)] transition-shadow duration-500">
                <form action="/search" method="GET" class="flex flex-col md:flex-row gap-2">
                    <div class="relative md:w-48 flex-shrink-0">
                        <select name="category" class="w-full h-12 px-4 bg-gray-50 border-none rounded-lg text-gray-700 font-semibold focus:ring-2 focus:ring-yellow-500 cursor-pointer outline-none appearance-none transition-colors hover:bg-gray-100">
                            <option value="products">Products</option>
                            <option value="suppliers">Suppliers</option>
                            <option value="buyers">Buyers</option>
                        </select>
                        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-500">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </div>

                    <div class="hidden md:block w-px bg-gray-200 my-2"></div>

                    <div class="flex-1">
                        <input type="text" name="query" placeholder="Find Your Textile Needs..." 
                               class="w-full h-12 px-4 bg-transparent border-none text-gray-900 placeholder-gray-400 font-medium focus:ring-0 outline-none text-lg">
                    </div>

                    <button type="submit" class="h-12 md:w-32 px-6 bg-gray-900 hover:bg-yellow-600 text-white font-bold rounded-lg transition-all duration-300 flex items-center justify-center gap-2 group/btn">
                        <span>SEARCH</span>
                        <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </button>
                </form>
            </div>

            <div class="mt-16 md:mt-24 grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 w-full max-w-5xl mx-auto">
                <div class="flex flex-col items-center justify-center p-6 bg-white/10 backdrop-blur-md rounded-xl border border-white/10 hover:border-yellow-500/50 hover:bg-white/20 transition-all duration-300 hover:-translate-y-2 cursor-default group/stat">
                    <span class="text-3xl md:text-4xl font-extrabold text-yellow-500 tracking-tight group-hover/stat:scale-110 transition-transform">354,702</span>
                    <span class="text-xs md:text-sm font-semibold text-gray-300 mt-2 uppercase tracking-wider">Verified Suppliers</span>
                </div>
                <div class="flex flex-col items-center justify-center p-6 bg-white/10 backdrop-blur-md rounded-xl border border-white/10 hover:border-yellow-500/50 hover:bg-white/20 transition-all duration-300 hover:-translate-y-2 cursor-default group/stat">
                    <span class="text-3xl md:text-4xl font-extrabold text-white tracking-tight group-hover/stat:scale-110 transition-transform">404,404</span>
                    <span class="text-xs md:text-sm font-semibold text-gray-300 mt-2 uppercase tracking-wider">Products</span>
                </div>
                <div class="flex flex-col items-center justify-center p-6 bg-white/10 backdrop-blur-md rounded-xl border border-white/10 hover:border-yellow-500/50 hover:bg-white/20 transition-all duration-300 hover:-translate-y-2 cursor-default group/stat">
                    <span class="text-3xl md:text-4xl font-extrabold text-yellow-500 tracking-tight group-hover/stat:scale-110 transition-transform">592,976</span>
                    <span class="text-xs md:text-sm font-semibold text-gray-300 mt-2 uppercase tracking-wider">Trusted Buyers</span>
                </div>
                <div class="flex flex-col items-center justify-center p-6 bg-white/10 backdrop-blur-md rounded-xl border border-white/10 hover:border-yellow-500/50 hover:bg-white/20 transition-all duration-300 hover:-translate-y-2 cursor-default group/stat">
                    <span class="text-3xl md:text-4xl font-extrabold text-white tracking-tight group-hover/stat:scale-110 transition-transform">412,486</span>
                    <span class="text-xs md:text-sm font-semibold text-gray-300 mt-2 uppercase tracking-wider">Global Companies</span>
                </div>
            </div>
        </div>
    </section>
</body>
</html>