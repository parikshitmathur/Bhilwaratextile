<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>
        body { background: #050507; color: white; margin: 0; }
        .gold-text { 
            background: linear-gradient(to right, #C9922A, #F3D084, #C9922A);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .glass-card { 
            background: rgba(15, 15, 19, 0.6); 
            backdrop-filter: blur(10px); 
            border: 1px solid rgba(255, 255, 255, 0.03); 
        }
        /* Custom Scrollbar for Compact Look */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: #C9922A; border-radius: 10px; }
        
        .main-wrapper { display: flex; min-height: 100vh; }
        .content-area { flex: 1; min-width: 0; }
    </style>
</head>
<body>

    <div class="main-wrapper">
        <div class="shrink-0">
            <%- include('./partials/sidebar') %>
        </div>

        <div class="content-area p-4 lg:p-8">
            
            <div class="flex justify-between items-end mb-8 border-b border-white/5 pb-6">
                <div>
                    <h1 class="text-2xl lg:text-3xl font-black italic uppercase tracking-tighter">
                        Inquiry <span class="gold-text">Authority</span>
                    </h1>
                    <p class="text-[8px] uppercase tracking-[0.4em] text-zinc-500 mt-1 font-bold">Signal Database</p>
                </div>
                <div class="bg-zinc-900/50 border border-white/5 px-3 py-1 rounded-full">
                    <span class="text-[9px] font-black uppercase text-[#C9922A] tracking-widest">
                        Total: <%= inquiries ? inquiries.length : 0 %>
                    </span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% if(inquiries && inquiries.length > 0){ %>
                    <% inquiries.forEach((item)=>{ %>
                        <div class="glass-card rounded-3xl p-4 hover:border-[#C9922A]/30 transition-all duration-300">
                            
                            <div class="flex items-center justify-between mb-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-[#C9922A]/10 flex items-center justify-center border border-[#C9922A]/10 text-[#C9922A]">
                                        <i class="fa-solid fa-bolt-lightning text-xs"></i>
                                    </div>
                                    <div>
                                        <h2 class="text-xs font-black uppercase text-white truncate max-w-[150px]">
                                            <%= item.name || 'Anonymous' %>
                                        </h2>
                                        <p class="text-[7px] text-zinc-500 uppercase tracking-widest mt-0.5 font-bold">Identity Verified</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <span class="text-[8px] text-[#C9922A] font-mono font-bold">
                                        <%= item.createdAt ? new Date(item.createdAt).toLocaleDateString('en-IN') : 'N/A' %>
                                    </span>
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-2 mb-3">
                                <div class="bg-black/40 rounded-xl p-2.5 border border-white/5">
                                    <p class="text-[7px] uppercase tracking-widest text-zinc-500 font-black mb-1">Email Node</p>
                                    <h3 class="text-[10px] text-zinc-200 truncate font-semibold"><%= item.email || 'N/A' %></h3>
                                </div>
                                <div class="bg-black/40 rounded-xl p-2.5 border border-white/5">
                                    <p class="text-[7px] uppercase tracking-widest text-zinc-500 font-black mb-1">Mobile Secure</p>
                                    <h3 class="text-[10px] text-zinc-200 font-semibold"><%= item.mobile || 'Private' %></h3>
                                </div>
                            </div>

                            <div class="bg-zinc-900/40 rounded-2xl p-3 border border-white/5">
                                <p class="text-[7px] uppercase tracking-widest text-[#C9922A] font-black mb-2 flex items-center gap-2">
                                    <span class="w-1 h-1 rounded-full bg-[#C9922A]"></span> Dispatch Content
                                </p>
                                <div class="text-[10px] text-zinc-400 leading-relaxed italic line-clamp-3">
                                    "<%= item.message || 'No specific requirement provided.' %>"
                                </div>
                            </div>

                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full py-20 text-center glass-card rounded-[3rem]">
                        <div class="w-16 h-16 rounded-full bg-zinc-900 flex items-center justify-center mx-auto mb-4 border border-white/5">
                            <i class="fa-solid fa-satellite-dish text-xl text-zinc-700"></i>
                        </div>
                        <h2 class="text-sm font-black uppercase text-zinc-500 tracking-widest italic">
                            No incoming signals detected
                        </h2>
                    </div>
                <% } %>
            </div>

        </div>
    </div>

</body>
</html>