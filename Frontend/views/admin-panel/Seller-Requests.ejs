<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<script>
    tailwind.config = {
        theme: {
            extend: {
                fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
                colors: { gold: '#C9922A', surface: '#0f0f13' }
            }
        }
    }
</script>

<style>
    body { background-color: #050507; color: #d4d4d8; margin: 0; overflow-x: hidden; }
    .glass-card { background: rgba(17, 17, 19, 0.6); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.05); }
    
    /* Ultra Compact Status Pills */
    .status-pill { font-size: 8px; font-weight: 800; text-transform: uppercase; padding: 2px 8px; border-radius: 999px; letter-spacing: 0.05em; }
    .st-pending { background: rgba(234,179,8,0.1); color: #eab308; border: 1px solid rgba(234,179,8,0.2); }
    .st-approved { background: rgba(34,197,94,0.1); color: #22c55e; border: 1px solid rgba(34,197,94,0.2); }
    .st-rejected { background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
    
    /* Layout Fix: Flex container handles the gap automatically */
    .main-container { display: flex; min-height: 100vh; width: 100%; }
    .authority-wrapper { flex: 1; min-width: 0; } /* min-width: 0 prevents flex child from overflowing */

    /* Compact Sizes */
    h1 { font-size: 1.5rem !important; }
    .stat-val { font-size: 1.25rem !important; }
    .table-text { font-size: 11px !important; }
    .sub-text { font-size: 9px !important; }
</style>

<div class="main-container">
    <div class="shrink-0">
        <%- include('partials/sidebar') %>
    </div>

    <div class="authority-wrapper flex flex-col">
        <main class="p-4 lg:p-8 w-full max-w-7xl">
            
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h1 class="font-black text-white italic uppercase tracking-tighter">
                        Seller <span class="text-gold">Authority</span>
                    </h1>
                    <p class="sub-text font-bold text-zinc-500 uppercase tracking-widest">Verification Control</p>
                </div>
                <div class="bg-surface border border-zinc-800 px-3 py-1 rounded-xl flex items-center gap-2">
                    <span class="flex h-1.5 w-1.5 relative">
                        <span class="animate-ping absolute h-full w-full rounded-full bg-green-500 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
                    </span>
                    <span class="text-[8px] font-black text-zinc-400 uppercase tracking-tight italic">Live Database</span>
                </div>
            </div>

            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                <div class="glass-card p-4 rounded-2xl border-l-2 border-gold">
                    <p class="sub-text font-bold text-zinc-500 uppercase">Total</p>
                    <h3 id="statTotal" class="stat-val font-black text-white mt-0.5">0</h3>
                </div>
                <div class="glass-card p-4 rounded-2xl border-l-2 border-yellow-500">
                    <p class="sub-text font-bold text-zinc-500 uppercase">Pending</p>
                    <h3 id="statPending" class="stat-val font-black text-white mt-0.5">0</h3>
                </div>
                <div class="glass-card p-4 rounded-2xl border-l-2 border-green-500">
                    <p class="sub-text font-bold text-zinc-500 uppercase">Approved</p>
                    <h3 id="statApproved" class="stat-val font-black text-white mt-0.5">0</h3>
                </div>
                <div class="glass-card p-4 rounded-2xl border-l-2 border-red-500">
                    <p class="sub-text font-bold text-zinc-500 uppercase">Rejected</p>
                    <h3 id="statRejected" class="stat-val font-black text-white mt-0.5">0</h3>
                </div>
            </div>

            <div class="glass-card rounded-2xl overflow-hidden border-zinc-800/50 shadow-2xl">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-black/40 border-b border-zinc-800">
                            <tr class="text-[9px] font-black text-zinc-500 uppercase tracking-widest">
                                <th class="px-5 py-4">Merchant Details</th>
                                <th class="px-5 py-4 text-center">Current Status</th>
                                <th class="px-5 py-4 text-right">Verification</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody" class="divide-y divide-zinc-800/30">
                            </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</div>

<div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 hidden z-[9999] px-4 py-2 rounded-full font-bold text-[10px] shadow-2xl backdrop-blur-md"></div>

<script>
let data = [];

async function load() {
    try {
        const res = await fetch('/admin/seller-requests/data');
        data = await res.json();
        updateStats();
        render();
    } catch (e) { 
        showToast("System Error: Fetch Failed", true);
    }
}

function updateStats() {
    document.getElementById('statTotal').innerText = data.length;
    document.getElementById('statPending').innerText = data.filter(x => !x.status || x.status === 'Pending').length;
    document.getElementById('statApproved').innerText = data.filter(x => x.status === 'Approved').length;
    document.getElementById('statRejected').innerText = data.filter(x => x.status === 'Rejected').length;
}

function render() {
    const table = document.getElementById('tableBody');
    if (!data.length) {
        table.innerHTML = '<tr><td colspan="3" class="p-8 text-center text-zinc-700 uppercase font-black sub-text">No Records found in database</td></tr>';
        return;
    }

    table.innerHTML = data.map(s => {
        const statusClass = s.status === 'Approved' ? 'st-approved' : (s.status === 'Rejected' ? 'st-rejected' : 'st-pending');
        return `
            <tr class="hover:bg-white/[0.02] transition-all">
                <td class="px-5 py-3.5">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-zinc-900 border border-zinc-800 flex items-center justify-center text-gold/60 overflow-hidden shadow-inner">
                            ${s.logo ? `<img src="${s.logo}" class="w-full h-full object-cover">` : `<i class="fas fa-building text-sm"></i>`}
                        </div>
                        <div>
                            <h4 class="table-text font-bold text-white uppercase tracking-tight leading-none">${s.companyName || 'Bhilwara Merchant'}</h4>
                            <p class="sub-text text-zinc-500 mt-1 font-semibold italic">${s.email} | ${s.mobile || 'No Contact'}</p>
                        </div>
                    </div>
                </td>
                <td class="px-5 py-3.5 text-center">
                    <span class="status-pill ${statusClass}">${s.status || 'Pending'}</span>
                </td>
                <td class="px-5 py-3.5">
                    <div class="flex justify-end gap-2">
                        <button onclick="updateStatus(this, '${s._id}', 'Approved')" class="w-8 h-8 rounded-xl bg-green-500/10 text-green-500 border border-green-500/20 hover:bg-green-500 hover:text-white transition-all text-[11px] flex items-center justify-center shadow-lg shadow-green-500/5">
                            <i class="fas fa-check"></i>
                        </button>
                        <button onclick="updateStatus(this, '${s._id}', 'Rejected')" class="w-8 h-8 rounded-xl bg-red-500/10 text-red-500 border border-red-500/20 hover:bg-red-500 hover:text-white transition-all text-[11px] flex items-center justify-center shadow-lg shadow-red-500/5">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </td>
            </tr>
        `;
    }).join('');
}

async function updateStatus(btn, id, status) {
    try {
        btn.disabled = true;
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

        const response = await fetch('/api/seller/update-status/' + id, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: status })
        });

        if (response.ok) {
            showToast("Authority Verified: " + status, false);
            await load();
        } else {
            const contentType = response.headers.get("content-type");
            let msg = "Update Blocked";
            if (contentType && contentType.indexOf("application/json") !== -1) {
                const errData = await response.json();
                msg = errData.message || msg;
            }
            showToast(msg, true);
            btn.innerHTML = originalHTML;
            btn.disabled = false;
        }
    } catch (e) {
        showToast("System Error: Connection Failed", true);
        btn.disabled = false;
    }
}

function showToast(msg, err = false) {
    const t = document.getElementById('toast');
    t.innerText = msg;
    t.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-[9999] px-5 py-2 rounded-full font-bold text-[9px] shadow-2xl backdrop-blur-xl ${err ? 'bg-red-500/20 text-red-400 border border-red-500/30' : 'bg-green-500/20 text-green-400 border border-green-500/30'}`;
    t.classList.remove('hidden');
    setTimeout(() => t.classList.add('hidden'), 3000);
}

load();
</script>