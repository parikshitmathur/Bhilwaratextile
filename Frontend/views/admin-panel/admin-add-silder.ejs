<%- include('./partials/sidebar') %>

<!-- Tailwind & FontAwesome -->
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<!-- 🛠️ GAP FIX: Main container with precise alignment -->
<div class="min-h-screen bg-[#08090a] flex">
    
    <main class="flex-1 lg:ml-72 p-6 md:p-10 transition-all duration-500">
        <div class="max-w-7xl mx-auto">
            
            <!-- ✨ Elite Header -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-12">
                <div>
                    <h1 class="text-4xl font-black tracking-tighter text-white italic">
                        HERO <span class="text-[#C9922A]">SLIDER</span> AUTHORITY
                    </h1>
                    <p class="text-gray-500 text-xs font-bold uppercase tracking-[0.3em] mt-2">Control the first impression of your legacy</p>
                </div>
                <div class="px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-[10px] font-black text-[#C9922A] uppercase tracking-widest">
                    Maximum 3 Active Slides
                </div>
            </div>

            <!-- 🎴 Slider Control Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% [1, 2, 3].forEach(num => { 
                    const slide = slides.find(s => s.slideNumber === num);
                %>
                <div class="group bg-white/[0.02] border border-white/10 p-1 rounded-[2.5rem] hover:border-[#C9922A]/30 transition-all duration-500 shadow-2xl">
                    <div class="bg-[#0b111a] p-6 rounded-[2.4rem] h-full flex flex-col">
                        
                        <!-- Slide Badge -->
                        <div class="flex justify-between items-center mb-6">
                            <span class="px-4 py-1 bg-[#C9922A] text-black text-[10px] font-black rounded-full uppercase tracking-tighter">
                                SLIDE 0<%= num %>
                            </span>
                            <% if(slide) { %>
                                <span class="text-[10px] text-green-500 font-bold uppercase tracking-widest"><i class="fa-solid fa-circle-check"></i> Live</span>
                            <% } %>
                        </div>

                        <!-- Preview Frame -->
                        <div class="relative w-full h-44 rounded-3xl overflow-hidden mb-6 border border-white/5 bg-black/40 group-hover:shadow-[0_0_30px_rgba(201,146,42,0.1)] transition-all">
                            <% if(slide && slide.imagePath) { %>
                                <img src="<%= slide.imagePath %>" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700">
                            <% } else { %>
                                <div class="flex flex-col items-center justify-center h-full text-gray-700">
                                    <i class="fa-solid fa-image text-3xl mb-2"></i>
                                    <p class="text-[10px] font-bold uppercase tracking-widest">No Visual Set</p>
                                </div>
                            <% } %>
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                        </div>

                        <!-- Update Form -->
                        <form action="/api/admin/update-slide" method="POST" enctype="multipart/form-data" class="space-y-4 flex-1 flex flex-col">
                            <input type="hidden" name="slideNumber" value="<%= num %>">
                            
                            <div class="relative group/file">
                                <label class="flex items-center justify-center gap-3 w-full p-3 bg-white/5 border border-dashed border-white/20 rounded-xl cursor-pointer hover:bg-white/10 transition-all">
                                    <i class="fa-solid fa-cloud-arrow-up text-[#C9922A]"></i>
                                    <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Upload Fabric Visual</span>
                                    <input type="file" name="slideImage" class="hidden">
                                </label>
                            </div>

                            <input type="text" name="title" placeholder="Main Heading (Thread Legacy...)" 
                                value="<%= slide ? slide.title : '' %>"
                                class="w-full bg-white/5 border border-white/10 p-4 rounded-2xl outline-none focus:border-[#C9922A] text-sm font-bold text-white transition-all placeholder:text-gray-700">
                            
                            <textarea name="subtitle" placeholder="Subtext describing the loom craft..." 
                                class="w-full bg-white/5 border border-white/10 p-4 rounded-2xl outline-none focus:border-[#C9922A] text-[11px] h-24 resize-none leading-relaxed text-gray-400 transition-all placeholder:text-gray-700"><%= slide ? slide.subtitle : '' %></textarea>

                            <button type="submit" class="mt-auto w-full bg-[#C9922A] text-black font-black py-4 rounded-2xl hover:scale-[1.02] hover:shadow-[0_10px_30px_rgba(201,146,42,0.2)] active:scale-95 transition-all uppercase tracking-widest text-xs">
                                Publish Slide <%= num %>
                            </button>
                        </form>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </main>
</div>

<style>
    /* Custom Scrollbar for better UX */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-thumb { background: #C9922A; border-radius: 10px; }
    
    /* 🛠️ GAP FIX: Prevent any horizontal scroll */
    body { overflow-x: hidden; }
    main {
    margin-top: 0 !important; /* Forcefully remove top gap */
    padding-top: 2rem;        /* Space from the top edge */
}
</style>