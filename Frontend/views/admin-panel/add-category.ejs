<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Categories | Bhilwara Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lato:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Lato', sans-serif; }
        .heading-font { font-family: 'Playfair Display', serif; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c8962a; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #1a1a1a; }
    </style>
</head>
<body class="bg-[#f4f0e8] min-h-screen flex items-center justify-center p-4">

    <div class="bg-white w-full max-w-5xl rounded-2xl shadow-2xl overflow-hidden border border-gray-100 transform transition-all hover:scale-[1.01]">
        
        <div class="bg-[#1a1a1a] px-8 py-8 border-b-4 border-[#c8962a] relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iOCIgaGVpZ2h0PSI4IiBmaWxsPSIjZmZmIj48L3JlY3Q+CjxwYXRoIGQ9Ik0wIDBMOCA4Wk04IDBMMCA4WiIgc3Ryb2tlPSIjMDAwIiBzdHJva2Utd2lkdGg9IjEiPjwvcGF0aD4KPC9zdmc+')]"></div>
            <div class="relative z-10 text-center">
                <h2 class="text-3xl text-white font-bold tracking-wider heading-font">
                    Manage <span class="text-[#c8962a]">Categories</span>
                </h2>
                <p class="text-gray-400 text-sm mt-2">Add new fabric collections and view your existing inventory.</p>
            </div>
        </div>

        <div class="flex flex-col md:flex-row">
         <form action="/api/category/add" method="POST" enctype="multipart/form-data" class="p-8 space-y-6 md:w-1/2 border-b md:border-b-0 md:border-r border-gray-100 bg-white">
    <div>
        <h3 class="text-xl font-bold text-gray-800 mb-6 heading-font border-b-2 border-[#c8962a] inline-block pb-1">Add New</h3>
    </div>

    <div>
        <label class="block text-sm font-bold text-gray-800 mb-2 uppercase tracking-wide">Category Name <span class="text-red-500">*</span></label>
        <input type="text" name="name" required placeholder="e.g., Premium Winter Woolens"
            class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#c8962a]">
    </div>

    <div>
        <label class="block text-sm font-bold text-gray-800 mb-2 uppercase tracking-wide">Category Image</label>
        <input type="file" name="image" accept="image/*"
            class="w-full px-5 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#c8962a] file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-[#1a1a1a] file:text-[#c8962a] hover:file:bg-gray-800 transition-all cursor-pointer">
    </div>

    <div>
        <label class="block text-sm font-bold text-gray-800 mb-2 uppercase tracking-wide">Description</label>
        <textarea name="description" rows="3" placeholder="Write a short detail..."
            class="w-full px-5 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#c8962a] resize-none"></textarea>
    </div>

    <hr class="border-gray-100 my-4">

    <div class="flex items-center justify-between pt-2">
        <a href="/admin" class="text-gray-500 hover:text-[#c8962a] font-bold text-sm transition-colors flex items-center gap-2">
            Dashboard
        </a>
        <button type="submit" class="bg-[#1a1a1a] text-white px-6 py-3 rounded-lg font-bold hover:bg-[#c8962a] transition-all duration-300">
            Save Category
        </button>
    </div>
</form>

            <div class="p-8 md:w-1/2 bg-gray-50 flex flex-col">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-800 heading-font border-b-2 border-[#c8962a] inline-block pb-1">Existing Categories</h3>
                    <span class="bg-[#1a1a1a] text-[#c8962a] text-xs font-bold px-3 py-1 rounded-full shadow-sm"><%= categories.length %> Total</span>
                </div>
                
                <div class="flex-1 overflow-y-auto max-h-[350px] pr-2 custom-scrollbar space-y-4">
                    
                 <% categories.forEach(function(cat) { %>
    <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow group relative">
        
        <div class="h-16 w-16 flex-shrink-0 rounded-lg overflow-hidden bg-gray-100 border border-gray-200">
            <% if(cat.image) { %>
                <img src="<%= cat.image %>" alt="<%= cat.name %>" class="h-full w-full object-cover">
            <% } else { %>
                <div class="h-full w-full flex items-center justify-center text-gray-400 text-xs text-center">No Img</div>
            <% } %>
        </div>

        <div class="flex-1">
            <h4 class="font-bold text-gray-900"><%= cat.name %></h4>
            <p class="text-xs text-gray-500 mt-1 line-clamp-1"><%= cat.description || "No description" %></p>
        </div>
        
        <form action="/api/category/delete/<%= cat._id %>" method="POST" onsubmit="return confirm('Pakka delete karna hai bhai?');">
            <button type="submit" class="text-gray-400 hover:text-red-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
        </form>
    </div>
<% }); %>

                </div>
            </div>

        </div>
    </div>
</body>
</html>