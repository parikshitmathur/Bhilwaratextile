<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vault Control | Bhilwara Authority</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        /* Pure Black Theme Overrides */
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #000000; /* Pitch Black */
            color: #a1a1aa; 
        }
        
        .glass-card { 
            background: #09090b; /* Slightly lighter black for depth */
            border: 1px solid #18181b; 
        }
        
        .input-dark { 
            background: #000000; 
            border: 1px solid #27272a; 
            color: #fff; 
            transition: 0.2s ease; 
        }
        
        .input-dark:focus { 
            border-color: #c8962a; 
            outline: none; 
            box-shadow: 0 0 15px rgba(200, 150, 42, 0.1); 
        }

        .custom-scrollbar::-webkit-scrollbar { width: 3px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c8962a; border-radius: 10px; }
        
        /* Subtle Glow for Categories */
        .category-card:hover {
            border-color: #c8962a;
            background: #0c0c0e;
            transform: translateY(-2px);
        }
    </style>
</head>
<body class="antialiased">

    <div class="flex h-screen overflow-hidden">
        <%- include('partials/sidebar') %>

        <div class="flex-1 flex flex-col min-w-0 bg-black">


            <main class="flex-1 overflow-y-auto p-4 lg:p-8 custom-scrollbar">
                
                <!-- Page Header -->
                <div class="mb-8">
                    <div class="flex items-center gap-3 mb-1">
                        <div class="h-5 w-[2px] bg-[#c8962a]"></div>
                        <h1 class="text-2xl font-black text-white uppercase tracking-tighter italic">
                            Vault <span class="text-[#c8962a]">Control</span>
                        </h1>
                    </div>
                    <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-[0.3em] ml-4">Segment Management System</p>
                </div>

                <div class="grid lg:grid-cols-12 gap-8">
                    
                    <!-- Left: Register Segment Form -->
                    <div class="lg:col-span-4">
                        <div class="glass-card rounded-2xl p-6 sticky top-0 shadow-2xl">
                            <h3 class="text-[10px] font-black text-zinc-400 mb-6 uppercase tracking-[0.2em] flex items-center gap-2">
                                <span class="w-2 h-2 bg-[#c8962a] rounded-full animate-pulse"></span> Create New Segment
                            </h3>

                            <form action="/api/category/add" method="POST" enctype="multipart/form-data" class="space-y-5">
                                <div>
                                    <label class="text-[10px] font-black text-zinc-500 uppercase mb-2 block tracking-widest">Category Name</label>
                                    <input type="text" name="name" required placeholder="e.g. PREMIUM SUITINGS" 
                                        class="w-full input-dark rounded-lg px-4 py-3 text-[12px] font-bold tracking-wide">
                                </div>

                                <div>
                                    <label class="text-[10px] font-black text-zinc-500 uppercase mb-2 block tracking-widest">Sub-Tags</label>
                                    <input type="text" name="subcategories" placeholder="Cotton, PV, Lycra..." 
                                        class="w-full input-dark rounded-lg px-4 py-3 text-[12px] font-bold tracking-wide">
                                </div>

                                <div>
                                    <label class="text-[10px] font-black text-zinc-500 uppercase mb-2 block tracking-widest">Visual Identity</label>
                                    <div class="relative border-2 border-dashed border-zinc-800 rounded-lg p-6 text-center hover:border-[#c8962a]/50 hover:bg-zinc-900/50 transition-all cursor-pointer group">
                                        <input type="file" name="image" required class="absolute inset-0 opacity-0 cursor-pointer">
                                        <div class="flex flex-col items-center gap-2">
                                            <svg class="w-5 h-5 text-zinc-600 group-hover:text-[#c8962a] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                            <span class="text-[9px] font-black text-zinc-500 uppercase tracking-widest group-hover:text-white">Upload Thumbnail</span>
                                        </div>
                                    </div>
                                </div>

                                <button type="submit" class="w-full bg-[#c8962a] hover:bg-white text-black font-black py-4 rounded-lg transition-all text-[11px] uppercase tracking-[0.2em] shadow-lg shadow-[#c8962a]/10">
                                    Sync to Inventory
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Right: Active Clusters Grid -->
                    <div class="lg:col-span-8">
                        <div class="flex items-center justify-between mb-6 px-1">
                            <h3 class="text-[11px] font-black text-zinc-400 uppercase tracking-[0.2em]">Active Clusters</h3>
                            <div class="flex items-center gap-2">
                                <span class="text-[10px] font-black text-[#c8962a] bg-[#c8962a]/10 border border-[#c8962a]/20 px-3 py-1 rounded-full uppercase">
                                    Total: <%= categories.length %>
                                </span>
                            </div>
                        </div>

                        <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-4">
                            <% categories.forEach(function(cat) { %>
                                <div class="glass-card category-card rounded-xl p-4 flex items-center gap-4 group relative transition-all duration-300">
                                    
                                    <!-- Thumbnail -->
                                    <div class="w-12 h-12 rounded-lg bg-black border border-zinc-800 overflow-hidden flex-shrink-0 shadow-inner">
                                        <% if(cat.image) { %>
                                            <img src="<%= cat.image %>" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-500">
                                        <% } else { %>
                                            <div class="w-full h-full flex items-center justify-center text-zinc-800 text-[10px] font-black">NO IMG</div>
                                        <% } %>
                                    </div>

                                    <!-- Name & Tags -->
                                    <div class="flex-1 min-w-0">
                                        <h4 class="text-white text-[12px] font-black uppercase truncate tracking-tight mb-0.5"><%= cat.name %></h4>
                                        <div class="flex flex-wrap gap-1">
                                            <p class="text-[9px] text-zinc-500 font-bold uppercase tracking-tighter truncate opacity-70 group-hover:opacity-100 transition-opacity">
                                                <%= cat.subcategories ? cat.subcategories.join(' • ') : 'No Tags' %>
                                            </p>
                                        </div>
                                    </div>

                                    <!-- Actions -->
                                    <form action="/api/category/delete/<%= cat._id %>" method="POST" onsubmit="return confirm('Archive this segment?');" class="opacity-0 group-hover:opacity-100 transition-all">
                                        <button class="bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white p-2 rounded-lg transition-all border border-red-500/20">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>
                                </div>
                            <% }); %>
                        </div>
                    </div>

                </div>
            </main>
        </div>
    </div>
</body>
</html>