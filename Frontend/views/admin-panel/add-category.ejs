<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Categories | Bhilwara Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lato:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Lato', sans-serif; }
        .heading-font { font-family: 'Playfair Display', serif; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c8962a; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #1a1a1a; }
    </style>
</head>
<body class="bg-[#f4f0e8] min-h-screen flex overflow-hidden">

    <%- include('partials/sidebar') %>

    <div class="flex-1 flex flex-col h-screen overflow-hidden">
        
        <%- include('partials/header') %>

        <main class="flex-1 overflow-y-auto p-4 md:p-8 flex items-start justify-center">
            
            <div class="bg-white w-full max-w-6xl rounded-2xl shadow-2xl overflow-hidden border border-gray-100 mt-4">
                
                <div class="bg-[#1a1a1a] px-8 py-8 border-b-4 border-[#c8962a] relative overflow-hidden">
                    <div class="absolute inset-0 opacity-10 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iOCIgaGVpZ2h0PSI4IiBmaWxsPSIjZmZmIj48L3JlY3Q+CjxwYXRoIGQ9Ik0wIDBMOCA4Wk04IDBMMCA4WiIgc3Ryb2tlPSIjMDAwIiBzdHJva2Utd2lkdGg9IjEiPjwvcGF0aD4KPC9zdmc+')]"></div>
                    <div class="relative z-10 text-center">
                        <h2 class="text-3xl text-white font-bold tracking-wider heading-font">
                            Manage <span class="text-[#c8962a]">Categories</span>
                        </h2>
                        <p class="text-gray-400 text-sm mt-2">Add new fabric collections and view your existing inventory.</p>
                    </div>
                </div>

                <div class="flex flex-col md:flex-row h-full">
                    
                    <div class="p-8 md:w-1/2 bg-white border-r border-gray-100">
                        <div class="mb-6">
                            <h3 class="text-xl font-bold text-gray-800 heading-font border-b-2 border-[#1a1a1a] inline-block pb-1">Add New Category</h3>
                        </div>

                        <form action="/api/category/add" method="POST" enctype="multipart/form-data" class="space-y-5">
                            
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-1">Category Name <span class="text-red-500">*</span></label>
                                <input type="text" name="name" placeholder="e.g. Premium Suiting" required 
                                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:border-[#c8962a] focus:ring-2 focus:ring-[#c8962a]/20 transition-all outline-none text-sm text-gray-800">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-1">Description</label>
                                <textarea name="description" placeholder="Briefly describe this category..." 
                                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:border-[#c8962a] focus:ring-2 focus:ring-[#c8962a]/20 transition-all outline-none text-sm text-gray-800 min-h-[100px] resize-y"></textarea>
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-1">Sub-categories</label>
                                <input type="text" name="subcategories" placeholder="Cotton, Silk, Denim (Comma separated)" 
                                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:border-[#c8962a] focus:ring-2 focus:ring-[#c8962a]/20 transition-all outline-none text-sm text-gray-800">
                                <p class="text-xs text-gray-400 mt-1">Separate multiple items with a comma.</p>
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-1">Category Image <span class="text-red-500">*</span></label>
                                <div class="relative w-full border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-[#c8962a] hover:bg-[#c8962a]/5 transition-all cursor-pointer group bg-gray-50">
                                    <input type="file" name="image" required class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                    <div class="text-gray-500 group-hover:text-[#c8962a] flex flex-col items-center pointer-events-none">
                                        <svg class="w-8 h-8 mb-2 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                        <span class="text-sm font-semibold">Click to upload or drag and drop</span>
                                        <span class="text-xs mt-1 opacity-70">PNG, JPG up to 5MB</span>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="w-full bg-[#1a1a1a] hover:bg-[#c8962a] text-white font-bold py-3.5 px-4 rounded-xl transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5 mt-4">
                                Save Category
                            </button>
                        </form>
                    </div>

                    <div class="p-8 md:w-1/2 bg-gray-50 flex flex-col h-full">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-xl font-bold text-gray-800 heading-font border-b-2 border-[#c8962a] inline-block pb-1">Existing Inventory</h3>
                            <span class="bg-[#1a1a1a] text-[#c8962a] text-xs font-bold px-3 py-1 rounded-full shadow-sm">
                                <%= categories.length %> Total
                            </span>
                        </div>
                        
                        <div class="flex-1 overflow-y-auto max-h-[550px] pr-3 custom-scrollbar space-y-4">
                            <% categories.forEach(function(cat) { %>
                                <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[#c8962a]/30 transition-all group relative flex flex-col">
                                    
                                    <form action="/api/category/delete/<%= cat._id %>" method="POST" class="absolute right-4 top-4 z-10" onsubmit="return confirm('Pakka delete karna hai bhai? No going back from this one.');">
                                        <button type="submit" class="p-2 text-gray-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors bg-white" title="Delete Category">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>

                                    <div class="flex items-start gap-4 pr-12">
                                        
                                        <div class="h-16 w-16 flex-shrink-0 rounded-lg overflow-hidden bg-gray-100 border border-gray-200">
                                            <% if(cat.image) { %>
                                                <img src="<%= cat.image %>" alt="<%= cat.name %>" class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-500">
                                            <% } else { %>
                                                <div class="h-full w-full flex items-center justify-center text-gray-400 text-xs text-center font-semibold">No Img</div>
                                            <% } %>
                                        </div>

                                        <div class="flex-1 mt-1">
                                            <h4 class="font-bold text-gray-900 text-lg flex items-center gap-2">
                                                <%= cat.name %>
                                            </h4>
                                            <p class="text-xs text-gray-500 mt-0.5"><%= cat.description || "No description provided." %></p>
                                        </div>
                                    </div>
                                    
                                    <div class="mt-4 pt-4 border-t border-gray-100">
                                        <p class="text-[10px] font-bold text-gray-400 mb-2 uppercase tracking-wider">Sub-categories:</p>
                                        
                                        <% if(cat.subcategories && cat.subcategories.length > 0) { %>
                                            <div class="flex flex-wrap gap-2">
                                                <% cat.subcategories.forEach(function(sub) { %>
                                                    <span class="bg-[#c8962a]/10 text-[#c8962a] border border-[#c8962a]/20 px-3 py-1 rounded-full text-xs font-bold shadow-sm">
                                                        <%= sub %>
                                                    </span>
                                                <% }); %>
                                            </div>
                                        <% } else { %>
                                            <p class="text-xs text-gray-400 italic">No sub-categories added yet.</p>
                                        <% } %>
                                    </div>

                                </div>
                            <% }); %>
                        </div>
                    </div>

                </div>
            </div>
        </main>
    </div>
</body>
</html>