<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .gold-text {
            background: linear-gradient(to right, #C9922A, #F3D084, #C9922A);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        input, textarea {
            background: #09090b !important;
            border: 1px solid #27272a !important;
            color: white !important;
        }
        input:focus, textarea:focus {
            border-color: #C9922A !important;
            outline: none;
        }
    </style>
    <title>Admin | Fabric Slider Control</title>
</head>
<body class="bg-black text-white">

    <div class="flex min-h-screen">
        <%- include('./partials/sidebar') %>

        <main class="flex-1 p-10">
            <header class="mb-10">
                <h1 class="text-4xl font-black italic uppercase tracking-tighter text-white">
                    Fabric <span class="gold-text">Authority</span>
                </h1>
                <p class="text-zinc-500 text-xs mt-1 uppercase tracking-widest font-bold">Manage your industrial hero section</p>
            </header>

            <div class="max-w-4xl bg-zinc-900/40 border border-zinc-800 p-8 rounded-[2.5rem] backdrop-blur-sm shadow-2xl mb-12">
                <form id="sliderForm" action="/admin/fabric-slider/update" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-4">
                            <div>
                                <label class="text-[10px] uppercase font-black text-[#C9922A] tracking-widest mb-2 block">Tagline</label>
                                <input type="text" name="tagline" value="<%= data.tagline || '' %>" placeholder="e.g. Industrial Heritage" class="w-full p-3 rounded-xl text-sm" required>
                            </div>
                            <div>
                                <label class="text-[10px] uppercase font-black text-zinc-500 tracking-widest mb-2 block">Title (White Part)</label>
                                <input type="text" name="titleMain" value="<%= data.titleMain || '' %>" placeholder="e.g. Vastra" class="w-full p-3 rounded-xl text-sm" required>
                            </div>
                            <div>
                                <label class="text-[10px] uppercase font-black text-[#C9922A] tracking-widest mb-2 block">Title (Gold Part)</label>
                                <input type="text" name="titleGold" value="<%= data.titleGold || '' %>" placeholder="e.g. Nagri" class="w-full p-3 rounded-xl text-sm" required>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <div>
                                <label class="text-[10px] uppercase font-black text-zinc-500 tracking-widest mb-2 block">Image URL</label>
                                <input type="text" name="imageURL" value="<%= data.imageURL || '' %>" placeholder="Unsplash Link" class="w-full p-3 rounded-xl text-sm" required>
                            </div>
                            <div>
                                <label class="text-[10px] uppercase font-black text-zinc-500 tracking-widest mb-2 block">Badge Text</label>
                                <input type="text" name="badgeText" value="<%= data.badgeText || '' %>" placeholder="Manchester of Rajasthan" class="w-full p-3 rounded-xl text-sm">
                            </div>
                            <div class="grid grid-cols-2 gap-2">
                                <div>
                                    <label class="text-[10px] uppercase font-black text-[#C9922A] tracking-widest mb-2 block">Stat 1 Value</label>
                                    <input type="text" name="stat1_val" value="<%= data.stats && data.stats[0] ? data.stats[0].value : '' %>" placeholder="1.2B" class="w-full p-3 rounded-xl text-sm">
                                </div>
                                <div>
                                    <label class="text-[10px] uppercase font-black text-zinc-500 tracking-widest mb-2 block">Stat 1 Label</label>
                                    <input type="text" name="stat1_lbl" value="<%= data.stats && data.stats[0] ? data.stats[0].label : '' %>" placeholder="Meters" class="w-full p-3 rounded-xl text-sm">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="text-[10px] uppercase font-black text-zinc-500 tracking-widest mb-2 block">Description</label>
                        <textarea name="description" rows="3" class="w-full p-4 rounded-2xl text-sm resize-none" placeholder="Bhilwara ki kahani..."><%= data.description || '' %></textarea>
                    </div>

                    <div class="flex justify-end gap-4 pt-4">
                        <button type="button" onclick="document.getElementById('sliderForm').reset();" class="border border-zinc-800 text-zinc-500 font-black uppercase text-[10px] tracking-[0.2em] px-8 py-4 rounded-xl hover:text-white hover:border-zinc-600 transition-all">
                            Clear Form
                        </button>

                        <button type="submit" class="bg-[#C9922A] text-black font-black uppercase text-[10px] tracking-[0.2em] px-10 py-4 rounded-xl hover:bg-white hover:scale-105 transition-all duration-300">
                            Update Live Hero
                        </button>
                    </div>
                </form>
            </div>

            <h2 class="text-xs font-black uppercase tracking-[0.5em] text-zinc-700 mb-6">Current Live Preview</h2>
            
            <% if(data && data.titleMain) { %>
                <div class="opacity-50 pointer-events-none scale-75 origin-top-left border border-zinc-800 rounded-[3rem] overflow-hidden">
                     <section class="relative pt-20 pb-16 px-10 bg-black">
                        <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
                            <div class="lg:col-span-7">
                                <span class="text-[8px] font-black text-[#C9922A] uppercase tracking-[0.6em] mb-2 block italic"><%= data.tagline %></span>
                                <h1 class="text-5xl font-black italic uppercase mb-4">
                                    <span class="block text-white"><%= data.titleMain %></span>
                                    <span class="gold-text block"><%= data.titleGold %></span>
                                </h1>
                            </div>
                            <div class="lg:col-span-5">
                                <img src="<%= data.imageURL %>" class="rounded-3xl h-40 w-full object-cover grayscale opacity-40">
                            </div>
                        </div>
                    </section>
                </div>
            <% } else { %>
                <p class="text-zinc-600 italic text-sm">No active slider found. Fill the form to create one.</p>
            <% } %>
        </main>
    </div>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('success')) {
            alert("Fabric Authority Updated!");
            // Agar redirect ke baad form khaali rakhna hai toh:
            // window.history.replaceState({}, document.title, "/admin/fabric-slider");
        }
    </script>
</body>
</html>