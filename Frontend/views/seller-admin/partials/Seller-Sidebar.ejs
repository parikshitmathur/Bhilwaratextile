<aside id="tx-sidebar" class="tx-sidebar">
    <div class="tx-brand">
        <div class="tx-logo">BT</div>
        <div class="tx-brand-info">
            <span class="tx-name">BHILWARA <b class="gold">TEXTILE</b></span>
            <span class="tx-status">Merchant Panel</span>
        </div>
    </div>

    <nav class="tx-nav">
        <a href="/tx-dashboard" class="tx-link <%= (typeof title !== 'undefined' && title == 'Dashboard') ? 'active' : '' %>">
            <i class="icon">📊</i> <span>Dashboard</span>
        </a>
        <a href="/seller/my-products" class="tx-link <%= (typeof title !== 'undefined' && title == 'My Inventory') ? 'active' : '' %>">
            <i class="icon">🧵</i> <span>My Fabrics</span>
        </a>
        <a href="/seller/add-product" class="tx-link <%= (typeof title !== 'undefined' && title == 'Add Product') ? 'active' : '' %>">
            <i class="icon">➕</i> <span>Add Product</span>
        </a>
        <a href="/tx-profile" class="tx-link">
            <i class="icon">👤</i> <span>Profile</span>
        </a>
    </nav>

    <div class="tx-footer">
        <a href="/tx-logout" class="tx-logout">
            <span>🔐 Secure Exit</span>
        </a>
    </div>
</aside>

<style>
    :root { --gold: #C9922A; --bg: #08090a; --sidebar-w: 280px; }
    .tx-sidebar {
        width: var(--sidebar-w);
        height: 100vh;
        position: fixed;
        left: 0; top: 0;
        background: #0d0f14;
        border-right: 1px solid rgba(255,255,255,0.05);
        display: flex; flex-direction: column;
        z-index: 1000;
    }
    .tx-brand { padding: 30px; display: flex; align-items: center; gap: 15px; }
    .tx-logo { 
        width: 45px; height: 45px; background: var(--gold); 
        color: black; display: flex; align-items: center; justify-content: center;
        border-radius: 12px; font-weight: 900; font-size: 20px;
    }
    .tx-brand-info { display: flex; flex-direction: column; }
    .tx-name { color: white; font-weight: 800; font-size: 15px; }
    .tx-status { color: #64748b; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; }
    .gold { color: var(--gold); }

    .tx-nav { flex: 1; padding: 20px; display: flex; flex-direction: column; gap: 8px; }
    .tx-link {
        display: flex; align-items: center; gap: 15px; padding: 14px 20px;
        color: #94a3b8; text-decoration: none; border-radius: 15px;
        font-weight: 600; font-size: 14px; transition: 0.3s;
    }
    .tx-link:hover { background: rgba(255,255,255,0.03); color: white; }
    .tx-link.active { background: rgba(201, 146, 42, 0.1); color: var(--gold); }
    
    .tx-footer { padding: 25px; border-top: 1px solid rgba(255,255,255,0.05); }
    .tx-logout {
        display: block; padding: 15px; background: rgba(239, 68, 68, 0.05);
        color: #ef4444; text-decoration: none; border-radius: 12px;
        text-align: center; font-weight: 800; font-size: 13px;
    }
</style>