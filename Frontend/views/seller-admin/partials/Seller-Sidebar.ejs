<!-- Mobile Header Bar (Sirf Mobile par dikhega) -->
<div class="ss-mobile-header md:hidden">
    <div class="ss-logo-small">BT</div>
    <button class="ss-mobile-toggle" onclick="toggleSidebar()">
        <span class="ss-burger"></span>
    </button>
</div>

<aside id="ss-sidebar-main" class="ss-sidebar">
    <!-- Close Button for Mobile -->
    <button class="ss-close-btn md:hidden" onclick="toggleSidebar()">&times;</button>

    <!-- Brand Branding -->
    <div class="ss-brand">
        <div class="ss-logo-glow"></div>
        <div class="ss-logo-box">BT</div>
        <div class="ss-brand-text">
            BHILWARA <span class="ss-gold-text">TEXTILE</span>
        </div>
    </div>

    <!-- User Profile Section -->
    <div class="ss-user-card">
        <div class="ss-avatar-wrapper">
            <div class="ss-avatar">
                <%= (typeof user !== 'undefined' && user.contactPerson) ? user.contactPerson.charAt(0).toUpperCase() : 'M' %>
            </div>
            <div class="ss-online-badge"></div>
        </div>
        <div class="ss-user-details">
            <h4 class="ss-user-name">
                <%= (typeof user !== 'undefined' && user.contactPerson) ? user.contactPerson : 'Elite Merchant' %>
            </h4>
            <div class="ss-badge">Verified Partner</div>
        </div>
    </div>

    <!-- Navigation Menu -->
    <nav class="ss-nav">
        <div class="ss-nav-label">Main Menu</div>
        <a href="/tx-dashboard" class="ss-link active">
            <i class="ss-icon">📊</i> <span>Dashboard</span>
        </a>
        <a href="/seller/my-products" class="ss-link">
            <i class="ss-icon">🧵</i> <span>My Fabrics</span>
        </a>
        <a href="/seller/orders" class="ss-link">
            <i class="ss-icon">🛍️</i> <span>Orders</span>
        </a>
        <a href="/seller/profile" class="ss-link">
            <i class="ss-icon">👤</i> <span>My Account</span>
        </a>
    </nav>

    <!-- Logout Footer -->
    <div class="ss-footer">
        <a href="/tx-logout" class="ss-logout-card">
            <div class="ss-logout-icon">🔐</div>
            <div class="ss-logout-text">
                <strong>Secure Exit</strong>
                <span>End active session</span>
            </div>
        </a>
    </div>
</aside>

<style>
    :root {
        --ss-gold: #C9922A;
        --ss-gold-light: #eec16d;
        --ss-bg: #08090a;
        --ss-card: rgba(255, 255, 255, 0.03);
        --ss-transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Sidebar Base */
    .ss-sidebar {
        width: 280px;
        background: var(--ss-bg);
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        display: flex;
        flex-direction: column;
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        z-index: 2000;
        transition: var(--ss-transition);
        padding: 20px 0;
    }

    /* Brand Section */
    .ss-brand {
        padding: 20px 30px 40px;
        display: flex;
        align-items: center;
        gap: 15px;
        position: relative;
    }
    .ss-logo-box {
        background: var(--ss-gold);
        color: #000;
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        border-radius: 12px;
        font-size: 20px;
        box-shadow: 0 0 20px rgba(201, 146, 42, 0.3);
    }
    .ss-brand-text {
        color: #fff;
        font-weight: 800;
        font-size: 16px;
        letter-spacing: 1px;
    }
    .ss-gold-text { color: var(--ss-gold); display: block; font-size: 11px; margin-top: 2px; }

    /* User Profile Card */
    .ss-user-card {
        margin: 0 20px 35px;
        padding: 15px;
        background: var(--ss-card);
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .ss-avatar-wrapper { position: relative; }
    .ss-avatar {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #1f2937, #111827);
        border: 2px solid var(--ss-gold);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        color: var(--ss-gold);
        font-size: 22px;
    }
    .ss-online-badge {
        width: 12px;
        height: 12px;
        background: #2ecc71;
        border: 2px solid var(--ss-bg);
        border-radius: 50%;
        position: absolute;
        bottom: -2px;
        right: -2px;
        box-shadow: 0 0 10px #2ecc71;
    }
    .ss-user-name { color: #fff; font-size: 14px; font-weight: 700; margin: 0; }
    .ss-badge { font-size: 9px; color: var(--ss-gold); font-weight: 800; text-transform: uppercase; margin-top: 4px; }

    /* Navigation */
    .ss-nav { flex: 1; padding: 0 20px; }
    .ss-nav-label {
        font-size: 10px;
        color: #4b5563;
        text-transform: uppercase;
        font-weight: 800;
        letter-spacing: 1.5px;
        margin-bottom: 15px;
        padding-left: 10px;
    }
    .ss-link {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px 18px;
        color: #9ca3af;
        text-decoration: none;
        border-radius: 16px;
        font-size: 14px;
        font-weight: 600;
        transition: var(--ss-transition);
        margin-bottom: 8px;
    }
    .ss-link:hover { color: #fff; background: rgba(255,255,255,0.03); }
    .ss-link.active {
        background: linear-gradient(90deg, rgba(201, 146, 42, 0.15), transparent);
        color: var(--ss-gold);
        border-left: 3px solid var(--ss-gold);
    }
    .ss-icon { font-size: 18px; filter: grayscale(1); }
    .ss-link.active .ss-icon { filter: grayscale(0); }

    /* Logout Section */
    .ss-footer { padding: 20px; }
    .ss-logout-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 15px;
        background: rgba(231, 76, 60, 0.05);
        border-radius: 20px;
        text-decoration: none;
        border: 1px solid rgba(231, 76, 60, 0.1);
        transition: var(--ss-transition);
    }
    .ss-logout-icon { font-size: 20px; }
    .ss-logout-text strong { display: block; color: #ef4444; font-size: 13px; }
    .ss-logout-text span { color: #7f8c8d; font-size: 10px; }
    .ss-logout-card:hover { background: #ef4444; transform: translateY(-3px); }
    .ss-logout-card:hover strong, .ss-logout-card:hover span { color: #fff; }

    /* Mobile UI Logic */
    .ss-mobile-header {
        position: fixed; top: 0; left: 0; width: 100%; height: 60px;
        background: var(--ss-bg); border-bottom: 1px solid rgba(255,255,255,0.05);
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 20px; z-index: 1000;
    }
    .ss-logo-small { background: var(--ss-gold); color: #000; padding: 5px 10px; border-radius: 8px; font-weight: 900; }
    .ss-mobile-toggle { background: transparent; border: none; cursor: pointer; }
    .ss-burger {
        display: block; width: 25px; height: 2px; background: var(--ss-gold);
        position: relative;
    }
    .ss-burger::before, .ss-burger::after {
        content: ''; position: absolute; width: 100%; height: 2px; background: var(--ss-gold); left: 0;
    }
    .ss-burger::before { top: -8px; } .ss-burger::after { top: 8px; }

    .ss-close-btn {
        position: absolute; top: 20px; right: 20px; font-size: 30px;
        color: #4b5563; background: transparent; border: none; cursor: pointer;
    }

    @media (max-width: 768px) {
        .ss-sidebar { transform: translateX(-100%); width: 100%; }
        .ss-sidebar.open { transform: translateX(0); }
    }
</style>

<script>
    function toggleSidebar() {
        document.getElementById('ss-sidebar-main').classList.toggle('open');
    }
</script>