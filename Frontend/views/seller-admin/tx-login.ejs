<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elite Merchant Login | Bhilwara Textile</title>
    <!-- Font for Premium Feel -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --tx-gold: #C9922A;
            --tx-gold-light: #eec16d;
            --tx-dark: #08090a;
            --tx-card-bg: #111827;
            --tx-input-bg: #0b0f19;
            --tx-text-muted: #94a3b8;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: radial-gradient(circle at top right, #1e293b, var(--tx-dark));
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        /* Glassmorphism Background Shapes */
        .bg-shape {
            position: absolute;
            width: 300px;
            height: 300px;
            background: var(--tx-gold);
            filter: blur(120px);
            opacity: 0.1;
            z-index: 0;
        }
        .shape-1 { top: -50px; left: -50px; }
        .shape-2 { bottom: -50px; right: -50px; }

        .tx-container {
            z-index: 10;
            width: 100%;
            display: flex;
            justify-content: center;
            padding: 20px;
        }

        .tx-card {
            background: rgba(17, 24, 39, 0.8);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 50px 40px;
            border-radius: 30px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            text-align: center;
        }

        .tx-logo {
            font-size: 28px;
            font-weight: 800;
            color: var(--tx-gold);
            letter-spacing: 2px;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .tx-subtitle {
            color: var(--tx-text-muted);
            font-size: 13px;
            margin-bottom: 35px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .tx-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .tx-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            color: var(--tx-text-muted);
            margin-bottom: 8px;
            margin-left: 5px;
            text-transform: uppercase;
        }

        .tx-input {
            width: 100%;
            padding: 14px 18px;
            background: var(--tx-input-bg);
            border: 1px solid #1f2937;
            border-radius: 12px;
            color: white;
            font-size: 14px;
            box-sizing: border-box;
            outline: none;
            transition: all 0.3s ease;
        }

        .tx-input:focus {
            border-color: var(--tx-gold);
            box-shadow: 0 0 0 4px rgba(201, 146, 42, 0.1);
        }

        .tx-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--tx-gold), #A8761D);
            border: none;
            border-radius: 15px;
            color: #000;
            font-weight: 800;
            font-size: 14px;
            cursor: pointer;
            margin-top: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
        }

        .tx-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(201, 146, 42, 0.3);
            background: var(--tx-gold-light);
        }

        .tx-footer {
            margin-top: 30px;
            padding-top: 25px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .tx-link-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
        }

        .tx-link {
            color: var(--tx-gold);
            text-decoration: none;
            font-weight: 600;
            transition: 0.2s;
        }

        .tx-link:hover {
            color: white;
        }

        .signup-text {
            color: var(--tx-text-muted);
            margin-top: 20px;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <div class="bg-shape shape-1"></div>
    <div class="bg-shape shape-2"></div>

    <div class="tx-container">
        <div class="tx-card">
            <div class="tx-logo">BT MERCHANT</div>
            <div class="tx-subtitle">Elite Administration Portal</div>

           <form action="/api/seller/login" method="POST">
                <div class="tx-group">
                    <label class="tx-label">Email Address</label>
                    <input name="email" type="email" class="tx-input" placeholder="Enter your business email" required>
                </div>

                <div class="tx-group">
                    <label class="tx-label">Secret Password</label>
                    <input name="password" type="password" class="tx-input" placeholder="••••••••" required>
                </div>

                <button class="tx-btn">Enter Dashboard</button>
            </form>

         <div class="tx-footer">
    <div class="tx-link-row">
        <a href="/tx-forgot" class="tx-link">Forgot Password?</a>
  
    </div>
    
    <div class="signup-text">
        New merchant? <a href="/tx-register" class="tx-link">Create Elite Account</a>
    </div>
</div>
        </div>
    </div>

</body>
</html>