<%- include('./partials/Seller-Sidebar') %>

<!-- Tailwind & FontAwesome -->
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    body { background-color: #09090b; font-family: 'Inter', sans-serif; }
    .glass-card { background: #111113; border: 1px solid #1f1f22; }
    .inv-table-row { border-bottom: 1px solid rgba(255,255,255,0.03); transition: 0.2s; }
    .inv-table-row:hover { background: rgba(201, 146, 42, 0.02); }
    .custom-scrollbar::-webkit-scrollbar { width: 3px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #27272a; border-radius: 10px; }
</style>

<main class="min-h-screen text-zinc-400 lg:ml-[260px]">
    <div class="p-4 md:p-6 max-w-full mx-auto">
        
        <!-- ⚡ Compact Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-6">
            <div>
                <h1 class="text-xl font-black text-white uppercase italic tracking-tighter">
                    Stock <span class="text-[#C9922A]">Inventory</span>
                </h1>
                <p class="text-[9px] font-bold text-zinc-600 uppercase tracking-[0.2em]">Warehouse Management</p>
            </div>
            <a href="/seller/add-product" class="bg-[#C9922A] text-black px-5 py-2 rounded-lg font-black text-[10px] uppercase tracking-widest hover:bg-white transition-all flex items-center gap-2">
                <i class="fa-solid fa-plus text-xs"></i> New Entry
            </a>
        </div>

        <!-- 🔍 Tight Controls -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-3 mb-5">
            <div class="md:col-span-8 relative">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-zinc-700 text-xs"></i>
                <input type="text" id="invSearch" onkeyup="filterProducts()" placeholder="Search fabric..." 
                    class="w-full bg-[#111113] border border-zinc-800 rounded-lg py-2.5 pl-10 pr-4 text-xs text-white focus:border-[#C9922A] outline-none transition-all">
            </div>
            <div class="md:col-span-4">
                <select id="catFilter" onchange="filterProducts()" 
                    class="w-full bg-[#111113] border border-zinc-800 rounded-lg py-2.5 px-4 text-xs text-zinc-400 outline-none cursor-pointer">
                    <option value="all">All Clusters</option>
                    <% if(categories && categories.length > 0) { %>
                        <% categories.forEach(function(cat) { %>
                            <option value="<%= cat.name %>"><%= cat.name %></option>
                        <% }); %>
                    <% } %>
                </select>
            </div>
        </div>

        <!-- 📊 Compact Inventory Table -->
        <div class="glass-card rounded-xl overflow-hidden shadow-2xl">
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left min-w-[800px]">
                    <thead>
                        <tr class="bg-black/40 text-zinc-600 text-[9px] font-black uppercase tracking-widest border-b border-zinc-800">
                            <th class="px-5 py-3">Visual</th>
                            <th class="px-5 py-3">Signature / Type</th>
                            <th class="px-5 py-3">Segment</th>
                            <th class="px-5 py-3">Log (Mtrs)</th>
                            <th class="px-5 py-3">Rate (₹)</th>
                            <th class="px-5 py-3 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="invBody">
                        <% if(products && products.length > 0) { %>
                            <% products.forEach(function(p) { %>
                                <tr class="inv-table-row group" data-category="<%= p.category %>">
                                    <td class="px-5 py-3">
                                        <div class="w-10 h-10 rounded-lg border border-zinc-800 overflow-hidden bg-black flex-shrink-0">
                                            <img src="<%= p.fabricImage || '/images/no-fabric.png' %>" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all">
                                        </div>
                                    </td>
                                    <td class="px-5 py-3">
                                        <div class="text-[11px] font-black text-white uppercase truncate inv-name"><%= p.productName %></div>
                                        <div class="text-[8px] font-bold text-zinc-600 mt-0.5"><%= p.fabricType %></div>
                                    </td>
                                    <td class="px-5 py-3">
                                        <span class="text-[8px] font-black text-[#C9922A] uppercase tracking-tighter">
                                            <%= p.category %>
                                        </span>
                                    </td>
                                    <td class="px-5 py-3">
                                        <div class="text-[11px] font-black <%= p.bulkStock < 500 ? 'text-red-500' : 'text-zinc-300' %>">
                                            <%= p.bulkStock %> <small class="text-[8px] text-zinc-600 uppercase ml-1">Mtrs</small>
                                        </div>
                                    </td>
                                    <td class="px-5 py-3 text-[11px] font-black text-white">
                                        ₹<%= p.pricePerUnit %>
                                    </td>
                                    <td class="px-5 py-3 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button onclick="openEditModal('<%= p._id %>', '<%= p.productName %>', '<%= p.bulkStock %>', '<%= p.pricePerUnit %>', '<%= p.category %>')" 
                                                class="w-7 h-7 rounded bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 hover:text-[#C9922A] transition-all">
                                                <i class="fa-solid fa-pen text-[10px]"></i>
                                            </button>
                                            <button onclick="deleteProduct('<%= p._id %>')" 
                                                class="w-7 h-7 rounded bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 hover:text-red-500 transition-all">
                                                <i class="fa-solid fa-trash-can text-[10px]"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="py-12 text-center text-[10px] font-bold text-zinc-700 uppercase tracking-widest">
                                    <i class="fa-solid fa-box-open mb-2 text-xl block"></i> Warehouse Empty
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<!-- 📦 Compact Edit Modal -->
<div id="editModal" class="fixed inset-0 hidden bg-black/90 backdrop-blur-sm z-[1001] flex items-center justify-center p-4">
    <div class="glass-card p-6 rounded-2xl w-full max-w-md shadow-3xl">
        <div class="flex justify-between items-center mb-5">
            <h2 class="text-sm font-black italic text-white uppercase tracking-widest">Update <span class="text-[#C9922A]">Log</span></h2>
            <button onclick="closeEditModal()" class="text-zinc-600 hover:text-white"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="editForm" class="space-y-4">
            <input type="hidden" id="editId">
            
            <div>
                <label class="text-[9px] font-black text-zinc-500 uppercase tracking-widest block mb-1">Product Signature</label>
                <input type="text" id="editName" required class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-xs text-white outline-none focus:border-[#C9922A]">
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-[9px] font-black text-zinc-500 uppercase tracking-widest block mb-1">Stock (Mtrs)</label>
                    <input type="number" id="editStock" required class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-xs text-white outline-none focus:border-[#C9922A]">
                </div>
                <div>
                    <label class="text-[9px] font-black text-zinc-500 uppercase tracking-widest block mb-1">Price (₹)</label>
                    <input type="number" id="editPrice" required class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-xs text-white outline-none focus:border-[#C9922A]">
                </div>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="submit" class="flex-1 bg-[#C9922A] text-black font-black py-3 rounded-lg text-[10px] uppercase tracking-widest hover:bg-white transition-all">
                    Sync Changes
                </button>
                <button type="button" onclick="closeEditModal()" class="px-6 bg-zinc-900 text-zinc-500 font-bold py-3 rounded-lg text-[10px]">
                    Abort
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // --- Logic is exact same as before, just kept compact ---
    function filterProducts() {
        const search = document.getElementById('invSearch').value.toLowerCase();
        const category = document.getElementById('catFilter').value;
        const rows = document.querySelectorAll('.inv-table-row');
        rows.forEach(row => {
            const name = row.querySelector('.inv-name').innerText.toLowerCase();
            const rowCat = row.getAttribute('data-category');
            row.style.display = (name.includes(search) && (category === 'all' || rowCat === category)) ? '' : 'none';
        });
    }

    function openEditModal(id, name, stock, price, category) {
        document.getElementById('editId').value = id;
        document.getElementById('editName').value = name;
        document.getElementById('editStock').value = stock;
        document.getElementById('editPrice').value = price;
        document.getElementById('editModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeEditModal() {
        document.getElementById('editModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    document.getElementById('editForm').onsubmit = async (e) => {
        e.preventDefault();
        const id = document.getElementById('editId').value;
        const updateData = {
            productName: document.getElementById('editName').value,
            bulkStock: document.getElementById('editStock').value,
            pricePerUnit: document.getElementById('editPrice').value
        };
        try {
            const res = await fetch(`/api/seller/update-product/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(updateData)
            });
            if(res.ok) location.reload();
        } catch (err) { alert("Error updating!"); }
    }

    async function deleteProduct(id) {
        if(confirm("Confirm deletion?")) {
            const res = await fetch('/api/seller/delete-product/' + id, { method: 'POST' });
            if(res.ok) location.reload();
        }
    }
</script>