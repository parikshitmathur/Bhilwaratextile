<%- include('./partials/Seller-Sidebar') %>

<!-- Tailwind & FontAwesome for Premium Icons -->
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<main class="min-h-screen bg-[#08090a] text-white lg:ml-[280px] transition-all duration-300">
    <div class="p-4 md:p-8 lg:p-10 max-w-7xl mx-auto">
        
        <!-- ✨ Header Section -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10">
            <div>
                <h1 class="text-3xl md:text-4xl font-black tracking-tight italic">
                    MY <span class="text-[#C9922A]">INVENTORY</span>
                </h1>
                <p class="text-gray-500 text-xs md:text-sm font-bold uppercase tracking-[0.2em] mt-2">
                    Manage your wholesale fabric listings
                </p>
            </div>
            <a href="/seller/add-product" class="w-full md:w-auto bg-[#C9922A] text-black px-8 py-4 rounded-2xl font-black text-sm hover:scale-105 hover:shadow-[0_0_20px_rgba(201,146,42,0.3)] transition-all flex items-center justify-center gap-2">
                <i class="fa-solid fa-plus text-lg"></i> LIST NEW FABRIC
            </a>
        </div>

        <!-- 🔍 Controls Section -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 mb-8">
            <div class="lg:col-span-8 relative group">
                <i class="fa-solid fa-magnifying-glass absolute left-5 top-1/2 -translate-y-1/2 text-gray-500 group-focus-within:text-[#C9922A] transition-colors"></i>
                <input type="text" id="invSearch" onkeyup="filterProducts()" placeholder="Search by fabric name..." 
                    class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-14 pr-6 focus:outline-none focus:border-[#C9922A] focus:ring-1 focus:ring-[#C9922A] transition-all placeholder:text-gray-600">
            </div>
            <div class="lg:col-span-4">
                <select id="catFilter" onchange="filterProducts()" 
                    class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-6 focus:outline-none focus:border-[#C9922A] appearance-none cursor-pointer text-gray-300">
                    <option value="all" class="bg-[#0b111a]">All Categories</option>
                    <% if(categories && categories.length > 0) { %>
                        <% categories.forEach(function(cat) { %>
                            <option value="<%= cat.name %>" class="bg-[#0b111a]"><%= cat.name %></option>
                        <% }); %>
                    <% } %>
                </select>
            </div>
        </div>

        <!-- 📊 Inventory Table / Grid -->
        <div class="bg-white/5 border border-white/10 rounded-[2.5rem] overflow-hidden backdrop-blur-xl shadow-2xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left min-w-[900px] lg:min-w-full">
                    <thead class="bg-white/5 border-b border-white/10">
                        <tr class="text-[#64748b] text-[11px] font-black uppercase tracking-widest">
                            <th class="p-6">Fabric Preview</th>
                            <th class="p-6">Details</th>
                            <th class="p-6">Category</th>
                            <th class="p-6">Live Stock</th>
                            <th class="p-6">Wholesale Rate</th>
                            <th class="p-6 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="invBody" class="divide-y divide-white/5">
                        <% if(products && products.length > 0) { %>
                            <% products.forEach(function(p) { %>
                                <tr class="inv-row hover:bg-white/[0.02] transition-all group" data-category="<%= p.category %>">
                                    <td class="p-6">
                                        <div class="w-20 h-20 rounded-2xl border border-white/10 overflow-hidden shadow-lg group-hover:border-[#C9922A]/50 transition-all">
                                            <img src="<%= p.fabricImage || '/images/no-fabric.png' %>" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500">
                                        </div>
                                    </td>
                                    <td class="p-6">
                                        <div class="text-lg font-black text-white leading-tight"><%= p.productName %></div>
                                        <div class="text-[10px] font-bold text-gray-500 uppercase tracking-tighter mt-1"><%= p.fabricType %></div>
                                    </td>
                                    <td class="p-6">
                                        <span class="px-4 py-1.5 bg-[#C9922A]/10 text-[#C9922A] border border-[#C9922A]/20 rounded-full text-[10px] font-black uppercase tracking-widest">
                                            <%= p.category %>
                                        </span>
                                    </td>
                                    <td class="p-6">
                                        <div class="text-xl font-black <%= p.bulkStock < 500 ? 'text-red-500' : 'text-green-500' %>">
                                            <%= p.bulkStock %> <small class="text-[10px] text-gray-500">MTRS</small>
                                        </div>
                                        <div class="text-[10px] font-bold text-gray-600 uppercase mt-1">Available Ready</div>
                                    </td>
                                    <td class="p-6">
                                        <div class="text-xl font-black text-white">₹<%= p.pricePerUnit %></div>
                                        <div class="text-[10px] font-bold text-gray-600 uppercase mt-1">Per Meter</div>
                                    </td>
                                    <td class="p-6 text-right">
                                        <div class="flex justify-end gap-3">
                                            <button onclick="openEditModal('<%= p._id %>', '<%= p.productName %>', '<%= p.bulkStock %>', '<%= p.pricePerUnit %>', '<%= p.category %>')" 
                                                class="w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[#C9922A] hover:text-black transition-all shadow-xl">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </button>
                                            <button onclick="deleteProduct('<%= p._id %>')" 
                                                class="w-11 h-11 rounded-xl bg-red-500/10 border border-red-500/20 text-red-500 flex items-center justify-center hover:bg-red-500 hover:text-white transition-all shadow-xl">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="p-20 text-center">
                                    <div class="opacity-20 mb-4"><i class="fa-solid fa-box-open text-6xl text-gray-500"></i></div>
                                    <p class="text-gray-500 font-bold uppercase tracking-widest text-sm">No fabrics listed in your warehouse</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<!-- 📦 ELITE EDIT MODAL -->
<div id="editModal" class="fixed inset-0 hidden bg-black/95 backdrop-blur-md z-[1001] flex items-center justify-center p-4">
    <div class="bg-[#0b111a] border border-white/10 p-6 md:p-10 rounded-[2.5rem] w-full max-w-2xl shadow-3xl transform transition-all">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-3xl font-black italic">EDIT <span class="text-[#C9922A]">FABRIC</span></h2>
            <button onclick="closeEditModal()" class="text-gray-500 hover:text-white text-2xl"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="editForm" class="space-y-6">
            <input type="hidden" id="editId" name="id">
            
            <div class="space-y-2">
                <label class="text-[11px] font-black text-gray-500 uppercase tracking-widest ml-1">Product Name / Title</label>
                <input type="text" id="editName" name="productName" required
                    class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 text-white focus:outline-none focus:border-[#C9922A] transition-all">
            </div>

            <div class="space-y-2">
                <label class="text-[11px] font-black text-gray-500 uppercase tracking-widest ml-1">Update Category</label>
                <select id="editCategory" name="category" 
                    class="w-full bg-[#0b111a] border border-white/10 rounded-2xl p-4 text-white focus:outline-none focus:border-[#C9922A] appearance-none cursor-pointer">
                    <% categories.forEach(function(cat) { %>
                        <option value="<%= cat.name %>"><%= cat.name %></option>
                    <% }); %>
                </select>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="text-[11px] font-black text-gray-500 uppercase tracking-widest ml-1">Stock Level (Mtrs)</label>
                    <input type="number" id="editStock" name="bulkStock" required
                        class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 text-white focus:outline-none focus:border-[#C9922A] transition-all">
                </div>
                <div class="space-y-2">
                    <label class="text-[11px] font-black text-gray-500 uppercase tracking-widest ml-1">Price Per Meter (₹)</label>
                    <input type="number" id="editPrice" name="pricePerUnit" required
                        class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 text-white focus:outline-none focus:border-[#C9922A] transition-all">
                </div>
            </div>

            <div class="flex flex-col md:flex-row gap-4 pt-6">
                <button type="submit" class="flex-1 bg-[#C9922A] text-black font-black p-5 rounded-2xl hover:scale-105 transition-all uppercase tracking-widest text-sm">
                    🚀 SAVE UPDATED DETAILS
                </button>
                <button type="button" onclick="closeEditModal()" class="px-10 bg-white/5 text-gray-400 font-bold p-5 rounded-2xl hover:bg-white/10 transition-all text-sm">
                    CANCEL
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // --- SEARCH & FILTER ---
    function filterProducts() {
        const search = document.getElementById('invSearch').value.toLowerCase();
        const category = document.getElementById('catFilter').value;
        const rows = document.querySelectorAll('.inv-row');

        rows.forEach(row => {
            const name = row.querySelector('.inv-name').innerText.toLowerCase();
            const rowCat = row.getAttribute('data-category');
            const matchesSearch = name.includes(search);
            const matchesCat = (category === 'all' || rowCat === category);
            row.style.display = (matchesSearch && matchesCat) ? '' : 'none';
        });
    }

    // --- MODAL LOGIC ---
    function openEditModal(id, name, stock, price, category) {
        document.getElementById('editId').value = id;
        document.getElementById('editName').value = name;
        document.getElementById('editStock').value = stock;
        document.getElementById('editPrice').value = price;
        document.getElementById('editCategory').value = category;
        
        const modal = document.getElementById('editModal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Stop body scroll
    }

    function closeEditModal() {
        const modal = document.getElementById('editModal');
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    // --- AJAX UPDATE ---
    document.getElementById('editForm').onsubmit = async (e) => {
        e.preventDefault();
        const id = document.getElementById('editId').value;
        const btn = e.submitter;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> UPDATING...';

        const updateData = {
            productName: document.getElementById('editName').value,
            bulkStock: document.getElementById('editStock').value,
            pricePerUnit: document.getElementById('editPrice').value,
            category: document.getElementById('editCategory').value
        };

        try {
            const res = await fetch(`/api/seller/update-product/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(updateData)
            });

            if(res.ok) {
                location.reload();
            } else {
                alert("Bhai, update nahi ho paya!");
                btn.innerText = '🚀 SAVE UPDATED DETAILS';
            }
        } catch (err) {
            console.error(err);
            alert("Network issue!");
            btn.innerText = '🚀 SAVE UPDATED DETAILS';
        }
    }

    // --- DELETE ---
    async function deleteProduct(id) {
        if(confirm("Bhai, kya aap sach mein ye fabric delete karna chahte hain?")) {
            try {
                const res = await fetch('/api/seller/delete-product/' + id, { method: 'POST' });
                if(res.ok) location.reload();
            } catch (e) { alert("Error deleting!"); }
        }
    }
</script>