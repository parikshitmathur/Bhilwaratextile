<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join Elite Merchants | Bhilwara Textile</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --tx-gold: #C9922A;
            --tx-dark: #08090a;
            --tx-card-bg: rgba(17, 24, 39, 0.85);
            --tx-input-bg: #0b0f19;
            --tx-text-muted: #94a3b8;
        }

        body {
            margin: 0;
            padding: 40px 20px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: radial-gradient(circle at bottom left, #1e293b, var(--tx-dark));
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
        }

        /* Abstract Glows */
        .bg-glow {
            position: absolute;
            width: 500px;
            height: 500px;
            background: var(--tx-gold);
            filter: blur(150px);
            opacity: 0.08;
            z-index: 0;
            border-radius: 50%;
        }
        .glow-1 { top: -150px; right: -100px; }
        .glow-2 { bottom: -150px; left: -100px; }

        /* Main Split Layout Container */
        .tx-page-wrapper {
            display: flex;
            align-items: center;
            justify-content: space-between;
            max-width: 1200px;
            width: 100%;
            gap: 60px;
            z-index: 10;
            position: relative;
        }

        /* =========================================
           LEFT SIDE: INFO & BENEFITS (NEW SECTION)
        ========================================== */
        .tx-info-section {
            flex: 1;
            color: white;
            padding-right: 20px;
        }

        .tx-info-title {
            font-size: 38px;
            font-weight: 900;
            margin: 0 0 10px 0;
            line-height: 1.2;
        }

        .tx-info-subtitle {
            color: var(--tx-text-muted);
            font-size: 16px;
            margin-bottom: 40px;
            line-height: 1.6;
        }

        /* Timeline Steps CSS */
        .tx-steps-container {
            position: relative;
            padding-left: 30px;
            border-left: 2px dashed rgba(201, 146, 42, 0.3);
        }

        .tx-step-item {
            position: relative;
            margin-bottom: 40px;
        }

        .tx-step-item:last-child {
            margin-bottom: 0;
        }

        .tx-step-icon {
            position: absolute;
            left: -48px; /* Centers icon on the dashed line */
            top: 0;
            width: 36px;
            height: 36px;
            background: var(--tx-dark);
            border: 2px solid var(--tx-gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--tx-gold);
            font-size: 14px;
            box-shadow: 0 0 15px rgba(201, 146, 42, 0.2);
        }

        .tx-step-content {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 20px;
            border-radius: 16px;
            transition: 0.3s;
        }

        .tx-step-content:hover {
            border-color: var(--tx-gold);
            background: rgba(201, 146, 42, 0.05);
            transform: translateX(10px);
        }

        .tx-step-title {
            font-size: 18px;
            font-weight: 800;
            color: #fff;
            margin: 0 0 10px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .tx-step-badge {
            font-size: 10px;
            background: var(--tx-gold);
            color: #000;
            padding: 2px 8px;
            border-radius: 20px;
            text-transform: uppercase;
            font-weight: 800;
        }

        .tx-step-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .tx-step-list li {
            color: var(--tx-text-muted);
            font-size: 14px;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .tx-step-list li i { color: #22c55e; font-size: 12px; }

        /* =========================================
           RIGHT SIDE: REGISTRATION FORM (YOUR UI)
        ========================================== */
        .tx-form-section {
            width: 100%;
            max-width: 420px;
        }

        .tx-card {
            background: var(--tx-card-bg);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 45px 40px;
            border-radius: 35px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
            text-align: center;
        }

        .tx-logo {
            font-size: 26px;
            font-weight: 800;
            color: var(--tx-gold);
            letter-spacing: 2px;
            margin: 0;
            text-transform: uppercase;
        }

        .tx-subtitle {
            color: var(--tx-text-muted);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-top: 8px;
            margin-bottom: 35px;
        }

        .tx-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .tx-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            color: var(--tx-text-muted);
            margin-bottom: 8px;
            margin-left: 5px;
            text-transform: uppercase;
        }

        .tx-input {
            width: 100%;
            padding: 14px 18px;
            background: var(--tx-input-bg);
            border: 1px solid #1f2937;
            border-radius: 15px;
            color: white;
            font-size: 14px;
            box-sizing: border-box;
            outline: none;
            transition: 0.3s;
        }

        .tx-input:focus {
            border-color: var(--tx-gold);
            box-shadow: 0 0 0 4px rgba(201, 146, 42, 0.1);
        }

        .tx-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--tx-gold), #A8761D);
            border: none;
            border-radius: 15px;
            color: #000;
            font-weight: 800;
            font-size: 14px;
            cursor: pointer;
            margin-top: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.4s;
        }

        .tx-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(201, 146, 42, 0.25);
        }

        .tx-footer {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .tx-link {
            color: var(--tx-gold);
            text-decoration: none;
            font-weight: 700;
        }

        .tx-footer p {
            color: var(--tx-text-muted);
            font-size: 14px;
            margin: 0;
        }

        /* Mobile Responsive */
        @media (max-width: 900px) {
            .tx-page-wrapper {
                flex-direction: column;
            }
            .tx-info-section {
                padding-right: 0;
                margin-bottom: 40px;
                text-align: center;
            }
            .tx-steps-container {
                border-left: none;
                padding-left: 0;
                display: flex;
                flex-direction: column;
                gap: 20px;
            }
            .tx-step-icon {
                display: none; /* Hide icons on mobile for cleaner look */
            }
            .tx-step-item {
                margin-bottom: 0;
            }
            .tx-step-content:hover {
                transform: translateY(-5px); /* Upward hover on mobile */
            }
            .tx-step-list {
                text-align: left;
            }
        }
    </style>
</head>
<body>

    <div class="bg-glow glow-1"></div>
    <div class="bg-glow glow-2"></div>

    <div class="tx-page-wrapper">
        
        <!-- LEFT SIDE: HOW TO SELL / BENEFITS -->
        <div class="tx-info-section">
            <h1 class="tx-info-title">How To Sell On <span style="color: var(--tx-gold);">Bhilwara Textile?</span></h1>
            <p class="tx-info-subtitle">Enhance your textile business. Promote your brand and drive wholesale traffic directly to your WhatsApp from thousands of active buyers.</p>

            <div class="tx-steps-container">
                
                <!-- Step 1 -->
                <div class="tx-step-item">
                    <div class="tx-step-icon"><i class="fa-solid fa-1"></i></div>
                    <div class="tx-step-content">
                        <h3 class="tx-step-title">Free Business Registration <span class="tx-step-badge">Quick</span></h3>
                        <ul class="tx-step-list">
                            <li><i class="fa-solid fa-check"></i> Enter your Name</li>
                            <li><i class="fa-solid fa-check"></i> Valid Email Address</li>
                            <li><i class="fa-solid fa-check"></i> Secure Password</li>
                        </ul>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="tx-step-item">
                    <div class="tx-step-icon"><i class="fa-solid fa-2"></i></div>
                    <div class="tx-step-content">
                        <h3 class="tx-step-title">Setup Elite Profile & Inventory</h3>
                        <ul class="tx-step-list">
                            <li><i class="fa-solid fa-check"></i> Add Company Details & Address</li>
                            <li><i class="fa-solid fa-check"></i> Upload your premium Fabric Catalog</li>
                            <li><i class="fa-solid fa-check"></i> Set Pricing & Minimum Order Quantity</li>
                        </ul>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="tx-step-item">
                    <div class="tx-step-icon"><i class="fa-solid fa-3"></i></div>
                    <div class="tx-step-content">
                        <h3 class="tx-step-title">Get Direct Buyer Signals <span class="tx-step-badge" style="background:#22c55e; color:white;">Profits</span></h3>
                        <ul class="tx-step-list">
                            <li><i class="fa-solid fa-check"></i> Receive requirements via Elite Dashboard</li>
                            <li><i class="fa-solid fa-check"></i> Connect directly on Call or WhatsApp</li>
                            <li><i class="fa-solid fa-check"></i> Close deals and grow your network</li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>

        <!-- RIGHT SIDE: THE REGISTRATION FORM -->
        <div class="tx-form-section">
            <div class="tx-card">
                <h2 class="tx-logo">REGISTER SELLER</h2>
                <p class="tx-subtitle">Start your elite business journey</p>

                <form action="/api/seller-admin/register" method="POST">
                    <div class="tx-group">
                        <label class="tx-label">Full Name</label>
                        <input name="name" class="tx-input" placeholder="Enter your full name" required>
                    </div>

                    <div class="tx-group">
                        <label class="tx-label">Email Address</label>
                        <input name="email" type="email" class="tx-input" placeholder="name@company.com" required>
                    </div>

                    <div class="tx-group">
                        <label class="tx-label">Password</label>
                        <input name="password" type="password" class="tx-input" placeholder="••••••••" required>
                    </div>

                    <button class="tx-btn">Create Elite Account</button>
                </form>

                <div class="tx-footer">
                    <p>Already have an account? <a href="/tx-login" class="tx-link">Login here</a></p>
                </div>
            </div>
        </div>

    </div>

</body>
</html>