<%- include('./partials/Seller-Sidebar') %>

<style>
    body { background-color: #050507; margin: 0; font-family: 'Inter', sans-serif; }
    
    .tx-main-wrapper { 
        margin-left: 280px; 
        min-height: 100vh;
        padding: 40px;
        background: radial-gradient(circle at top right, #111, #050507);
    }

    .glass-card {
        background: rgba(17, 17, 19, 0.7);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: 24px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .glass-card:hover {
        border-color: #C9922A;
        transform: translateY(-5px);
        background: rgba(20, 20, 25, 0.9);
    }

    .gold-gradient-text {
        background: linear-gradient(to right, #C9922A, #F3D084);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    @media (max-width: 768px) {
        .tx-main-wrapper { margin-left: 0; padding: 80px 20px; }
    }
</style>

<main class="tx-main-wrapper">
    
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px;">
        <div>
            <h1 style="color: white; font-size: 32px; margin: 0; font-weight: 900; text-transform: uppercase; font-style: italic;">
                Ram Ram, <span class="gold-gradient-text"><%= user.companyName || user.name %></span>
            </h1>
            <div style="margin-top: 12px; display: flex; gap: 12px; align-items: center;">
                <% if (user.status === 'Approved') { %>
                    <span class="status-badge" style="background: rgba(34, 197, 94, 0.1); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2);">
                        ● Verified Authority
                    </span>
                <% } else { %>
                    <span class="status-badge" style="background: rgba(249, 115, 22, 0.1); color: #f97316; border: 1px solid rgba(249, 115, 22, 0.2);">
                        ● Pending Sync
                    </span>
                <% } %>
                <span style="color: #52525b; font-size: 9px; font-weight: 800; text-transform: uppercase;">Node ID: <%= user._id.toString().slice(-6).toUpperCase() %></span>
            </div>
        </div>
        
        <button onclick="location.href='/seller/add-product'" style="background: #C9922A; color: black; border: none; padding: 14px 28px; border-radius: 14px; font-weight: 900; cursor: pointer; text-transform: uppercase; font-size: 10px; letter-spacing: 1px; box-shadow: 0 10px 20px rgba(201, 146, 42, 0.2);">
            + Dispatch New Fabric
        </button>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-bottom: 40px;">
        
        <div class="glass-card" onclick="location.href='/seller/my-products'">
            <div style="font-size: 24px; margin-bottom: 15px;">📦</div>
            <p style="color: #71717a; font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; margin: 0;">Total Inventory</p>
            <h2 style="color: white; font-size: 38px; margin: 10px 0; font-weight: 900; font-style: italic;"><%= stats.totalProducts %></h2>
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="color: #C9922A; font-size: 9px; font-weight: 800; text-transform: uppercase;">Manage Fabrics</span>
                <i class="fa-solid fa-arrow-right-long" style="color: #C9922A; font-size: 10px;"></i>
            </div>
        </div>

        <!-- Yahan Click link update kiya hai /tx-inquiries par -->
        <div class="glass-card" onclick="location.href='/tx-inquiries'" style="border-left: 4px solid #C9922A;">
            <div style="font-size: 24px; margin-bottom: 15px;">📡</div>
            <p style="color: #71717a; font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; margin: 0;">Active Signals</p>
            <h2 style="color: white; font-size: 38px; margin: 10px 0; font-weight: 900; font-style: italic;"><%= stats.leadsCount %></h2>
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="color: #22c55e; font-size: 9px; font-weight: 800; text-transform: uppercase;">View Potential Leads</span>
                <div style="width: 6px; height: 6px; background: #22c55e; border-radius: 50%; animate: pulse 2s infinite;"></div>
            </div>
        </div>

        <div class="glass-card" onclick="location.href='/tx-profile'">
            <div style="font-size: 24px; margin-bottom: 15px;">🏆</div>
            <p style="color: #71717a; font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; margin: 0;">Authority Grade</p>
            <h2 style="color: white; font-size: 38px; margin: 10px 0; font-weight: 900; font-style: italic;">ELITE</h2>
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="color: #3b82f6; font-size: 9px; font-weight: 800; text-transform: uppercase;">Merchant Profile</span>
                <i class="fa-solid fa-user-gear" style="color: #3b82f6; font-size: 10px;"></i>
            </div>
        </div>

    </div>

    <div class="glass-card" style="padding: 0; overflow: hidden; cursor: default;">
        <div style="padding: 24px; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.02);">
            <h3 style="margin: 0; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; color: white; font-style: italic;">Live Signal Intercepts</h3>
            <span style="font-size: 8px; color: #52525b; font-weight: 900; text-transform: uppercase;">Real-Time Feed</span>
        </div>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead style="background: rgba(0,0,0,0.2);">
                    <tr>
                        <th style="padding: 18px 24px; font-size: 9px; color: #C9922A; text-transform: uppercase; letter-spacing: 2px;">Origin</th>
                        <th style="padding: 18px 24px; font-size: 9px; color: #C9922A; text-transform: uppercase; letter-spacing: 2px;">Requirement Stream</th>
                        <th style="padding: 18px 24px; font-size: 9px; color: #C9922A; text-transform: uppercase; letter-spacing: 2px; text-align: right;">Timestamp</th>
                    </tr>
                </thead>
                <tbody style="color: #d4d4d8;">
                    <% if(recentLeads && recentLeads.length > 0) { %>
                        <% recentLeads.forEach(lead => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03); transition: 0.3s;" onmouseover="this.style.background='rgba(201,146,42,0.02)'" onmouseout="this.style.background='transparent'">
                            
                            <!-- Buyer Name & Phone -->
                            <td style="padding: 18px 24px;">
                                <div style="font-size: 11px; font-weight: 800; color: white; text-transform: uppercase;"><%= lead.buyerName %></div>
                                <div style="font-size: 9px; color: #52525b; margin-top: 4px; font-family: monospace;">📞 <%= lead.buyerPhone %></div>
                            </td>
                            
                            <!-- Product Details & Message -->
                            <td style="padding: 18px 24px;">
                                <div style="font-size: 10px; font-weight: 800; color: #C9922A; text-transform: uppercase; margin-bottom: 5px;">📦 <%= lead.productName %></div>
                                <div style="font-size: 10px; color: #a1a1aa; font-style: italic; background: rgba(255,255,255,0.03); padding: 6px 12px; border-radius: 8px; display: inline-block;">
                                    "<%= lead.message.substring(0, 60) %>..."
                                </div>
                            </td>
                            
                            <!-- Status & Date -->
                       <!-- ==========================================
     BUYER DETAILS WITH WHATSAPP INTEGRATION 
=========================================== -->
<td style="padding: 18px 24px; vertical-align: top;">
    <div style="font-size: 13px; font-weight: 800; color: white; text-transform: uppercase;"><%= lead.buyerName %></div>
    
    <div style="display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap;">
        <!-- Call Button -->
        <a href="tel:<%= lead.buyerPhone %>" style="background: rgba(59, 130, 246, 0.1); color: #60a5fa; padding: 5px 10px; border-radius: 6px; font-size: 11px; font-family: monospace; text-decoration: none; border: 1px solid rgba(59, 130, 246, 0.2); transition: 0.2s;" onmouseover="this.style.background='#3b82f6'; this.style.color='white'" onmouseout="this.style.background='rgba(59, 130, 246, 0.1)'; this.style.color='#60a5fa'">
            📞 <%= lead.buyerPhone %>
        </a>
        
        <!-- WhatsApp Magic Button -->
        <a href="https://wa.me/91<%= lead.buyerPhone %>?text=Ram%20Ram%20<%= encodeURIComponent(lead.buyerName) %>,%20I%20saw%20your%20inquiry%20for%20<%= encodeURIComponent(lead.productName) %>%20on%20Bhilwara%20Textile%20Marketplace.%20How%20can%20we%20help%20you?" target="_blank" style="background: rgba(37, 211, 102, 0.1); color: #22c55e; padding: 5px 10px; border-radius: 6px; font-size: 11px; font-weight: bold; text-decoration: none; border: 1px solid rgba(37, 211, 102, 0.2); transition: 0.2s; display: flex; align-items: center; gap: 5px;" onmouseover="this.style.background='#22c55e'; this.style.color='white'" onmouseout="this.style.background='rgba(37, 211, 102, 0.1)'; this.style.color='#22c55e'">
            <i class="fa-brands fa-whatsapp" style="font-size: 13px;"></i> WhatsApp
        </a>
    </div>
</td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" style="padding: 60px; text-align: center; color: #3f3f46; font-size: 9px; text-transform: uppercase; font-weight: 900; letter-spacing: 3px;">
                                <i class="fa-solid fa-satellite-dish" style="font-size: 20px; display: block; margin-bottom: 15px; opacity: 0.2;"></i>
                                Scanning frequencies for buyer signals...
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>