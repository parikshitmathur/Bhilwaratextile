<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen text-gray-800">

    <main class="flex-grow flex justify-center items-center py-12 px-4 sm:px-6 lg:px-8 mt-[72px]">
        
        <div class="max-w-6xl w-full bg-white shadow-2xl rounded-3xl border border-gray-100 overflow-hidden flex flex-col md:flex-row">
            
            <div class="w-full md:w-5/12 bg-[#141210] text-white p-8 sm:p-12 flex flex-col justify-center relative overflow-hidden">
                <div class="absolute top-0 right-0 -mt-10 -mr-10 w-40 h-40 bg-[#C9922A] rounded-full opacity-20 blur-3xl"></div>
                <div class="absolute bottom-0 left-0 -mb-10 -ml-10 w-40 h-40 bg-blue-500 rounded-full opacity-10 blur-3xl"></div>
                
                <div class="relative z-10">
                    <div class="inline-block bg-[#C9922A]/20 text-[#C9922A] border border-[#C9922A]/30 font-semibold px-4 py-1.5 rounded-full text-xs mb-6 tracking-wider uppercase">
                        Grow Your Business
                    </div>
                    <h1 class="text-3xl sm:text-4xl font-extrabold mb-4 leading-tight">Sell Your Textiles <br><span class="text-[#C9922A]">Globally</span></h1>
                    <p class="text-gray-400 text-sm sm:text-base mb-10 leading-relaxed">Join India's premier B2B textile network. Register your company today and connect with thousands of active buyers instantly.</p>

                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="bg-white/10 p-2.5 rounded-lg shrink-0 mt-1">
                                <svg class="w-5 h-5 text-[#C9922A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-white">Global Reach</h3>
                                <p class="text-gray-400 text-xs mt-1">Get inquiries from domestic and international buyers.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="bg-white/10 p-2.5 rounded-lg shrink-0 mt-1">
                                <svg class="w-5 h-5 text-[#C9922A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-white">Increase Sales</h3>
                                <p class="text-gray-400 text-xs mt-1">Boost your revenue with genuine wholesale leads.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="bg-white/10 p-2.5 rounded-lg shrink-0 mt-1">
                                <svg class="w-5 h-5 text-[#C9922A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-white">Verified Platform</h3>
                                <p class="text-gray-400 text-xs mt-1">Trade securely in a 100% verified business ecosystem.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-full md:w-7/12 p-8 sm:p-12 flex flex-col justify-center">
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-gray-900">Register Your Company</h2>
                    <p class="text-gray-500 text-sm mt-1">Fill out the form below to create your seller profile.</p>
                </div>

                <form action="/submit-seller" method="POST" class="space-y-5">
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Company Name <span class="text-red-500">*</span></label>
                            <input type="text" name="companyName" required placeholder="e.g. Bhilwara Fabrics Pvt Ltd" 
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Contact Person <span class="text-red-500">*</span></label>
                            <input type="text" name="contactPerson" required placeholder="Full Name" 
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Mobile Number <span class="text-red-500">*</span></label>
                            <div class="flex rounded-xl overflow-hidden border border-gray-200 focus-within:ring-2 focus-within:ring-[#C9922A]/50 focus-within:border-[#C9922A] transition-all">
                                <span class="inline-flex items-center px-3 border-r border-gray-200 bg-gray-100 text-gray-600 text-sm font-medium">+91</span>
                                <input type="tel" name="mobile" required placeholder="9876543210" 
                                    class="w-full px-4 py-3 bg-gray-50 focus:bg-white focus:outline-none text-sm">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
                            <input type="email" name="email" required placeholder="seller@company.com" 
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">City <span class="text-red-500">*</span></label>
                            <input type="text" name="city" required placeholder="e.g. Bhilwara, Surat" 
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Business Type <span class="text-red-500">*</span></label>
                            <select name="businessType" required class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#C9922A]/50 focus:border-[#C9922A] transition-all text-sm cursor-pointer shadow-sm">
                                <option value="" disabled selected>-- Select Type --</option>
                                <option value="Manufacturer">Manufacturer</option>
                                <option value="Wholesaler">Wholesaler / Distributor</option>
                                <option value="Trader">Trader</option>
                                <option value="Retailer">Retailer</option>
                                <option value="Exporter">Exporter</option>
                            </select>
                        </div>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="w-full bg-[#141210] hover:bg-[#C9922A] text-white font-bold text-base py-3.5 rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
                            Submit Registration
                        </button>
                    </div>
                    
                    <p class="text-center text-xs text-gray-400 mt-4">By submitting, you agree to our Terms of Service and Privacy Policy.</p>
                </form>
            </div>
            
        </div>
    </main>

    <%- include('partials/footer') %>

</body>
</html>